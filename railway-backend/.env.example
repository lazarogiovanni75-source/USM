# Ultimate Social Media Backend - Railway Environment Variables
# =============================================================

# Required API Keys (get from respective services)
# ------------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
SHOTSTACK_API_KEY=your_shotstack_api_key_here
DEFAPI_API_KEY=your_defapi_api_key_here
MAKEAI_API_KEY=your_makeai_api_key_here
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/yyyyy/

# Service Configuration
# ---------------------
PORT=3000
NODE_ENV=production

# CORS Configuration
# Comma-separated list of allowed frontend origins
# Update these with your actual deployment URLs
ALLOWED_ORIGINS=https://your-thread.clacky.app,http://localhost:3000,https://localhost:3000

# ElevenLabs Configuration
# Default voice ID (Adam - professional male voice)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# OpenAI Configuration
# Model to use for content generation
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORG_ID=your_org_id_here  # Optional - only if using organization

# Shotstack Configuration
SHOTSTACK_ENVIRONMENT=stage  # Use "stage" for testing, "prod" for production
SHOTSTACK_WEBHOOK_SECRET=your_webhook_secret_here  # Optional - for verifying webhooks

# Make.com Configuration
MAKEAI_WEBHOOK_URL=https://hook.make.com/your_scenario_id  # Optional

# Optional: Database (if you add database later)
# DATABASE_URL=postgresql://user:password@host:port/database

# Railway Static URL (auto-filled by Railway)
# RAILWAY_STATIC_URL=https://your-app.up.railway.app

# =============================================================
# HOW TO GET EACH API KEY:
# =============================================================

# ELEVENLABS (Text-to-Speech)
# 1. Go to https://elevenlabs.io
# 2. Create account or sign in
# 3. Go to Profile > API Key
# 4. Copy your xi-api-key
# 5. (Optional) Browse Voice Library for custom voice IDs

# OPENAI (AI Content Generation)
# 1. Go to https://platform.openai.com
# 2. Create account or sign in
# 3. Go to API Keys > Create new secret key
# 4. Copy the sk- key (never share this publicly!)
# 5. Check Usage page for rate limits

# SHOTSTACK (Video Generation)
# 1. Go to https://shotstack.io
# 2. Create account or sign in
# 3. Go to Dashboard > API
# 4. Copy your API key
# 5. Use "stage" environment for testing (free tier)

# MAKE (Automation)
# 1. Go to https://make.com
# 2. Create account or sign in
# 3. Go to Profile > API Key
# 4. Copy your API key
# 5. Create scenarios and get webhook URLs

# ZAPIER (Automation Alternative)
# 1. Go to https://zapier.com
# 2. Create account or sign in
# 3. Create new Zap with "Webhooks by Zapier" trigger
# 4. Copy the webhook URL after testing

# DEFAPI (AI Video Generation)
# 1. Go to https://defapi.org
# 2. Create account or sign in
# 3. Go to API Settings > Copy your API key
# 4. Use model: "openai/sora-2" for video generation
# 5. Endpoints: POST /video/start, GET /video/status/:jobId

# =============================================================
