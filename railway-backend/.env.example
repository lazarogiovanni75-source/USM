# Ultimate Social Media Backend - Railway Environment Variables
# =============================================================

# Required API Keys (get from respective services)
# ------------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
SHOTSTACK_API_KEY=your_shotstack_api_key_here
DEFAPI_API_KEY=your_defapi_api_key_here
MAKEAI_API_KEY=your_makeai_api_key_here
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/yyyyy/

# Service Configuration
# ---------------------
PORT=3000
NODE_ENV=production

# CORS Configuration
# Comma-separated list of allowed frontend origins
# Update these with your actual deployment URLs
# For custom domain: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://your-thread.clacky.app,http://localhost:3000,https://localhost:3000

# Database Configuration
# ----------------------
# Use DATABASE_URL for PostgreSQL connection (recommended for Railway)
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://postgres:pgBqpmYZ@127.0.0.1:5432/clacky_app_db

# ElevenLabs Configuration
# Default voice ID (Adam - professional male voice)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# OpenAI Configuration
# Model to use for content generation
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORG_ID=your_org_id_here  # Optional - only if using organization

# Shotstack Configuration
SHOTSTACK_ENVIRONMENT=stage  # Use "stage" for testing, "prod" for production
SHOTSTACK_WEBHOOK_SECRET=your_webhook_secret_here  # Optional - for verifying webhooks

# Make.com Configuration
MAKEAI_WEBHOOK_URL=https://hook.make.com/your_scenario_id  # Optional

# =============================================================
# RAILWAY DEPLOYMENT:
# =============================================================
#
# 1. Create a new Railway project
# 2. Connect your GitHub repository
# 3. Add a PostgreSQL 15.0 service from the Railway marketplace
# 4. Set the following environment variables in Railway:
#    - ELEVENLABS_API_KEY
#    - OPENAI_API_KEY
#    - SHOTSTACK_API_KEY
#    - DEFAPI_API_KEY
#    - MAKEAI_API_KEY
#    - DATABASE_URL (auto-filled when you add PostgreSQL)
#    - ALLOWED_ORIGINS (update with your custom domain)
# 5. Deploy the service
#
# The service will automatically:
# - Connect to PostgreSQL using DATABASE_URL
# - Create required tables on startup
# - Use the API keys for external services
#
# =============================================================
# CUSTOM DOMAIN SETUP:
# =============================================================
#
# To connect a custom domain (e.g., api.yourdomain.com):
#
# 1. In Railway Backend Project:
#    - Settings → Networking → Add Domain
#    - Enter: api.yourdomain.com
#
# 2. In GoDaddy DNS:
#    - Add CNAME record:
#      Type: CNAME
#      Name: api
#      Value: clacky-clean-production-c2a4.up.railway.app
#      TTL: 600
#
# 3. Update Railway Environment Variables:
#    - ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
#
# 4. Wait for DNS propagation (5-30 minutes)
#
# 5. Test: curl https://api.yourdomain.com/health
#
# Full guide: docs/DOMAIN_CONNECTION_GUIDE.md
