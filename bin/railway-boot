#!/usr/bin/env bash
# Railway Boot Script - Ensures environment variables are not overridden
# This script runs BEFORE Rails starts on Railway

set -e

echo "🚂 Railway Boot Script Starting..."

# Check if we're on Railway (Railway sets RAILWAY_ENVIRONMENT)
if [ -n "$RAILWAY_ENVIRONMENT" ]; then
  echo "✅ Detected Railway environment: $RAILWAY_ENVIRONMENT"
  
  # Remove config/application.yml if it exists - it can override Railway ENV vars
  if [ -f "config/application.yml" ]; then
    echo "⚠️  Found config/application.yml - DELETING to prevent ENV override"
    rm -f config/application.yml
    echo "✅ config/application.yml deleted"
  else
    echo "✅ config/application.yml does not exist (good)"
  fi
  
  # Verify critical environment variables are present
  echo ""
  echo "🔍 Checking Railway Environment Variables:"
  
  if [ -n "$ANTHROPIC_API_KEY" ]; then
    echo "✅ ANTHROPIC_API_KEY is set (${ANTHROPIC_API_KEY:0:8}...)"
  else
    echo "❌ ANTHROPIC_API_KEY is NOT set!"
  fi
  
  if [ -n "$ATLASCLOUD_API_KEY" ]; then
    echo "✅ ATLASCLOUD_API_KEY is set (${ATLASCLOUD_API_KEY:0:8}...)"
  else
    echo "❌ ATLASCLOUD_API_KEY is NOT set!"
  fi
  
  echo ""
  echo "🚂 Railway Boot Script Complete - Starting Rails..."
else
  echo "ℹ️  Not on Railway - skipping ENV checks"
fi

# Run migrations
echo "📦 Running database migrations..."
echo "RAILS_ENV: ${RAILS_ENV}"
echo "DATABASE_URL set: $([ -n "$DATABASE_URL" ] && echo 'yes' || echo 'no')"

if RAILS_ENV=production bundle exec rails db:migrate 2>&1; then
  echo "✅ Migrations completed successfully"
else
  echo "❌ Migration failed, checking status..."
  RAILS_ENV=production bundle exec rails db:migrate:status || true
  echo "⚠️  Attempting to continue anyway..."
fi

# Check migration status
echo "🔍 Checking migration status..."
RAILS_ENV=production bundle exec rails db:migrate:status || true

# Run seeds for production
echo "🌱 Running database seeds..."
if RAILS_ENV=production bundle exec rails db:seed 2>&1; then
  echo "✅ Seeds completed successfully"
else
  echo "⚠️  Seeding failed, continuing to start server..."
fi

# Generate sitemap for SEO
echo "🗺️  Generating sitemap..."
if RAILS_ENV=production bundle exec rake sitemap:refresh:no_ping 2>&1; then
  echo "✅ Sitemap generated successfully"
else
  echo "⚠️  Sitemap generation failed, continuing to start server..."
fi

# Build Tailwind CSS first
echo "🎨 Building Tailwind CSS..."
if npm run build:css 2>&1; then
  echo "✅ Tailwind CSS built successfully"
else
  echo "❌ Tailwind CSS build failed"
fi

# Precompile assets if not already present
echo "📦 Checking/Precompiling assets..."
# Check if sprockets manifest exists (Rails creates this during precompilation)
if [ ! -d "public/assets" ] || ! ls public/assets/.sprockets-manifest-*.json 1> /dev/null 2>&1; then
  echo "⚠️  Assets not found - precompiling..."
  if SECRET_KEY_BASE="${SECRET_KEY_BASE:-$RAILS_MASTER_KEY}" RAILS_ENV=production bundle exec rails assets:precompile 2>&1; then
    echo "✅ Assets precompiled successfully"
  else
    echo "❌ Asset precompilation failed, checking if assets exist..."
    ls -la public/assets/ 2>/dev/null || echo "No assets directory"
  fi
else
  echo "✅ Assets already precompiled"
fi

# Start Puma
echo "🚀 Starting Puma web server..."
exec bundle exec puma -C config/puma.rb
