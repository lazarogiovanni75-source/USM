<% connected = platform[:connected] %>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow duration-200">
  <% case platform[:platform] %>
  <% when 'instagram' %>
    <div class="bg-gradient-to-r from-pink-500 via-purple-500 to-pink-600 px-5 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">📸</span>
          <h3 class="text-lg font-bold text-white"><%= platform[:name] || platform[:platform].titleize %></h3>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= connected ? 'bg-green-500/20 text-green-100' : 'bg-white/20 text-white' %>"><%= connected ? 'Connected' : 'Not Connected' %></span>
      </div>
    </div>
  <% when 'twitter' %>
    <div class="bg-gradient-to-r from-gray-800 via-gray-900 to-black px-5 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">𝕏</span>
          <h3 class="text-lg font-bold text-white"><%= platform[:name] || 'Twitter/X' %></h3>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= connected ? 'bg-green-500/20 text-green-100' : 'bg-white/20 text-white' %>"><%= connected ? 'Connected' : 'Not Connected' %></span>
      </div>
    </div>
  <% when 'tiktok' %>
    <div class="bg-gradient-to-r from-red-500 via-pink-500 to-purple-600 px-5 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">🎵</span>
          <h3 class="text-lg font-bold text-white"><%= platform[:name] || 'TikTok' %></h3>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= connected ? 'bg-green-500/20 text-green-100' : 'bg-white/20 text-white' %>"><%= connected ? 'Connected' : 'Not Connected' %></span>
      </div>
    </div>
  <% when 'facebook' %>
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">📘</span>
          <h3 class="text-lg font-bold text-white"><%= platform[:name] || 'Facebook' %></h3>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= connected ? 'bg-green-500/20 text-green-100' : 'bg-white/20 text-white' %>"><%= connected ? 'Connected' : 'Not Connected' %></span>
      </div>
    </div>
  <% when 'linkedin' %>
    <div class="bg-gradient-to-r from-blue-700 to-blue-800 px-5 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">💼</span>
          <h3 class="text-lg font-bold text-white"><%= platform[:name] || 'LinkedIn' %></h3>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= connected ? 'bg-green-500/20 text-green-100' : 'bg-white/20 text-white' %>"><%= connected ? 'Connected' : 'Not Connected' %></span>
      </div>
    </div>
  <% when 'youtube' %>
    <div class="bg-gradient-to-r from-red-600 to-red-700 px-5 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">▶️</span>
          <h3 class="text-lg font-bold text-white"><%= platform[:name] || 'YouTube' %></h3>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= connected ? 'bg-green-500/20 text-green-100' : 'bg-white/20 text-white' %>"><%= connected ? 'Connected' : 'Not Connected' %></span>
      </div>
    </div>
  <% when 'pinterest' %>
    <div class="bg-gradient-to-r from-red-600 to-red-700 px-5 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">📌</span>
          <h3 class="text-lg font-bold text-white"><%= platform[:name] || 'Pinterest' %></h3>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= connected ? 'bg-green-500/20 text-green-100' : 'bg-white/20 text-white' %>"><%= connected ? 'Connected' : 'Not Connected' %></span>
      </div>
    </div>
  <% when 'bluebird' %>
    <div class="bg-gradient-to-r from-blue-400 to-blue-600 px-5 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">🐦</span>
          <h3 class="text-lg font-bold text-white"><%= platform[:name] || 'Bluebird' %></h3>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= connected ? 'bg-green-500/20 text-green-100' : 'bg-white/20 text-white' %>"><%= connected ? 'Connected' : 'Not Connected' %></span>
      </div>
    </div>
  <% when 'threads' %>
    <div class="bg-gradient-to-r from-gray-700 to-gray-900 px-5 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-2xl">@</span>
          <h3 class="text-lg font-bold text-white"><%= platform[:name] || 'Threads' %></h3>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= connected ? 'bg-green-500/20 text-green-100' : 'bg-white/20 text-white' %>"><%= connected ? 'Connected' : 'Not Connected' %></span>
      </div>
    </div>
  <% end %>

  <% if connected %>
    <div class="p-5">
      <div class="grid grid-cols-2 gap-4">
        <div class="text-center p-3 bg-gray-50 rounded-lg">
          <p class="text-sm text-gray-500">Followers</p>
          <p class="text-lg font-bold text-gray-900"><%= number_with_delimiter(platform[:followers]) %></p>
        </div>
        <div class="text-center p-3 bg-gray-50 rounded-lg">
          <p class="text-sm text-gray-500">Likes</p>
          <p class="text-lg font-bold text-gray-900"><%= number_with_delimiter(platform[:likes]) %></p>
        </div>
        <div class="text-center p-3 bg-gray-50 rounded-lg">
          <p class="text-sm text-gray-500">Views</p>
          <p class="text-lg font-bold text-gray-900"><%= number_with_delimiter(platform[:views]) %></p>
        </div>
        <div class="text-center p-3 bg-gray-50 rounded-lg">
          <p class="text-sm text-gray-500">Engagement</p>
          <p class="text-lg font-bold text-gray-900"><%= number_with_delimiter(platform[:engagement]) %></p>
        </div>
        <div class="text-center p-3 bg-gray-50 rounded-lg">
          <p class="text-sm text-gray-500">Shares</p>
          <p class="text-lg font-bold text-gray-900"><%= number_with_delimiter(platform[:shares]) %></p>
        </div>
        <div class="text-center p-3 bg-green-50 rounded-lg">
          <p class="text-sm text-green-600">New Followers</p>
          <p class="text-lg font-bold text-green-600">+<%= number_with_delimiter(platform[:new_followers]) %></p>
        </div>
        <div class="text-center p-3 bg-red-50 rounded-lg">
          <p class="text-sm text-red-600">Unfollowers</p>
          <p class="text-lg font-bold text-red-600">-<%= number_with_delimiter(platform[:unfollowers]) %></p>
        </div>
        <div class="text-center p-3 bg-gray-50 rounded-lg">
          <p class="text-sm text-gray-500">Messages/DM</p>
          <p class="text-lg font-bold text-gray-900"><%= number_with_delimiter(platform[:messages]) %></p>
        </div>
      </div>
    </div>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-gray-500 mb-4">Connect your <%= platform[:name] %> account to see metrics</p>
      <%= link_to "Connect Account", social_account_connections_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>
