<!-- Waitlist Entry Details -->
<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6">
      <%= link_to 'Back to Waitlist', waitlists_path, class: "text-primary hover:text-primary/80" %>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h1 class="text-2xl font-bold text-gray-900">Waitlist Entry</h1>
      </div>
      <div class="px-6 py-4">
        <dl>
          <div class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
            <div>
              <dt class="text-sm font-medium text-gray-500">Email</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @waitlist.email %></dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Signed Up</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @waitlist.created_at.strftime('%B %d, %Y at %l:%M %p') %></dd>
            </div>
          </div>
        </dl>
      </div>
      <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex gap-4">
        <%= link_to 'Edit', edit_waitlist_path(@waitlist), class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary hover:bg-primary/90" %>
        <%= button_to 'Delete', waitlist_path(@waitlist), method: :delete, data: { confirm: 'Are you sure?' }, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700" %>
      </div>
    </div>
  </div>
</div>
