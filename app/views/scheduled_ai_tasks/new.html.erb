<% content_for :title, "New AI Task" %>

<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated py-8">
  <div class="container-xl mx-auto px-4">
    <!-- Header -->
    <div class="mb-6">
      <%= link_to scheduled_ai_tasks_path, class: "inline-flex items-center text-sm text-muted hover:text-primary transition-colors mb-4" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
        Back to AI Tasks
      <% end %>
      <h1 class="text-3xl font-bold text-primary">Create Scheduled AI Task</h1>
      <p class="text-muted mt-2">Automate your AI-powered content operations</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
      <%= form_with model: @task, url: scheduled_ai_tasks_path, local: true, class: "space-y-6" do |f| %>
        <!-- Name -->
        <div>
          <%= f.label :name, "Task Name", class: "block text-sm font-medium text-primary mb-2" %>
          <%= f.text_field :name, class: "form-input w-full", placeholder: "e.g., Daily Content Generation" %>
          <% if @task.errors[:name].any? %>
            <p class="mt-1 text-sm text-red-600"><%= @task.errors[:name].first %></p>
          <% end %>
        </div>

        <!-- Description -->
        <div>
          <%= f.label :description, "Description", class: "block text-sm font-medium text-primary mb-2" %>
          <%= f.text_area :description, rows: 3, class: "form-input w-full", placeholder: "Describe what this task does..." %>
        </div>

        <!-- Task Type -->
        <div>
          <%= f.label :task_type, "Task Type", class: "block text-sm font-medium text-primary mb-2" %>
          <%= f.select :task_type, 
              ScheduledAiTask.task_types.keys.map { |k| [k.titleize, k] },
              { prompt: "Select task type..." },
              class: "form-input w-full" %>
          <% if @task.errors[:task_type].any? %>
            <p class="mt-1 text-sm text-red-600"><%= @task.errors[:task_type].first %></p>
          <% end %>
          <p class="mt-1 text-xs text-muted">What should this AI task do?</p>
        </div>

        <!-- Schedule Type -->
        <div>
          <%= f.label :schedule_type, "Schedule Type", class: "block text-sm font-medium text-primary mb-2" %>
          <%= f.select :schedule_type,
              ScheduledAiTask.schedule_types.keys.map { |k| [k.titleize, k] },
              { prompt: "Select schedule..." },
              class: "form-input w-full" %>
          <% if @task.errors[:schedule_type].any? %>
            <p class="mt-1 text-sm text-red-600"><%= @task.errors[:schedule_type].first %></p>
          <% end %>
          <p class="mt-1 text-xs text-muted">How often should this task run?</p>
        </div>

        <!-- Next Run At -->
        <div>
          <%= f.label :next_run_at, "Next Run Time", class: "block text-sm font-medium text-primary mb-2" %>
          <%= f.datetime_field :next_run_at, class: "form-input w-full" %>
          <p class="mt-1 text-xs text-muted">When should this task first run?</p>
        </div>

        <!-- Status -->
        <div>
          <%= f.label :status, "Status", class: "block text-sm font-medium text-primary mb-2" %>
          <div class="flex items-center gap-4">
            <label class="inline-flex items-center">
              <%= f.radio_button :status, 'active', checked: true, class: "form-radio" %>
              <span class="ml-2 text-sm text-primary">Active</span>
            </label>
            <label class="inline-flex items-center">
              <%= f.radio_button :status, 'paused', class: "form-radio" %>
              <span class="ml-2 text-sm text-primary">Paused</span>
            </label>
            <label class="inline-flex items-center">
              <%= f.radio_button :status, 'inactive', class: "form-radio" %>
              <span class="ml-2 text-sm text-primary">Inactive</span>
            </label>
          </div>
        </div>

        <!-- Configuration (Advanced) -->
        <div class="border-t border-border/30 pt-6">
          <h3 class="text-lg font-medium text-primary mb-4">Advanced Configuration</h3>
          
          <div>
            <%= f.label :config, "Task Configuration (JSON)", class: "block text-sm font-medium text-primary mb-2" %>
            <%= f.text_area :config, rows: 6, class: "form-input w-full font-mono text-sm", placeholder: '{}' %>
            <p class="mt-1 text-xs text-muted">Custom configuration as JSON object (optional)</p>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex gap-3 pt-4">
          <%= f.submit "Create Task", class: "btn-primary" %>
          <%= link_to "Cancel", scheduled_ai_tasks_path, class: "btn-secondary" %>
        </div>
      <% end %>
    </div>

    <!-- Templates -->
    <% if @task_templates&.any? %>
      <div class="mt-8">
        <h2 class="text-xl font-bold text-primary mb-4">Quick Start Templates</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @task_templates.each do |template| %>
            <div class="bg-white rounded-xl p-5 border border-border/50 hover:shadow-md transition-shadow">
              <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center">
                  <%= lucide_icon "bot", class: "w-5 h-5 text-white" %>
                </div>
                <span class="px-2 py-1 rounded-full text-xs bg-primary/10 text-primary"><%= template[:schedule_type]&.titleize %></span>
              </div>
              <h3 class="font-medium text-primary mb-2"><%= template[:name] %></h3>
              <p class="text-sm text-muted mb-4"><%= template[:description] %></p>
              <%= button_to "Use Template", create_from_template_scheduled_ai_tasks_path(template_id: template[:id]), method: :post, class: "text-sm text-primary hover:underline" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
