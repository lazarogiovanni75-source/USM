<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Scheduled AI Tasks</h1>
          <p class="mt-2 text-gray-600">Automate recurring AI operations and content management</p>
        </div>
        <div class="flex items-center space-x-3">
          <% if @due_tasks.any? %>
            <%= link_to execute_all_due_scheduled_ai_tasks_path, 
                method: :post,
                data: { confirm: "Execute #{@due_tasks.count} due tasks?" },
                class: "btn-secondary inline-flex items-center px-4 py-2 rounded-lg border border-green-300 bg-green-50 text-green-700 hover:bg-green-100 transition-colors" do %>
              <%= lucide_icon "play", class: "w-5 h-5 mr-2" %>
              Execute Due Tasks
            <% end %>
          <% end %>
          <%= link_to new_scheduled_ai_task_path, 
              class: "btn-primary inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
            <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
            New Task
          <% end %>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "clock", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @due_tasks.count %>
            </div>
            <div class="text-sm text-gray-600">Tasks Due Now</div>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "check-circle", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @statistics[:successful_executions] %>
            </div>
            <div class="text-sm text-gray-600">Successful Executions</div>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-purple-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "zap", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @statistics[:success_rate] %>%
            </div>
            <div class="text-sm text-gray-600">Success Rate</div>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "repeat", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @tasks.active.count %>
            </div>
            <div class="text-sm text-gray-600">Active Tasks</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Active Tasks -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold text-gray-900">Your Scheduled AI Tasks</h2>
        </div>
      </div>
      
      <% if @tasks.any? %>
        <div class="divide-y divide-gray-200">
          <% @tasks.each do |task| %>
            <div class="p-6">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="flex items-center mb-2">
                    <h3 class="text-lg font-medium text-gray-900 mr-3"><%= task.name %></h3>
                    <% if task.active? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <div class="w-1.5 h-1.5 bg-green-400 rounded-full mr-1.5"></div>
                        Active
                      </span>
                    <% elsif task.paused? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                        <div class="w-1.5 h-1.5 bg-yellow-400 rounded-full mr-1.5"></div>
                        Paused
                      </span>
                    <% else %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                        <div class="w-1.5 h-1.5 bg-gray-400 rounded-full mr-1.5"></div>
                        Inactive
                      </span>
                    <% end %>
                    
                    <% if task.due? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 ml-2">
                        <%= lucide_icon "clock", class: "w-3 h-3 mr-1" %>
                        Due
                      </span>
                    <% end %>
                  </div>
                  
                  <p class="text-gray-600 text-sm mb-3"><%= task.description %></p>
                  
                  <div class="flex flex-wrap gap-2">
                    <span class="inline-block text-xs px-2 py-1 bg-blue-100 text-blue-800 rounded-full">
                      <%= task.task_type.gsub('_', ' ').titleize %>
                    </span>
                    <span class="inline-block text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded-full">
                      <%= task.schedule_type.titleize %>
                    </span>
                    <% if task.next_run_at %>
                      <span class="inline-block text-xs px-2 py-1 bg-purple-100 text-purple-600 rounded-full">
                        Next: <%= task.next_run_at.strftime('%m/%d %I:%M %p') %>
                      </span>
                    <% end %>
                  </div>
                </div>
                
                <div class="flex items-center space-x-2 ml-4">
                  <%= link_to execute_now_scheduled_ai_task_path(task), 
                      method: :post,
                      class: "text-blue-600 hover:text-blue-700 text-sm font-medium" do %>
                    Execute Now
                  <% end %>
                  
                  <%= link_to toggle_status_scheduled_ai_task_path(task), 
                      method: :post,
                      class: "text-gray-600 hover:text-gray-700 text-sm font-medium" do %>
                    <%= task.active? ? 'Disable' : 'Enable' %>
                  <% end %>
                  
                  <%= link_to edit_scheduled_ai_task_path(task), 
                      class: "text-gray-600 hover:text-gray-700 text-sm font-medium" do %>
                    Edit
                  <% end %>
                  
                  <%= link_to scheduled_ai_task_path(task), 
                      method: :delete,
                      data: { confirm: 'Are you sure?' },
                      class: "text-red-600 hover:text-red-700 text-sm font-medium" do %>
                    Delete
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-8 text-center">
          <%= lucide_icon "robot", class: "w-12 h-12 text-gray-300 mx-auto mb-4" %>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No scheduled AI tasks created</h3>
          <p class="text-gray-500 mb-4">Get started by creating your first scheduled AI task</p>
          <%= link_to new_scheduled_ai_task_path, 
              class: "btn-primary inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
            <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
            Create First Task
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>