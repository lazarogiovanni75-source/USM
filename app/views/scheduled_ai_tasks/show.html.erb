<% content_for :title, @task.name %>

<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated py-8">
  <div class="container-xl mx-auto px-4">
    <!-- Header -->
    <div class="mb-6">
      <%= link_to scheduled_ai_tasks_path, class: "inline-flex items-center text-sm text-muted hover:text-primary transition-colors mb-4" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
        Back to AI Tasks
      <% end %>
      
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-primary mb-2"><%= @task.name %></h1>
          <p class="text-muted"><%= @task.description %></p>
        </div>
        <div class="flex gap-2">
          <%= button_to execute_now_scheduled_ai_task_path(@task), method: :post, class: "btn-secondary" do %>
            <%= lucide_icon "play-circle", class: "w-4 h-4 mr-2" %>Execute Now
          <% end %>
          <%= link_to edit_scheduled_ai_task_path(@task), class: "btn-primary" do %>
            <%= lucide_icon "edit-2", class: "w-4 h-4 mr-2" %>Edit
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Details Card -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h2 class="text-lg font-bold text-primary mb-4">Task Details</h2>
          
          <div class="space-y-4">
            <div>
              <span class="text-sm font-medium text-muted">Task Type</span>
              <p class="text-primary font-medium mt-1"><%= @task.task_type&.titleize %></p>
            </div>
            
            <div>
              <span class="text-sm font-medium text-muted">Schedule Type</span>
              <p class="text-primary font-medium mt-1"><%= @task.schedule_type&.titleize %></p>
            </div>
            
            <div>
              <span class="text-sm font-medium text-muted">Status</span>
              <div class="mt-1">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium 
                  <%= case @task.status
                      when 'active' then 'bg-green-100 text-green-700'
                      when 'paused' then 'bg-yellow-100 text-yellow-700'
                      else 'bg-gray-100 text-gray-700'
                      end %>">
                  <div class="w-2 h-2 rounded-full mr-2
                    <%= case @task.status
                        when 'active' then 'bg-green-400'
                        when 'paused' then 'bg-yellow-400'
                        else 'bg-gray-400'
                        end %>"></div>
                  <%= @task.status&.titleize %>
                </span>
              </div>
            </div>
            
            <% if @task.next_run_at %>
              <div>
                <span class="text-sm font-medium text-muted">Next Run</span>
                <p class="text-primary font-medium mt-1"><%= @task.next_run_at.strftime('%B %d, %Y %I:%M %p') %></p>
                <% if @task.due? %>
                  <span class="inline-flex items-center mt-2 px-2 py-1 rounded-full text-xs bg-blue-100 text-blue-700">
                    <%= lucide_icon "clock", class: "w-3 h-3 mr-1" %>Overdue
                  </span>
                <% end %>
              </div>
            <% end %>
            
            <% if @task.config.present? && @task.config.any? %>
              <div>
                <span class="text-sm font-medium text-muted">Configuration</span>
                <pre class="mt-2 p-3 bg-gray-50 rounded-lg text-xs font-mono overflow-x-auto"><%= JSON.pretty_generate(@task.config) %></pre>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Execution History -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50">
          <div class="px-6 py-4 border-b border-border/30">
            <h2 class="text-lg font-bold text-primary">Execution History</h2>
          </div>
          
          <% if @executions&.any? %>
            <div class="divide-y divide-border/30">
              <% @executions.each do |execution| %>
                <div class="p-4">
                  <div class="flex items-center justify-between">
                    <div class="flex-1">
                      <p class="text-sm text-primary font-medium"><%= execution.action_taken || 'Executed' %></p>
                      <p class="text-xs text-muted mt-1"><%= execution.created_at.strftime('%b %d, %Y %I:%M %p') %></p>
                    </div>
                    <span class="px-2 py-1 rounded-full text-xs <%= execution.successful? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                      <%= execution.successful? ? 'Success' : 'Failed' %>
                    </span>
                  </div>
                  <% if execution.error_message.present? %>
                    <p class="text-xs text-red-600 mt-2"><%= execution.error_message %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="p-12 text-center">
              <%= lucide_icon "clock", class: "w-12 h-12 text-muted mx-auto mb-3" %>
              <p class="text-muted">No executions yet</p>
            </div>
          <% end %>
        </div>

        <!-- Recent Results -->
        <% if @results&.any? %>
          <div class="bg-white rounded-2xl shadow-sm border border-border/50">
            <div class="px-6 py-4 border-b border-border/30">
              <h2 class="text-lg font-bold text-primary">Recent Results</h2>
            </div>
            
            <div class="divide-y divide-border/30">
              <% @results.each do |result| %>
                <div class="p-4">
                  <p class="text-sm text-primary font-medium"><%= result.result_type&.titleize %></p>
                  <p class="text-xs text-muted mt-1"><%= result.created_at.strftime('%b %d, %Y %I:%M %p') %></p>
                  <% if result.result_data.present? %>
                    <div class="mt-2 p-2 bg-gray-50 rounded text-xs">
                      <%= result.result_data.to_s.truncate(200) %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Stats -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-lg font-bold text-primary mb-4">Statistics</h3>
          
          <div class="space-y-4">
            <div>
              <span class="text-sm text-muted">Total Executions</span>
              <p class="text-2xl font-bold text-primary mt-1"><%= @statistics[:total_executions] || 0 %></p>
            </div>
            
            <div>
              <span class="text-sm text-muted">Successful</span>
              <p class="text-2xl font-bold text-green-600 mt-1"><%= @statistics[:successful_executions] || 0 %></p>
            </div>
            
            <div>
              <span class="text-sm text-muted">Success Rate</span>
              <p class="text-2xl font-bold text-primary mt-1"><%= @statistics[:success_rate] || 0 %>%</p>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-lg font-bold text-primary mb-4">Quick Actions</h3>
          
          <div class="space-y-3">
            <%= button_to execute_now_scheduled_ai_task_path(@task), method: :post, class: "w-full btn-secondary justify-center" do %>
              <%= lucide_icon "play-circle", class: "w-4 h-4 mr-2" %>
              Execute Now
            <% end %>
            
            <%= button_to toggle_status_scheduled_ai_task_path(@task), method: :post, class: "w-full btn-secondary justify-center" do %>
              <%= lucide_icon (@task.active? ? 'pause' : 'play'), class: "w-4 h-4 mr-2" %>
              <%= case @task.status
                  when 'active' then 'Pause Task'
                  when 'paused' then 'Resume Task'
                  else 'Activate Task'
                  end %>
            <% end %>
            
            <%= link_to edit_scheduled_ai_task_path(@task), class: "w-full btn-primary justify-center" do %>
              <%= lucide_icon "edit-2", class: "w-4 h-4 mr-2" %>
              Edit Task
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
