<% content_for :title, "Otto-Chat" %>
<!-- stimulus-validator: disable-next-line -->

<div class="bg-gradient-to-br from-purple-50 via-white to-purple-100 dark:from-purple-900 dark:via-gray-900 dark:to-purple-900 relative" 
     data-controller="ai-chat"
     data-voice-message="<%= @voice_message %>"
     data-conversation-id="<%= @current_conversation&.id %>">
  <!-- Decorative Background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-64 h-64 bg-purple-300/30 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute top-40 right-20 w-96 h-96 bg-indigo-300/30 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  </div>

  <!-- Header -->
  <div class="bg-white/80 backdrop-blur-lg border-b border-purple-200 dark:border-purple-800 sticky top-0 z-40 relative">
    <div class="container-xl mx-auto px-4">
      <div class="flex justify-between items-center py-4">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center shadow-lg">
            <%= lucide_icon "bot", class: "w-6 h-6 text-white" %>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-purple-700 dark:text-white">Otto-Chat</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400">Your intelligent marketing companion</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <button id="new-chat-btn" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors" data-action="ai-chat#createNewConversation">
            <%= lucide_icon "plus", class: "w-4 h-4 mr-2" %>
            New Chat
          </button>
        </div>
      </div>
      
      <!-- Tabs -->
      <div class="flex gap-2 pb-4 overflow-x-auto items-center">
        <%= link_to ai_chat_index_path, class: "flex items-center gap-2 px-4 py-2 bg-white border border-purple-200 rounded-xl hover:bg-purple-50 transition-all whitespace-nowrap #{controller_name == 'ai_chat' ? 'bg-gradient-to-r from-purple-500 to-indigo-600 text-white' : 'text-purple-700'}" do %>
          <%= lucide_icon "message-circle", class: "w-4 h-4" %>
          Text Chat
        <% end %>
        <%= link_to content_creation_index_path, class: "flex items-center gap-2 px-4 py-2 bg-white border border-purple-200 rounded-xl hover:bg-purple-50 transition-all whitespace-nowrap #{controller_name == 'content_creation' ? 'bg-gradient-to-r from-purple-500 to-indigo-600 text-white' : 'text-purple-700'}" do %>
          <%= lucide_icon "sparkles", class: "w-4 h-4" %>
          Content
        <% end %>
        <%= link_to scheduled_posts_path, class: "flex items-center gap-2 px-4 py-2 bg-white border border-purple-200 rounded-xl hover:bg-purple-50 transition-all whitespace-nowrap #{controller_name == 'scheduled_posts' ? 'bg-gradient-to-r from-purple-500 to-indigo-600 text-white' : 'text-purple-700'}" do %>
          <%= lucide_icon "calendar", class: "w-4 h-4" %>
          Scheduled
        <% end %>
      </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <%# Otto-Chat page: Show the navbar voice button here too %>
<style>
  /* No hiding - show the button on Otto-Chat */
</style>

<div class="container-xl mx-auto px-4 py-6 relative min-h-screen">
    <!-- Main Chat Area (TOP - Full Width) -->
    <div class="bg-white dark:bg-gray-800 backdrop-blur-sm rounded-2xl shadow-sm border border-purple-200 dark:border-purple-700 h-[600px] flex flex-col overflow-hidden mb-6">
      
      <!-- Chat Messages -->
      <div id="chat-messages" class="flex-1 p-6 overflow-y-auto" data-ai-chat-target="messagesContainer">
        <!-- Voice Transcript Display -->
        <div id="voice-transcript-display" class="hidden mb-4 p-4 bg-green-500/10 border border-green-500/30 rounded-xl">
          <p class="text-sm text-green-700 font-medium mb-1">🎤 You said:</p>
          <p id="voice-transcript" class="text-gray-900 dark:text-white"></p>
        </div>
        <!-- END Voice Response Display -->

        <% end %>
      </div>
      <!-- END Chat Messages -->

      </div>
      <!-- END Chat Input Area -->
    </div>
    <!-- END Main Chat Area -->

    <!-- 3-Column Sidebar Below Chat -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Voice Prompts (LEFT - now column 1) -->
      <div class="bg-white dark:bg-gray-800 backdrop-blur-sm rounded-2xl shadow-sm border border-purple-200 dark:border-purple-700 p-4">
        <h2 class="text-lg font-bold text-purple-700 dark:text-white mb-3 flex items-center gap-2">
          <%= lucide_icon "mic", class: "w-5 h-5" %>
          Voice Prompts
        </h2>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">Try saying these commands to Otto-Pilot:</p>
        
        <div id="voice-prompts-list" class="space-y-3 max-h-[400px] overflow-y-auto">
          <div class="prompt-category">
            <h3 class="text-xs font-semibold text-purple-600 dark:text-purple-400 mb-2 uppercase tracking-wide">📝 Content Creation</h3>
            <div class="space-y-1.5">
              <button class="quick-prompt w-full text-left p-2 rounded-lg hover:bg-purple-50 dark:hover:bg-gray-700 text-xs text-gray-700 dark:text-gray-300 transition-all border border-transparent hover:border-purple-200"
                      data-prompt="Create a social media post about our new product launch">
                "Create a social media post about our new product launch"
              </button>
              <button class="quick-prompt w-full text-left p-2 rounded-lg hover:bg-purple-50 dark:hover:bg-gray-700 text-xs text-gray-700 dark:text-gray-300 transition-all border border-transparent hover:border-purple-200"
                      data-prompt="Generate three Instagram captions for a fitness brand">
                "Generate three Instagram captions for a fitness brand"
              </button>
            </div>
          </div>

          <div class="prompt-category pt-2 border-t border-gray-200 dark:border-gray-700">
            <h3 class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 mb-2 uppercase tracking-wide">📅 Scheduling</h3>
            <div class="space-y-1.5">
              <button class="quick-prompt w-full text-left p-2 rounded-lg hover:bg-purple-50 dark:hover:bg-gray-700 text-xs text-gray-700 dark:text-gray-300 transition-all border border-transparent hover:border-purple-200"
                      data-prompt="Schedule my Instagram post for tomorrow at 3 PM">
                "Schedule my Instagram post for tomorrow at 3 PM"
              </button>
              <button class="quick-prompt w-full text-left p-2 rounded-lg hover:bg-purple-50 dark:hover:bg-gray-700 text-xs text-gray-700 dark:text-gray-300 transition-all border border-transparent hover:border-purple-200"
                      data-prompt="Show me all my scheduled posts for this week">
                "Show me all my scheduled posts for this week"
              </button>
            </div>
          </div>

          <div class="prompt-category pt-2 border-t border-gray-200 dark:border-gray-700">
            <h3 class="text-xs font-semibold text-green-600 dark:text-green-400 mb-2 uppercase tracking-wide">🚀 Campaign</h3>
            <div class="space-y-1.5">
              <button class="quick-prompt w-full text-left p-2 rounded-lg hover:bg-purple-50 dark:hover:bg-gray-700 text-xs text-gray-700 dark:text-gray-300 transition-all border border-transparent hover:border-purple-200"
                      data-prompt="Help me create a campaign for our holiday promotion">
                "Help me create a campaign for our holiday promotion"
              </button>
              <button class="quick-prompt w-full text-left p-2 rounded-lg hover:bg-purple-50 dark:hover:bg-gray-700 text-xs text-gray-700 dark:text-gray-300 transition-all border border-transparent hover:border-purple-200"
                      data-prompt="Start a new product launch campaign">
                "Start a new product launch campaign"
              </button>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Otto Settings (RIGHT) -->
      <div class="bg-white dark:bg-gray-800 backdrop-blur-sm rounded-2xl shadow-sm border border-purple-200 dark:border-purple-700 p-5">
        <h2 class="text-lg font-bold text-purple-700 dark:text-white mb-4 flex items-center gap-2">
          <%= lucide_icon "user-cog", class: "w-5 h-5" %>
          Otto Settings
        </h2>
        
        <!-- Auto-Speak Toggle with Test Button -->
        <div class="flex items-center justify-between py-3 border-b border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900 flex items-center justify-center">
              <%= lucide_icon "volume-2", class: "w-4 h-4 text-purple-600 dark:text-purple-400" %>
            </div>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Auto-voice</span>
          </div>
          <div class="flex items-center gap-2">
            <button id="test-voice-btn" type="button" class="text-xs px-2 py-1 bg-purple-100 dark:bg-purple-800 text-purple-600 dark:text-purple-400 rounded-lg hover:bg-purple-200">
              Test
            </button>
            <button id="auto-speak-toggle" type="button" class="relative inline-flex h-8 w-14 items-center rounded-full bg-purple-600 hover:bg-purple-700 transition-colors cursor-pointer">
              <span class="inline-block h-6 w-6 transform rounded-full bg-white shadow-lg transition-transform translate-x-7"></span>
            </button>
          </div>
        </div>
        
        <!-- Voice Selection -->
        <div class="py-3 border-b border-gray-100 dark:border-gray-700">
          <label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2 block">Voice</label>
          <div class="relative">
            <select id="voice-select" class="w-full px-4 py-2.5 bg-purple-50 dark:bg-gray-700 border border-purple-200 dark:border-gray-600 rounded-xl text-sm text-gray-900 dark:text-white appearance-none cursor-pointer hover:border-purple-400 focus:outline-none focus:ring-2 focus:ring-purple-500/50">
              <option value="alloy">👨 Alloy (Male)</option>
              <option value="echo">👨 Echo (Male)</option>
              <option value="onyx">👨 Onyx (Male)</option>
              <option value="fable">🧑 Fable (Neutral)</option>
              <option value="nova">👩 Nova (Female)</option>
              <option value="shimmer">👩 Shimmer (Female)</option>
            </select>
            <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">
              <%= lucide_icon "chevron-down", class: "w-4 h-4 text-gray-400" %>
            </div>
          </div>
        </div>
        
        <!-- Speech Rate -->
        <div class="py-3 border-b border-gray-100 dark:border-gray-700">
          <label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2 block">
            Speed: <span id="speech-rate-value" class="text-purple-600 font-bold">1.0x</span>
          </label>
          <div class="flex items-center gap-3">
            <%= lucide_icon "snail", class: "w-4 h-4 text-gray-400" %>
            <input type="range" id="speech-rate" min="0.5" max="2" step="0.1" value="1" 
                   class="flex-1 h-2 bg-purple-200 dark:bg-gray-600 rounded-lg appearance-none cursor-pointer accent-purple-600">
            <%= lucide_icon "zap", class: "w-4 h-4 text-gray-400" %>
          </div>
        </div>
        
        <!-- AI Personality -->
        <div class="pt-2">
          <label class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2 block">Personality</label>
          <div class="relative">
            <select id="ai-personality" class="w-full px-4 py-2.5 bg-purple-50 dark:bg-gray-700 border border-purple-200 dark:border-gray-600 rounded-xl text-sm text-gray-900 dark:text-white appearance-none cursor-pointer hover:border-purple-400 focus:outline-none focus:ring-2 focus:ring-purple-500/50">
              <option value="default">🤖 Helpful Assistant</option>
              <option value="friendly">😊 Friendly & Casual</option>
              <option value="professional">💼 Professional & Direct</option>
              <option value="creative">🎨 Creative & Witty</option>
              <option value="expert">📊 Marketing Expert</option>
            </select>
            <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">
              <%= lucide_icon "chevron-down", class: "w-4 h-4 text-gray-400" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render 'ai_chat/otto_pilot_button' %>

<!-- Voice Command Modal -->
<div id="voice-command-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center" data-controller="voice-command-toggle">
  <div class="fixed inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="relative bg-white dark:bg-gray-800 rounded-3xl shadow-2xl p-8 max-w-md w-full mx-4 transform transition-all scale-95 opacity-0">
    <div class="text-center">
      <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center shadow-lg animate-pulse">
        <%= lucide_icon "mic", class: "w-12 h-12 text-white" %>
      </div>
      <h2 class="text-2xl font-bold text-primary mb-2">Otto-Chat</h2>
      <p class="text-gray-600 dark:text-gray-300 mb-6">Speak your commands to create campaigns, generate content, and manage your social media</p>
      
      <div class="bg-gray-50 dark:bg-gray-700 rounded-2xl p-4 mb-4 min-h-[80px]">
        <p id="voice-transcript" class="text-gray-900 dark:text-white text-lg mb-2">Listening...</p>
        <div id="voice-response" class="hidden">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">AI Response:</p>
          <p id="voice-response-text" class="text-gray-900 dark:text-white text-sm"></p>
        </div>
        <p id="voice-status" class="text-xs text-gray-500 mt-2"></p>
      </div>
      
      <button class="w-full py-3 bg-gradient-to-r from-purple-500 to-indigo-600 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all" data-action="voice-command-toggle#closeModal">
        Close Voice Command
      </button>
    </div>
  </div>
</div>
