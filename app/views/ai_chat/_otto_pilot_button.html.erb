<!-- Floating Voice Button - Otto-Pilot -->
<button id="voice-float-btn"
        type="button"
        data-controller="simple-voice"
        data-action="simple-voice#toggle"
        class="fixed bottom-8 left-1/2 transform -translate-x-1/2 z-50 flex items-center gap-2 px-4 py-3 rounded-full bg-gradient-to-br from-red-500 to-red-600 shadow-lg shadow-red-500/30 hover:scale-110 transition-transform group cursor-pointer wake-word-active:from-green-500 wake-word-active:to-green-600 wake-word-active:shadow-green-500/30 wake-word-detected:from-purple-500 wake-word-detected:to-purple-600 wake-word-detected:shadow-purple-500/30 wake-word-detected:animate-pulse">
  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
  </svg>
  <span class="text-white font-medium text-sm pr-1">Otto-Pilot</span>
</button>
