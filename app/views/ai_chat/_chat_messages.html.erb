<div id="chat-messages" class="flex-1 p-6 overflow-y-auto" data-ai-chat-target="messagesContainer">
  <% if messages.any? %>
    <% messages.each do |message| %>
      <% suggested_actions = message.metadata&.dig('suggested_actions') || [] %>
      <div class="message <%= message.role %> mb-4 flex <%= message.role == 'user' ? 'justify-end' : 'justify-start' %>">
        <div class="flex <%= message.role == 'user' ? 'flex-row-reverse' : 'flex-row' %> items-start gap-3 max-w-3xl">
          <div class="flex-shrink-0">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center <%= message.role == 'user' ? 'bg-gradient-to-br from-primary to-secondary' : 'bg-gradient-to-br from-green-500 to-emerald-500' %>">
              <% if message.role == 'user' %>
                <%= lucide_icon "user", class: "w-5 h-5 text-white" %>
              <% else %>
                <%= lucide_icon "bot", class: "w-5 h-5 text-white" %>
              <% end %>
            </div>
          </div>
          <div class="<%= message.role == 'user' ? 'text-right' : 'text-left' %>">
            <div class="inline-block p-4 rounded-2xl <%= message.role == 'user' ? 'bg-gradient-to-br from-primary to-secondary text-white' : 'bg-surface border border-border/50 text-primary' %> shadow-sm">
              <p class="text-sm whitespace-pre-wrap"><%= message.content %></p>
            </div>
            <% if suggested_actions.any? && message.role == 'assistant' %>
              <div class="mt-2 flex flex-wrap gap-2 justify-start">
                <% suggested_actions.each do |action| %>
                  <% action_type = action['type'] || action[:type] %>
                  <% action_label = action['label'] || action[:label] || 'Action' %>
                  <% action_data = action['data'] || action[:data] || {} %>
                  <button
                    type="button"
                    data-action="click->ai-chat#handleSuggestedAction"
                    data-action-type="<%= action_type %>"
                    data-action-data="<%= action_data.to_json %>"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-primary to-secondary text-white text-sm font-medium rounded-full hover:shadow-lg hover:scale-105 transition-all duration-200"
                  >
                    <% case action_type %>
                    <% when 'generate_image' %>
                      <%= lucide_icon "image", class: "w-4 h-4" %>
                    <% when 'generate_video' %>
                      <%= lucide_icon "video", class: "w-4 h-4" %>
                    <% when 'create_campaign' %>
                      <%= lucide_icon "megaphone", class: "w-4 h-4" %>
                    <% when 'generate_content' %>
                      <%= lucide_icon "file-text", class: "w-4 h-4" %>
                    <% else %>
                      <%= lucide_icon "play", class: "w-4 h-4" %>
                    <% end %>
                    <%= action_label %>
                  </button>
                <% end %>
              </div>
            <% end %>
            <p class="text-xs text-muted mt-1"><%= message.created_at.strftime('%H:%M') %></p>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="flex flex-col items-center justify-center h-full">
      <div class="w-20 h-20 rounded-full bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center mb-4 shadow-lg">
        <%= lucide_icon "sparkles", class: "w-10 h-10 text-primary" %>
      </div>
      <h3 class="text-xl font-bold text-primary mb-2">Pilot</h3>
      <p class="text-muted text-center max-w-md mb-6">Ask me anything about content creation, scheduling, or marketing strategy</p>
    </div>
  <% end %>
</div>
