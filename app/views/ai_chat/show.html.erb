<!-- AI Chat - Conversation View -->
<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated relative overflow-hidden" data-controller="ai-chat" data-ai-chat-conversation-id-value="<%= @conversation&.id %>">
  <!-- Decorative Background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-64 h-64 bg-primary/5 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute top-40 right-20 w-96 h-96 bg-secondary/5 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  </div>

  <!-- Header -->
  <div class="bg-white/60 backdrop-blur-lg border-b border-border/50 sticky top-0 z-40 relative">
    <div class="container-xl mx-auto px-4">
      <div class="flex justify-between items-center py-4">
        <div class="flex items-center gap-4">
          <%= link_to ai_chat_index_path, class: "p-2 hover:bg-surface-elevated rounded-lg transition-colors" do %>
            <%= lucide_icon "arrow-left", class: "w-5 h-5 text-primary" %>
          <% end %>
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-lg">
            <%= lucide_icon "bot", class: "w-6 h-6 text-white" %>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-primary"><%= @conversation&.title || 'Conversation' %></h1>
            <p class="text-sm text-muted">Your intelligent marketing companion</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <%= link_to ai_chat_index_path, class: "btn-primary" do %>
            <%= lucide_icon "message-circle", class: "w-4 h-4 mr-2" %>
            All Chats
          <% end %>
        </div>
      </div>
      
      <!-- Tabs -->
      <div class="flex gap-2 pb-4 overflow-x-auto">
        <%= link_to ai_chat_index_path, class: "flex items-center gap-2 px-4 py-2 bg-white/80 backdrop-blur-sm border border-border/50 rounded-xl hover:bg-white transition-all whitespace-nowrap #{controller_name == 'ai_chat' ? 'bg-gradient-to-r from-primary to-secondary text-white' : ''}" do %>
          <%= lucide_icon "message-circle", class: "w-4 h-4" %>
          Chat
        <% end %>
        <%= link_to content_creation_index_path, class: "flex items-center gap-2 px-4 py-2 bg-white/80 backdrop-blur-sm border border-border/50 rounded-xl hover:bg-white transition-all whitespace-nowrap #{controller_name == 'content_creation' ? 'bg-gradient-to-r from-primary to-secondary text-white' : ''}" do %>
          <%= lucide_icon "sparkles", class: "w-4 h-4" %>
          Content
        <% end %>
        <%= link_to scheduled_posts_path, class: "flex items-center gap-2 px-4 py-2 bg-white/80 backdrop-blur-sm border border-border/50 rounded-xl hover:bg-white transition-all whitespace-nowrap #{controller_name == 'scheduled_posts' ? 'bg-gradient-to-r from-primary to-secondary text-white' : ''}" do %>
          <%= lucide_icon "calendar", class: "w-4 h-4" %>
          Scheduled
        <% end %>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container-xl mx-auto px-4 py-6 relative">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      
      <!-- Sidebar: Conversations List -->
      <div class="lg:col-span-1">
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-sm border border-border/50 p-4 sticky top-40">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold text-primary flex items-center gap-2">
              <%= lucide_icon "history", class: "w-5 h-5" %>
              Recent Chats
            </h2>
            <button data-action="ai-chat#createNewConversation" class="p-2 hover:bg-surface-elevated rounded-lg transition-colors" title="New Chat">
              <%= lucide_icon "plus", class: "w-5 h-5 text-primary" %>
            </button>
          </div>
          <div id="conversations-list" class="space-y-2 max-h-[500px] overflow-y-auto" data-ai-chat-target="conversationList">
            <% if @conversations&.any? %>
              <% @conversations.each do |conversation| %>
                <div class="conversation-item p-3 rounded-xl hover:bg-gradient-to-r hover:from-primary/5 hover:to-secondary/5 cursor-pointer transition-all border border-transparent hover:border-primary/20 #{@conversation&.id == conversation.id ? 'bg-gradient-to-r from-primary/10 to-secondary/10 border-primary/30' : ''}" 
                     data-conversation-id="<%= conversation.id %>">
                  <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-primary truncate"><%= conversation.title || 'Untitled Chat' %></p>
                      <p class="text-xs text-muted"><%= time_ago_in_words(conversation.updated_at) %> ago</p>
                    </div>
                    <div class="ml-2">
                      <%= lucide_icon "chevron-right", class: "w-4 h-4 text-muted" %>
                    </div>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div class="text-center py-8">
                <div class="w-16 h-16 rounded-full bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center mx-auto mb-3">
                  <%= lucide_icon "message-square", class: "w-8 h-8 text-primary" %>
                </div>
                <h3 class="text-sm font-medium text-primary mb-1">No conversations yet</h3>
                <p class="text-xs text-muted">Start a new chat to get help</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Main Chat Area -->
      <div class="lg:col-span-3">
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-sm border border-border/50 h-[600px] flex flex-col overflow-hidden">
          
          <!-- Chat Messages -->
          <div id="chat-messages" class="flex-1 p-6 overflow-y-auto" data-ai-chat-target="messagesContainer">
            <!-- Voice Transcript Display (appears when speaking) -->
            <div id="voice-transcript-display" class="hidden mb-4 p-4 bg-green-500/10 border border-green-500/30 rounded-xl">
              <p class="text-sm text-green-700 font-medium mb-1">🎤 You said:</p>
              <p id="voice-transcript" class="text-primary"></p>
            </div>
            <!-- Voice Response Display -->
            <div id="voice-response-display" class="hidden mb-4 p-4 bg-blue-500/10 border border-blue-500/30 rounded-xl">
              <p class="text-sm text-blue-700 font-medium mb-1">🤖 AI:</p>
              <p id="voice-response-text" class="text-primary"></p>
            </div>
            <% if @messages.any? %>
              <% @messages.each do |message| %>
                <div class="message <%= message.role %> mb-4 flex <%= message.role == 'user' ? 'justify-end' : 'justify-start' %>">
                  <div class="flex <%= message.role == 'user' ? 'flex-row-reverse' : 'flex-row' %> items-start gap-3 max-w-3xl">
                    <div class="flex-shrink-0">
                      <div class="w-10 h-10 rounded-xl flex items-center justify-center <%= message.role == 'user' ? 'bg-gradient-to-br from-primary to-secondary' : 'bg-gradient-to-br from-green-500 to-emerald-500' %>">
                        <% if message.role == 'user' %>
                          <%= lucide_icon "user", class: "w-5 h-5 text-white" %>
                        <% else %>
                          <%= lucide_icon "bot", class: "w-5 h-5 text-white" %>
                        <% end %>
                      </div>
                    </div>
                    <div class="<%= message.role == 'user' ? 'text-right' : 'text-left' %>">
                      <div class="inline-block p-4 rounded-2xl <%= message.role == 'user' ? 'bg-gradient-to-br from-primary to-secondary text-white' : 'bg-white border border-border/50 text-primary' %> shadow-sm">
                        <p class="text-sm"><%= message.content %></p>
                      </div>
                      <p class="text-xs text-muted mt-1"><%= message.created_at.strftime('%H:%M') %></p>
                    </div>
                  </div>
                </div>
              <% end %>
            <% else %>
              <!-- Empty State -->
              <div class="flex flex-col items-center justify-center h-full">
                <div class="w-20 h-20 rounded-full bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center mb-4 shadow-lg">
                  <%= lucide_icon "sparkles", class: "w-10 h-10 text-primary" %>
                </div>
                <h3 class="text-xl font-bold text-primary mb-2">No Messages Yet</h3>
                <p class="text-muted text-center max-w-md mb-6">Start a conversation with your AI assistant</p>
                <div class="flex flex-wrap justify-center gap-2" data-ai-chat-target="quickPrompts">
                  <button class="quick-prompt px-4 py-2 bg-white/80 backdrop-blur-sm border border-border/50 rounded-full text-sm text-primary hover:bg-primary hover:text-white transition-all" 
                          data-prompt="Help me create a social media strategy for my new product launch">
                    New Product Launch
                  </button>
                  <button class="quick-prompt px-4 py-2 bg-white/80 backdrop-blur-sm border border-border/50 rounded-full text-sm text-primary hover:bg-primary hover:text-white transition-all" 
                          data-prompt="Generate engaging content ideas for Instagram posts">
                    Instagram Ideas
                  </button>
                  <button class="quick-prompt px-4 py-2 bg-white/80 backdrop-blur-sm border border-border/50 rounded-full text-sm text-primary hover:bg-primary hover:text-white transition-all" 
                          data-prompt="Help me optimize my existing campaigns for better engagement">
                    Optimize Campaigns
                  </button>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Chat Input with Submit Button -->
          <div class="border-t border-border/50 p-4 bg-white/50 backdrop-blur-sm">
            <form id="chat-form" class="flex gap-3" data-ai-chat-target="form">
              <div class="flex-1 relative">
                <textarea id="message-input" 
                         class="w-full px-4 py-3 pr-12 bg-white border border-border/50 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary resize-none shadow-sm"
                         rows="1" 
                         placeholder="Type your message..." data-ai-chat-target="input"></textarea>
                <!-- Submit Button -->
                <button type="submit" id="send-btn" class="absolute right-2 bottom-2 p-2 bg-gradient-to-r from-primary to-secondary text-white rounded-lg hover:shadow-lg hover:scale-105 transition-all" data-ai-chat-target="sendBtn">
                  <%= lucide_icon "send", class: "w-5 h-5" %>
                </button>
              </div>
            </form>
            <p class="text-xs text-muted mt-2 text-center">Press Enter to send or click the button • AI responses are generated by GPT-4o-mini</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Voice Command Modal -->
<div id="voice-command-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center" data-controller="voice-command-toggle">
  <div class="fixed inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="relative bg-white rounded-3xl shadow-2xl p-8 max-w-md w-full mx-4 transform transition-all scale-95 opacity-0">
    <div class="text-center">
      <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gradient-to-br from-green-500 to-emerald-500 flex items-center justify-center shadow-lg animate-pulse">
        <%= lucide_icon "mic", class: "w-12 h-12 text-white" %>
      </div>
      <h2 class="text-2xl font-bold text-primary mb-2">Otto-Pilot</h2>
      <p class="text-muted mb-6">Speak your commands to create campaigns, generate content, and manage your social media</p>
      
      <div class="bg-surface-elevated rounded-2xl p-4 mb-4 min-h-[80px]">
        <p id="voice-transcript" class="text-primary text-lg mb-2">Listening...</p>
        <div id="voice-response" class="hidden">
          <p class="text-xs text-muted mb-1">AI Response:</p>
          <p id="voice-response-text" class="text-primary text-sm"></p>
        </div>
        <p id="voice-status" class="text-xs text-gray-500 mt-2"></p>
      </div>
      
      <button class="w-full py-3 bg-gradient-to-r from-green-500 to-emerald-500 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all" data-action="voice-command-toggle#closeModal">
        Close Voice Command
      </button>
    </div>
  </div>
</div>
