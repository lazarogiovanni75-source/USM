<!-- AI Pilot Chat Button -->
<div class="fixed bottom-6 right-6 z-40">
  <button
    type="button"
    class="group relative flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-br from-purple-500 to-indigo-600 text-white shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110"
    data-controller="pilot-chat-toggle"
    data-action="pilot-chat-toggle#toggleChat"
    title="AI Pilot Chat"
  >
    <div class="flex items-center justify-center">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
      </svg>
    </div>

    <!-- Pulse animation ring -->
    <span class="absolute inset-0 rounded-full bg-gradient-to-br from-purple-500 to-indigo-600 animate-ping opacity-20"></span>
  </button>
</div>
