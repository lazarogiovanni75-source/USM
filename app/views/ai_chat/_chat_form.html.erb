<div data-controller="ai-chat">
<form id="chat-form" class="flex gap-3" data-ai-chat-target="form" data-action="submit->ai-chat#sendMessage">
  <div class="flex-1 relative">
    <textarea id="message-input" 
             class="w-full px-4 py-3 pr-12 bg-white border border-gray-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 resize-none shadow-sm"
             style="color: #111827 !important; -webkit-text-fill-color: #111827 !important; caret-color: #111827;"
             rows="1" 
             placeholder="Type your message..." data-ai-chat-target="input" data-ai-voice-chat-target="input"></textarea>
    <!-- Submit Button -->
    <button type="submit" id="send-btn" class="absolute right-2 bottom-2 p-2 bg-gradient-to-r from-primary to-secondary text-white rounded-lg hover:shadow-lg hover:scale-105 transition-all" data-ai-chat-target="sendBtn">
      <%= lucide_icon "send", class: "w-5 h-5" %>
    </button>
  </div>
</form>
</div>
