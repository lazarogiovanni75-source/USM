<div class="max-w-2xl mx-auto py-8 px-4">
  <div class="mb-6">
    <%= link_to "← Back to Workflows", workflows_path, class: "text-gray-600 hover:text-gray-900" %>
  </div>

  <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-200">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @workflow.title %></h1>
      <div class="flex items-center gap-4">
        <span class="badge-primary"><%= @workflow.workflow_type.humanize %></span>
        <span class="badge-<%= @workflow.status == 'completed' ? 'success' : @workflow.status == 'failed' ? 'danger' : 'warning' %>">
          <%= @workflow.status.humanize %>
        </span>
      </div>
    </div>

    <div class="mb-6">
      <h2 class="text-sm font-medium text-gray-700 mb-2">Content</h2>
      <div class="bg-gray-50 rounded-lg p-4 text-gray-900 whitespace-pre-wrap">
        <%= @workflow.content.presence || "No content provided" %>
      </div>
    </div>

    <% if @workflow.error_message.present? %>
      <div class="mb-6">
        <h2 class="text-sm font-medium text-gray-700 mb-2">Error</h2>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-red-700">
          <%= @workflow.error_message %>
        </div>
      </div>
    <% end %>

    <div class="flex gap-3 pt-4 border-t border-gray-200">
      <%= button_to "Delete Workflow", workflow_path(@workflow), method: :delete, 
          class: "btn-danger",
          data: { confirm: "Delete this workflow?" } %>
    </div>
  </div>
</div>
