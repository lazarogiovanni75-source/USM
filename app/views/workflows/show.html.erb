<% content_for :title, "Workflow Details" %>

<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated">
  <!-- Header -->
  <div class="bg-white/80 backdrop-blur-lg border-b border-border/50 sticky top-16 z-30">
    <div class="container-xl mx-auto px-4 py-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
          <%= link_to workflows_path, class: "btn-ghost" do %>
            <%= lucide_icon "arrow-left", class: "w-5 h-5" %>
          <% end %>
          <div>
            <h1 class="text-2xl font-bold text-primary">Workflow Details</h1>
            <p class="text-sm text-muted"><%= @workflow.workflow_type.humanize %></p>
          </div>
        </div>
        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium <%= case @workflow.status
          when 'completed' then 'bg-green-100 text-green-700'
          when 'running' then 'bg-blue-100 text-blue-700'
          when 'failed' then 'bg-red-100 text-red-700'
          else 'bg-gray-100 text-gray-700'
        end %>">
          <div class="w-2 h-2 rounded-full mr-2 <%= case @workflow.status
            when 'completed' then 'bg-green-400'
            when 'running' then 'bg-blue-400'
            when 'failed' then 'bg-red-400'
            else 'bg-gray-400'
          end %>"></div>
          <%= @workflow.status.humanize %>
        </span>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="container-xl mx-auto px-4 py-6">
    <div class="grid gap-6">
      <!-- Details Card -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-border/50">
        <h3 class="text-lg font-semibold text-primary mb-4">Workflow Information</h3>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <dt class="text-sm font-medium text-muted">Type</dt>
            <dd class="text-primary"><%= @workflow.workflow_type.humanize %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-muted">Status</dt>
            <dd class="text-primary"><%= @workflow.status.humanize %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-muted">Created</dt>
            <dd class="text-primary"><%= @workflow.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-muted">Updated</dt>
            <dd class="text-primary"><%= @workflow.updated_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
          </div>
        </dl>
      </div>

      <!-- Parameters Card -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-border/50">
        <h3 class="text-lg font-semibold text-primary mb-4">Parameters</h3>
        <pre class="bg-surface-elevated rounded-lg p-4 overflow-x-auto text-sm font-mono text-primary"><%= JSON.pretty_generate(@workflow.params || {}) %></pre>
      </div>

      <!-- Steps Card -->
      <% if @workflow.workflow_steps.any? %>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-border/50">
          <h3 class="text-lg font-semibold text-primary mb-4">Workflow Steps</h3>
          <div class="space-y-4">
            <% @workflow.workflow_steps.order(order: :asc).each do |step| %>
              <div class="flex items-start gap-4 p-4 bg-surface-elevated rounded-xl">
                <div class="w-8 h-8 rounded-full flex items-center justify-center <%= case step.status
                  when 'completed' then 'bg-green-100 text-green-600'
                  when 'running' then 'bg-blue-100 text-blue-600'
                  when 'failed' then 'bg-red-100 text-red-600'
                  else 'bg-gray-100 text-gray-600'
                end %>">
                  <%= lucide_icon case step.status
                    when 'completed' then "check"
                    when 'running' then "loader-2"
                    when 'failed' then "x"
                    else "circle"
                  end, class: "w-4 h-4" %>
                </div>
                <div class="flex-1">
                  <div class="flex items-center justify-between mb-1">
                    <h4 class="font-medium text-primary"><%= step.step_type.humanize %></h4>
                    <span class="text-xs text-muted">Order: <%= step.order %></span>
                  </div>
                  <p class="text-sm text-muted"><%= step.step_type.humanize %> - <%= step.status.humanize %></p>
                  <% if step.result.present? %>
                    <pre class="mt-2 bg-white rounded-lg p-3 overflow-x-auto text-xs font-mono text-primary"><%= JSON.pretty_generate(step.result) %></pre>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Actions -->
      <div class="flex gap-3">
        <% if @workflow.status == 'draft' || @workflow.status == 'paused' %>
          <%= button_to "Run Workflow", run_workflow_path(@workflow), method: :post, class: "btn-primary" %>
        <% end %>
        <%= button_to "Delete", workflow_path(@workflow), method: :delete, class: "btn-danger", data: { confirm: "Are you sure you want to delete this workflow?" } %>
        <%= link_to "Back to Workflows", workflows_path, class: "btn-secondary" %>
      </div>
    </div>
  </div>
</div>
