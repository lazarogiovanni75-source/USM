<% content_for :title, "New Workflow" %>

<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white border-b border-gray-200 sticky top-16 z-30">
    <div class="container-xl mx-auto px-4 py-4">
      <div class="flex items-center gap-4">
        <%= link_to workflows_path, class: "btn-ghost" do %>
          <%= lucide_icon "arrow-left", class: "w-5 h-5" %>
        <% end %>
        <div>
          <h1 class="text-2xl font-bold text-gray-900">New Workflow</h1>
          <p class="text-sm text-gray-500">Create an automated content workflow</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Form -->
  <div class="container-xl mx-auto px-4 py-6">
    <div class="max-w-2xl mx-auto">
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-200">
        <%= form_with model: @workflow, local: true, class: "space-y-6" do |f| %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Workflow Type</label>
            <%= f.select :workflow_type, 
                options_for_select([
                  ['Content to Post', 'content_to_post'],
                  ['Content to Image Post', 'content_to_image_post'],
                  ['Content to Video Post', 'content_to_video_post']
                ], f.object.workflow_type),
                {}, 
                class: "form-input" %>
            <p class="mt-1 text-xs text-gray-500">Select the type of automated workflow</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
            <%= f.select :status, 
                options_for_select([
                  ['Pending', 'pending'],
                  ['Active', 'active'],
                  ['Paused', 'paused']
                ], f.object.status),
                {}, 
                class: "form-input" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Parameters (JSON)</label>
            <%= f.text_area :params, 
                rows: 6, 
                class: "form-input font-mono text-sm text-gray-900",
                placeholder: '{"content_text": "Write your content here"}' %>
            <p class="mt-1 text-xs text-gray-500">Enter JSON with a "content_text" key containing your content</p>
          </div>

          <div class="flex gap-3 pt-4">
            <%= f.submit "Create Workflow", class: "btn-primary" %>
            <%= link_to "Cancel", workflows_path, class: "btn-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
