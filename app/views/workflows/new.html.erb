<div class="max-w-2xl mx-auto py-8 px-4">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Create Workflow</h1>
  </div>

  <%= form_with model: @workflow, url: workflows_path, class: "space-y-6" do |f| %>
    <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-sm border border-gray-200 dark:border-gray-700">
      <% if @workflow.errors.any? %>
        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-red-700"><%= @workflow.errors.full_messages.join(', ') %></p>
        </div>
      <% end %>

      <div>
        <%= f.label :workflow_type, "Workflow Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :workflow_type, 
            options_for_select([
              ['Content to Post', 'content_to_post'],
              ['Content to Image Post', 'content_to_image_post'],
              ['Content to Video Post', 'content_to_video_post']
            ], 'content_to_post'),
            {}, 
            class: "form-input w-full" %>
      </div>

      <div>
        <%= f.label :content, "Content", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :content, 
            rows: 6, 
            class: "form-textarea w-full",
            placeholder: "Enter your content or topic here...",
            required: true %>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Create Workflow", class: "btn-primary" %>
        <%= link_to "Cancel", workflows_path, class: "btn-secondary" %>
      </div>
    </div>
  <% end %>
</div>
