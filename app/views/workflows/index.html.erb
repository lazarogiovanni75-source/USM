<div class="max-w-4xl mx-auto py-8 px-4">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Workflows</h1>
    <%= link_to "New Workflow", new_workflow_path, class: "btn-primary" %>
  </div>

  <% if @workflows.any? %>
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-700">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Title</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Created</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @workflows.each do |workflow| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-6 py-4">
                <%= link_to workflow.title, workflow_path(workflow), class: "text-gray-900 dark:text-gray-100 font-medium hover:text-primary" %>
              </td>
              <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                <span class="badge-primary"><%= workflow.workflow_type.humanize %></span>
              </td>
              <td class="px-6 py-4">
                <span class="badge-<%= workflow.status == 'completed' ? 'success' : workflow.status == 'failed' ? 'danger' : 'warning' %>">
                  <%= workflow.status.humanize %>
                </span>
              </td>
              <td class="px-6 py-4 text-gray-500 dark:text-gray-400 text-sm">
                <%= workflow.created_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 text-right">
                <%= link_to "View", workflow_path(workflow), class: "text-gray-900 dark:text-gray-100 hover:underline" %>
                <%= button_to "Delete", workflow_path(workflow), method: :delete, 
                    class: "ml-4 text-red-600 dark:text-red-400 hover:underline",
                    data: { confirm: "Delete this workflow?" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white dark:bg-gray-800 rounded-2xl p-12 shadow-sm border border-gray-200 dark:border-gray-700 text-center">
      <p class="text-gray-500 dark:text-gray-400 mb-4">No workflows yet</p>
      <%= link_to "Create Your First Workflow", new_workflow_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>
