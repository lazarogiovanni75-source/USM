<% content_for :title, "New Client" %>

<div class="container-xl">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50">Add New Client</h1>
      <p class="text-gray-600 dark:text-gray-400 mt-2">Create a new client for your agency</p>
    </div>

    <div class="card border border-gray-200 dark:border-gray-700">
      <div class="card-body">
        <%= form_with(model: @client, local: true) do |f| %>
          <div class="space-y-6">
            <div>
              <%= f.label :name, class: "form-label required" %>
              <%= f.text_field :name, class: "form-input", required: true %>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <%= f.label :contact_name, class: "form-label" %>
                <%= f.text_field :contact_name, class: "form-input" %>
              </div>
              <div>
                <%= f.label :email, class: "form-label" %>
                <%= f.email_field :email, class: "form-input" %>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <%= f.label :phone, class: "form-label" %>
                <%= f.telephone_field :phone, class: "form-input" %>
              </div>
              <div>
                <%= f.label :plan, class: "form-label" %>
                <%= f.select :plan, Client.plans.keys.map { |p| [p.titleize, p] }, {}, class: "form-select" %>
              </div>
            </div>

            <div>
              <%= f.label :status, class: "form-label" %>
              <%= f.select :status, Client.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "form-select" %>
            </div>

            <div>
              <%= f.label :monthly_budget, class: "form-label" %>
              <%= f.number_field :monthly_budget, class: "form-input", step: 0.01 %>
            </div>

            <div>
              <%= f.label :address, class: "form-label" %>
              <%= f.text_area :address, class: "form-input", rows: 3 %>
            </div>

            <div>
              <%= f.label :notes, class: "form-label" %>
              <%= f.text_area :notes, class: "form-input", rows: 4 %>
            </div>
          </div>

          <div class="flex justify-end gap-3 mt-6">
            <%= link_to clients_path, class: "btn btn-secondary" do %>
              Cancel
            <% end %>
            <%= f.submit "Create Client", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
