<%= turbo_stream.update "post_modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-md w-full mx-4 p-6">
      <div class="text-center">
        <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center">
          <%= lucide_icon "send", class: "w-6 h-6 text-primary-600 dark:text-primary-400 animate-pulse" %>
        </div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Publishing...</h3>
        <p class="text-gray-600 dark:text-gray-400">Your post is being published now.</p>
      </div>
    </div>
  </div>
  <script>
    setTimeout(() => {
      window.location.reload();
    }, 2000);
  </script>
<% end %>
