<% # Month view calendar grid with enhanced post management %>
<div class="p-6" data-controller="calendar">
  <!-- Week headers -->
  <div class="grid grid-cols-7 gap-px mb-2">
    <% ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].each do |day| %>
      <div class="p-2 text-center text-xs font-semibold text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-700">
        <%= day %>
      </div>
    <% end %>
  </div>
  
  <!-- Calendar days -->
  <div class="grid grid-cols-7 gap-px bg-gray-200 dark:bg-gray-600 rounded-lg overflow-hidden">
    <% # Calculate the first day of the month and how many days to show %>
    <% first_day = current_date.beginning_of_month.beginning_of_week %>
    <% last_day = current_date.end_of_month.end_of_week %>
    <% total_days = (last_day - first_day).to_i + 1 %>
    
    <% (0..total_days.divmod(7)[0] * 7 + total_days.divmod(7)[1] - 1).each do |i| %>
      <% day = first_day + i.days %>
      <% day_posts = scheduled_posts.select { |post| post.scheduled_at.to_date == day.to_date } %>
      <% is_current_month = day.month == current_date.month %>
      <% is_today = day == Date.current %>
      
      <div class="bg-white dark:bg-gray-800 min-h-[140px] p-2 relative
                  <%= 'opacity-40' unless is_current_month %>
                  <%= 'bg-primary-50 dark:bg-primary-900/20' if is_today %>">
        
        <!-- Date number -->
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs font-medium 
                       <%= is_current_month ? 'text-gray-900 dark:text-white' : 'text-gray-400 dark:text-gray-500' %>
                       <%= 'text-primary-600 dark:text-primary-400 font-bold' if is_today %>">
            <%= day.day %>
          </span>
          
          <% if day_posts.any? %>
            <span class="text-xs bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-300 px-1 rounded">
              <%= day_posts.count %>
            </span>
          <% end %>
        </div>
        
        <!-- Scheduled posts -->
        <div class="space-y-1">
          <% day_posts.first(3).each do |post| %>
            <div class="group relative" data-post-id="<%= post.id %>">
              <div class="p-1.5 rounded text-xs cursor-pointer transition-all
                          hover:shadow-md border-l-3
                          <%= post.status == 'published' ? 'bg-green-50 border-green-500' :
                              post.status == 'failed' ? 'bg-red-50 border-red-500' :
                              post.status == 'cancelled' ? 'bg-gray-100 border-gray-400 opacity-60' :
                              'bg-gray-50 hover:bg-primary-50 border-transparent' %>
                          <%= post.platform == 'instagram' ? 'border-pink-500' :
                              post.platform == 'twitter' ? 'border-blue-500' :
                              post.platform == 'linkedin' ? 'border-blue-600' :
                              post.platform == 'facebook' ? 'border-blue-700' :
                              post.platform == 'tiktok' ? 'border-gray-900' : 'border-gray-500' %>"
                   data-action="calendar#showPostDetails"
                   data-post-id="<%= post.id %>">
                <div class="flex items-start justify-between gap-1">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-1">
                      <span class="font-medium text-gray-900 dark:text-white truncate block">
                        <%= truncate(post.content&.title || 'Untitled', length: 20) %>
                      </span>
                      <!-- Status indicator -->
                      <span class="flex-shrink-0 w-2 h-2 rounded-full
                        <%= post.status == 'published' ? 'bg-green-500' :
                            post.status == 'failed' ? 'bg-red-500' :
                            post.status == 'cancelled' ? 'bg-gray-400' :
                            'bg-blue-500' %>"
                        title="<%= post.status.titleize %>">
                      </span>
                    </div>
                    <div class="flex items-center gap-1 mt-0.5">
                      <span class="text-gray-500 dark:text-gray-400">
                        <%= post.scheduled_at.strftime("%H:%M") %>
                      </span>
                      <span class="text-gray-400 dark:text-gray-500">•</span>
                      <span class="text-gray-500 dark:text-gray-400 truncate">
                        <%= post.all_platforms.join(', ').titleize[0..15] %>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Quick action buttons (visible on hover) -->
              <% if post.can_cancel? || post.can_edit? %>
                <div class="absolute top-0 right-0 hidden group-hover:flex gap-1 p-1 bg-white dark:bg-gray-800 rounded shadow-md z-10">
                  <% if post.can_edit? %>
                    <button 
                      class="p-1 text-gray-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                      title="Edit"
                      data-action="calendar#editPost"
                      data-post-id="<%= post.id %>">
                      <%= lucide_icon "edit-2", class: "w-3 h-3" %>
                    </button>
                  <% end %>
                  <% if post.can_cancel? %>
                    <button 
                      class="p-1 text-gray-500 hover:text-red-600 dark:hover:text-red-400 transition-colors"
                      title="Cancel"
                      data-action="calendar#cancelPost"
                      data-post-id="<%= post.id %>">
                      <%= lucide_icon "x", class: "w-3 h-3" %>
                    </button>
                  <% end %>
                </div>
              <% end %>
              
              <!-- Hover tooltip -->
              <div class="absolute z-20 bottom-full left-0 mb-1 hidden group-hover:block bg-gray-900 text-white text-xs rounded py-2 px-3 w-48 shadow-lg">
                <div class="font-medium mb-1"><%= post.content&.title || 'Untitled' %></div>
                <div class="text-gray-300"><%= post.scheduled_at.strftime("%b %d, %Y at %I:%M %p") %></div>
                <div class="mt-1">
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium
                    <%= post.status == 'published' ? 'bg-green-600' :
                        post.status == 'failed' ? 'bg-red-600' :
                        post.status == 'cancelled' ? 'bg-gray-600' :
                        'bg-blue-600' %>">
                    <%= post.status.titleize %>
                  </span>
                </div>
                <% if post.error_message.present? %>
                  <div class="mt-1 text-red-300 text-xs truncate"><%= post.error_message %></div>
                <% end %>
                <div class="absolute top-full left-3 w-0 h-0 border-l-3 border-r-3 border-t-3 border-transparent border-t-gray-900"></div>
              </div>
            </div>
          <% end %>
          
          <% if day_posts.count > 3 %>
            <button class="w-full text-xs text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 text-center py-1 hover:bg-primary-50 dark:hover:bg-primary-900/20 rounded transition-colors"
                    data-action="calendar#showMorePosts"
                    data-date="<%= day.to_date %>">
              +<%= day_posts.count - 3 %> more
            </button>
          <% end %>
        </div>
        
        <!-- Empty day actions -->
        <% if day_posts.empty? && is_current_month %>
          <button class="absolute inset-0 w-full h-full opacity-0 hover:opacity-100 hover:bg-primary-50 dark:hover:bg-primary-900/20 flex items-center justify-center transition-opacity"
                  data-action="calendar#scheduleForDate"
                  data-date="<%= day.to_date %>">
            <div class="text-primary-600 dark:text-primary-400">
              <%= lucide_icon "plus", class: "w-4 h-4" %>
            </div>
          </button>
        <% end %>
      </div>
    <% end %>
  </div>
  
  <!-- Legend -->
  <div class="mt-4 flex items-center justify-center gap-6 text-xs">
    <div class="flex items-center gap-1.5">
      <span class="w-3 h-3 rounded bg-blue-500"></span>
      <span class="text-gray-600 dark:text-gray-400">Scheduled</span>
    </div>
    <div class="flex items-center gap-1.5">
      <span class="w-3 h-3 rounded bg-green-500"></span>
      <span class="text-gray-600 dark:text-gray-400">Published</span>
    </div>
    <div class="flex items-center gap-1.5">
      <span class="w-3 h-3 rounded bg-red-500"></span>
      <span class="text-gray-600 dark:text-gray-400">Failed</span>
    </div>
    <div class="flex items-center gap-1.5">
      <span class="w-3 h-3 rounded bg-gray-400"></span>
      <span class="text-gray-600 dark:text-gray-400">Cancelled</span>
    </div>
  </div>
</div>
