<% # Month view calendar grid %>
<div class="p-6" data-controller="calendar">
  <!-- Week headers -->
  <div class="grid grid-cols-7 gap-px mb-2">
    <% ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].each do |day| %>
      <div class="p-2 text-center text-xs font-semibold text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-700">
        <%= day %>
      </div>
    <% end %>
  </div>
  
  <!-- Calendar days -->
  <div class="grid grid-cols-7 gap-px bg-gray-200 dark:bg-gray-600 rounded-lg overflow-hidden">
    <% # Calculate the first day of the month and how many days to show %>
    <% first_day = current_date.beginning_of_month.beginning_of_week %>
    <% last_day = current_date.end_of_month.end_of_week %>
    <% total_days = (last_day - first_day).to_i + 1 %>
    
    <% (0..total_days.divmod(7)[0] * 7 + total_days.divmod(7)[1] - 1).each do |i| %>
      <% day = first_day + i.days %>
      <% day_posts = scheduled_posts.select { |post| post.scheduled_at.to_date == day.to_date } %>
      <% is_current_month = day.month == current_date.month %>
      <% is_today = day == Date.current %>
      
      <div class="bg-white dark:bg-gray-800 min-h-[120px] p-2 relative
                  <%= 'opacity-40' unless is_current_month %>
                  <%= 'bg-primary-50 dark:bg-primary-900/20' if is_today %>">
        
        <!-- Date number -->
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs font-medium 
                       <%= is_current_month ? 'text-gray-900 dark:text-white' : 'text-gray-400 dark:text-gray-500' %>
                       <%= 'text-primary-600 dark:text-primary-400 font-bold' if is_today %>">
            <%= day.day %>
          </span>
          
          <% if day_posts.any? %>
            <span class="text-xs bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-300 px-1 rounded">
              <%= day_posts.count %>
            </span>
          <% end %>
        </div>
        
        <!-- Scheduled posts -->
        <div class="space-y-1">
          <% day_posts.first(3).each do |post| %>
            <div class="group relative">
              <div class="p-1 bg-gray-100 dark:bg-gray-700 rounded text-xs cursor-pointer
                          hover:bg-primary-100 dark:hover:bg-primary-900/30 transition-colors
                          border-l-2 <%= post.platform == 'instagram' ? 'border-pink-500' :
                                             post.platform == 'twitter' ? 'border-blue-500' :
                                             post.platform == 'linkedin' ? 'border-blue-600' :
                                             post.platform == 'facebook' ? 'border-blue-700' :
                                             post.platform == 'tiktok' ? 'border-gray-900' : 'border-gray-500' %>"
                   data-action="calendar#showPostDetails"
                   data-post-id="<%= post.id %>">
                <div class="flex items-center justify-between">
                  <span class="truncate font-medium text-gray-900 dark:text-white">
                    <%= truncate(post.content.to_s, length: 25) %>
                  </span>
                  <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">
                    <%= post.scheduled_at.strftime("%H:%M") %>
                  </span>
                </div>
                <div class="text-xs text-gray-600 dark:text-gray-400 mt-0.5">
                  <%= post.platform.capitalize %>
                </div>
              </div>
              
              <!-- Hover tooltip -->
              <div class="absolute z-10 bottom-full left-0 mb-1 hidden group-hover:block bg-gray-900 text-white text-xs rounded py-1 px-2 whitespace-nowrap">
                <%= post.content.to_s.truncate(100) %>
                <div class="absolute top-full left-2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-gray-900"></div>
              </div>
            </div>
          <% end %>
          
          <% if day_posts.count > 3 %>
            <button class="w-full text-xs text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 text-center py-1"
                    data-action="calendar#showMorePosts"
                    data-date="<%= day.to_date %>">
              +<%= day_posts.count - 3 %> more
            </button>
          <% end %>
        </div>
        
        <!-- Empty day actions -->
        <% if day_posts.empty? && is_current_month %>
          <button class="absolute inset-0 w-full h-full opacity-0 hover:opacity-100 hover:bg-primary-50 dark:hover:bg-primary-900/20 flex items-center justify-center transition-opacity"
                  data-action="calendar#scheduleForDate"
                  data-date="<%= day.to_date %>">
            <div class="text-primary-600 dark:text-primary-400">
              <%= lucide_icon "plus", class: "w-4 h-4" %>
            </div>
          </button>
        <% end %>
      </div>
    <% end %>
  </div>
</div>