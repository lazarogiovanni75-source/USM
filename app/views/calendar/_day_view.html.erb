<% # Day view calendar grid %>
<div class="p-6" data-controller="calendar">
  <!-- Day header -->
  <div class="text-center mb-6">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
      <%= current_date.strftime("%A") %>
    </h2>
    <p class="text-lg text-gray-600 dark:text-gray-400">
      <%= current_date.strftime("%B %d, %Y") %>
    </p>
    <% if current_date == Date.current %>
      <span class="inline-block mt-2 px-3 py-1 text-sm font-medium bg-primary-100 text-primary-700 dark:bg-primary-900/30 dark:text-primary-300 rounded-full">
        Today
      </span>
    <% end %>
  </div>
  
  <!-- Hour-by-hour schedule -->
  <div class="max-w-4xl mx-auto">
    <div class="space-y-1">
      <% (0..23).each do |hour| %>
        <% hour_posts = scheduled_posts.select { |post| post.scheduled_at.hour == hour } %>
        <% is_current_hour = current_date.to_date == Date.current && hour == Time.current.hour %>
        
        <div class="flex border-b border-gray-200 dark:border-gray-700 min-h-[60px]
                    <%= 'bg-primary-50 dark:bg-primary-900/20' if is_current_hour %>">
          
          <!-- Time column -->
          <div class="w-20 flex-shrink-0 p-3 border-r border-gray-200 dark:border-gray-700 text-right">
            <span class="text-sm font-medium text-gray-600 dark:text-gray-400
                        <%= 'text-primary-600 dark:text-primary-400 font-bold' if is_current_hour %>">
              <%= format('%02d:00', hour) %>
            </span>
          </div>
          
          <!-- Posts column -->
          <div class="flex-1 p-3">
            <% if hour_posts.any? %>
              <div class="space-y-2">
                <% hour_posts.sort_by(&:scheduled_at).each do |post| %>
                  <div class="bg-white dark:bg-gray-800 rounded-lg p-3 border border-gray-200 dark:border-gray-600 hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-200 cursor-pointer shadow-sm hover:shadow"
                       data-action="calendar#showPostDetails"
                       data-post-id="<%= post.id %>">
                    
                    <div class="flex items-start justify-between mb-2">
                      <div class="flex items-center space-x-2">
                        <div class="w-3 h-3 rounded-full <%= post.platform == 'instagram' ? 'bg-pink-500' :
                                                               post.platform == 'twitter' ? 'bg-blue-500' :
                                                               post.platform == 'linkedin' ? 'bg-blue-600' :
                                                               post.platform == 'facebook' ? 'bg-blue-700' :
                                                               post.platform == 'tiktok' ? 'bg-gray-900' : 'bg-gray-500' %>"></div>
                        <span class="text-sm font-semibold text-gray-900 dark:text-white">
                          <%= post.platform.capitalize %>
                        </span>
                      </div>
                      
                      <div class="flex items-center space-x-2">
                        <span class="text-sm text-gray-600 dark:text-gray-400">
                          <%= post.scheduled_at.strftime("%H:%M") %>
                        </span>
                        <div class="flex space-x-1">
                          <button class="p-1 hover:bg-gray-100 dark:hover:bg-gray-700 rounded transition-colors"
                                  data-action="calendar#editPost"
                                  data-post-id="<%= post.id %>">
                            <%= lucide_icon "edit-2", class: "w-3 h-3 text-gray-500" %>
                          </button>
                          <button class="p-1 hover:bg-red-100 dark:hover:bg-red-900/30 rounded transition-colors"
                                  data-action="calendar#deletePost"
                                  data-post-id="<%= post.id %>">
                            <%= lucide_icon "trash-2", class: "w-3 h-3 text-red-500" %>
                          </button>
                        </div>
                      </div>
                    </div>
                    
                    <div class="text-sm text-gray-700 dark:text-gray-300 mb-3">
                      <%= post.content.to_s %>
                    </div>
                    
                    <div class="flex items-center justify-between">
                      <div class="flex items-center space-x-4 text-xs text-gray-500 dark:text-gray-400">
                        <span class="px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded">
                          <%= post.status.titleize %>
                        </span>
                        <% if post.scheduled_at < Time.current %>
                          <span class="text-green-600 dark:text-green-400">
                            <%= ((post.scheduled_at < Time.current) ? 'Posted' : 'Scheduled') %>
                          </span>
                        <% end %>
                      </div>
                      
                      <% if post.predicted_engagement %>
                        <div class="text-xs text-primary-600 dark:text-primary-400">
                          Predicted: <%= (post.predicted_engagement * 100).round(0) %>%
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <% # Empty hour - show add button for current time or future times %>
              <% if current_date.to_date >= Date.current && hour >= Time.current.hour %>
                <button class="w-full h-full min-h-[40px] border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg flex items-center justify-center text-gray-500 dark:text-gray-400 hover:border-primary-400 dark:hover:border-primary-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                        data-action="calendar#scheduleForHour"
                        data-date="<%= current_date.to_date %>"
                        data-hour="<%= hour %>">
                  <div class="flex items-center space-x-2">
                    <%= lucide_icon "plus", class: "w-4 h-4" %>
                    <span class="text-sm">Add post</span>
                  </div>
                </button>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    
    <!-- Add post for specific day -->
    <% if current_date.to_date >= Date.current %>
      <div class="mt-6 text-center">
        <button class="px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
                data-action="calendar#newPost"
                data-date="<%= current_date.to_date %>">
          <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
          Schedule Post for <%= current_date.strftime("%B %d") %>
        </button>
      </div>
    <% end %>
  </div>
</div>