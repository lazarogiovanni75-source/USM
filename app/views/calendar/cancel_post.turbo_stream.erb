<%= turbo_stream.update "post_modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-md w-full mx-4 p-6">
      <div class="text-center">
        <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
          <%= lucide_icon "check", class: "w-6 h-6 text-green-600 dark:text-green-400" %>
        </div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Post Cancelled</h3>
        <p class="text-gray-600 dark:text-gray-400">Your scheduled post has been cancelled.</p>
      </div>
    </div>
  </div>
  <script>
    setTimeout(() => {
      window.location.reload();
    }, 1500);
  </script>
<% end %>

<%= turbo_stream.replace "calendar-grid" do %>
  <%= render partial: "calendar/month_view", locals: { 
    current_date: @post.scheduled_at.to_date, 
    scheduled_posts: current_user.scheduled_posts,
    view_type: 'month' 
  } %>
<% end %>
