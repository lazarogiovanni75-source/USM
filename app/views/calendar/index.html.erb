<% content_for :title, "Calendar" %>

<div class="flex flex-col lg:flex-row gap-6" data-controller="calendar">
  <!-- Calendar Main Area -->
  <div class="flex-1">
    <!-- Calendar Navigation -->
    <div class="bg-white rounded-xl shadow-sm border border-border/50 p-4 mb-4">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <button 
            class="p-2 hover:bg-surface-elevated rounded-lg transition-colors"
            data-action="calendar#previousPeriod"
          >
            <%= lucide_icon "chevron-left", class: "w-5 h-5 text-primary" %>
          </button>
          
          <h2 class="text-lg font-bold text-primary min-w-[200px] text-center">
            <% if @current_view == 'month' %>
              <%= @current_date.strftime("%B %Y") %>
            <% elsif @current_view == 'week' %>
              Week of <%= @current_date.beginning_of_week.strftime("%b %d") %> - <%= @current_date.end_of_week.strftime("%b %d, %Y") %>
            <% else %>
              <%= @current_date.strftime("%A, %B %d, %Y") %>
            <% end %>
          </h2>
          
          <button 
            class="p-2 hover:bg-surface-elevated rounded-lg transition-colors"
            data-action="calendar#nextPeriod"
          >
            <%= lucide_icon "chevron-right", class: "w-5 h-5 text-primary" %>
          </button>
        </div>
        
        <div class="flex items-center gap-3">
          <!-- Status Filter -->
          <div class="flex items-center gap-2">
            <span class="text-sm text-muted">Status:</span>
            <select 
              class="text-sm border border-border rounded-lg px-3 py-1.5 bg-white focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none"
              data-action="calendar#filterByStatus"
              data-calendar-target="statusFilter"
            >
              <option value="all" <%= 'selected' if @status_filter == 'all' %>>All</option>
              <option value="scheduled" <%= 'selected' if @status_filter == 'scheduled' %>>Scheduled</option>
              <option value="draft" <%= 'selected' if @status_filter == 'draft' %>>Draft</option>
              <option value="published" <%= 'selected' if @status_filter == 'published' %>>Published</option>
              <option value="failed" <%= 'selected' if @status_filter == 'failed' %>>Failed</option>
              <option value="cancelled" <%= 'selected' if @status_filter == 'cancelled' %>>Cancelled</option>
            </select>
          </div>
          
          <button 
            class="px-3 py-1.5 text-sm bg-primary/10 text-primary rounded-lg hover:bg-primary/20 transition-colors"
            data-action="calendar#goToToday"
          >
            Today
          </button>
        </div>
      </div>
    </div>
    
    <!-- Calendar Grid -->
    <div class="bg-white rounded-xl shadow-sm border border-border/50">
      <div id="calendar-grid" data-calendar-target="grid">
        <%= render partial: "calendar/#{@current_view}_view", locals: { 
          current_date: @current_date, 
          scheduled_posts: @scheduled_posts,
          view_type: @current_view 
        } %>
      </div>
    </div>
  </div>
  
  <!-- Sidebar -->
  <div class="lg:w-80 space-y-4">
    <!-- Quick Actions -->
    <div class="bg-white rounded-xl shadow-sm border border-border/50 p-4">
      <h3 class="text-sm font-bold text-primary mb-3">Quick Actions</h3>
      <div class="space-y-2">
        <button 
          class="w-full flex items-center px-3 py-2 text-sm text-left text-primary hover:bg-surface-elevated rounded-lg transition-colors"
          data-action="calendar#bulkSchedule"
        >
          <%= lucide_icon "calendar-plus", class: "w-4 h-4 mr-3" %>
          Bulk Schedule Posts
        </button>
        <button 
          class="w-full flex items-center px-3 py-2 text-sm text-left text-primary hover:bg-surface-elevated rounded-lg transition-colors"
          data-action="calendar#importContent"
        >
          <%= lucide_icon "upload", class: "w-4 h-4 mr-3" %>
          Import Content
        </button>
        <button 
          class="w-full flex items-center px-3 py-2 text-sm text-left text-primary hover:bg-surface-elevated rounded-lg transition-colors"
          data-action="calendar#optimizeSchedule"
        >
          <%= lucide_icon "zap", class: "w-4 h-4 mr-3" %>
          Optimize Schedule
        </button>
      </div>
    </div>
    
    <!-- Optimal Times Suggestions -->
    <div class="bg-white rounded-xl shadow-sm border border-border/50 p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-bold text-primary">Optimal Times</h3>
        <button 
          class="text-xs text-primary hover:text-primary-dark"
          data-action="calendar#refreshOptimalTimes"
        >
          Refresh
        </button>
      </div>
      
      <div id="optimal-times-list" class="space-y-2">
        <% if @optimal_times && @optimal_times.any? %>
          <% @optimal_times.first(5).each do |suggestion| %>
            <div class="flex items-center justify-between p-2 bg-surface-elevated rounded-lg">
              <div class="flex-1">
                <div class="text-xs font-medium text-primary">
                  <%= suggestion[:platform].capitalize %>
                </div>
                <div class="text-xs text-muted">
                  <%= suggestion[:time].strftime("%H:%M") %>
                </div>
              </div>
              <div class="text-xs text-primary font-medium">
                <%= (suggestion[:confidence] * 100).round(0) %>%
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-xs text-muted text-center py-4">
            No suggestions available
          </p>
        <% end %>
      </div>
    </div>
    
    <!-- Content Gaps -->
    <div class="bg-white rounded-xl shadow-sm border border-border/50 p-4">
      <h3 class="text-sm font-bold text-primary mb-3">Content Gaps</h3>
      
      <div id="content-gaps-list" class="space-y-2">
        <% if @content_gaps && @content_gaps.any? %>
          <% @content_gaps.first(3).each do |gap| %>
            <div class="p-2 bg-amber-50 border border-amber-200 rounded-lg">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="text-xs font-medium text-amber-800">
                    <%= gap[:date].strftime("%b %d") %>
                  </div>
                  <div class="text-xs text-amber-700">
                    <%= gap[:reason] %>
                  </div>
                </div>
                <button 
                  class="text-xs text-amber-700 hover:text-amber-800"
                  data-action="calendar#fillGap"
                  data-gap-date="<%= gap[:date].to_date %>"
                >
                  Fix
                </button>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-xs text-muted text-center py-4">
            No content gaps found
          </p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Quick Schedule Modal -->
  <div id="quick-schedule-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl max-w-md w-full mx-4">
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-primary">Quick Schedule</h3>
          <button 
            class="text-muted hover:text-primary"
            data-action="calendar#closeModal"
          >
            <%= lucide_icon "x", class: "w-5 h-5" %>
          </button>
        </div>
        
        <div id="quick-schedule-content">
        </div>
      </div>
    </div>
  </div>
</div>
