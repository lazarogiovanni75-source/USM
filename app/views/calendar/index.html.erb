<%= page_title_for('calendar') %>

<div class="flex flex-col lg:flex-row gap-6" data-controller="calendar">
  <!-- Calendar Main Area -->
  <div class="flex-1">
    <!-- Calendar Navigation -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 mb-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <button 
            class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
            data-action="calendar#previousPeriod"
          >
            <%= lucide_icon "chevron-left", class: "w-5 h-5 text-gray-600 dark:text-gray-400" %>
          </button>
          
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white min-w-[200px] text-center">
            <% if @current_view == 'month' %>
              <%= @current_date.strftime("%B %Y") %>
            <% elsif @current_view == 'week' %>
              Week of <%= @current_date.beginning_of_week.strftime("%b %d") %> - <%= @current_date.end_of_week.strftime("%b %d, %Y") %>
            <% else %>
              <%= @current_date.strftime("%A, %B %d, %Y") %>
            <% end %>
          </h2>
          
          <button 
            class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
            data-action="calendar#nextPeriod"
          >
            <%= lucide_icon "chevron-right", class: "w-5 h-5 text-gray-600 dark:text-gray-400" %>
          </button>
        </div>
        
        <div class="flex items-center space-x-2">
          <button 
            class="px-3 py-1 text-sm bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
            data-action="calendar#goToToday"
          >
            Today
          </button>
        </div>
      </div>
    </div>
    
    <!-- Calendar Grid -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
      <div id="calendar-grid" data-calendar-target="grid">
        <%= render partial: "calendar/#{@current_view}_view", locals: { 
          current_date: @current_date, 
          scheduled_posts: @scheduled_posts,
          view_type: @current_view 
        } %>
      </div>
    </div>
  </div>
  
  <!-- Sidebar -->
  <div class="lg:w-80">
    <!-- Quick Actions -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 mb-4">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Quick Actions</h3>
      <div class="space-y-2">
        <button 
          class="w-full flex items-center px-3 py-2 text-sm text-left text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
          data-action="calendar#bulkSchedule"
        >
          <%= lucide_icon "calendar-plus", class: "w-4 h-4 mr-3" %>
          Bulk Schedule Posts
        </button>
        <button 
          class="w-full flex items-center px-3 py-2 text-sm text-left text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
          data-action="calendar#importContent"
        >
          <%= lucide_icon "upload", class: "w-4 h-4 mr-3" %>
          Import Content
        </button>
        <button 
          class="w-full flex items-center px-3 py-2 text-sm text-left text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
          data-action="calendar#optimizeSchedule"
        >
          <%= lucide_icon "zap", class: "w-4 h-4 mr-3" %>
          Optimize Schedule
        </button>
      </div>
    </div>
    
    <!-- Optimal Times Suggestions -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 mb-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Optimal Times</h3>
        <button 
          class="text-xs text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
          data-action="calendar#refreshOptimalTimes"
        >
          Refresh
        </button>
      </div>
      
      <div id="optimal-times-list" class="space-y-2">
        <% if @optimal_times && @optimal_times.any? %>
          <% @optimal_times.first(5).each do |suggestion| %>
            <div class="flex items-center justify-between p-2 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
              <div class="flex-1">
                <div class="text-xs font-medium text-gray-900 dark:text-white">
                  <%= suggestion[:platform].capitalize %>
                </div>
                <div class="text-xs text-gray-600 dark:text-gray-400">
                  <%= suggestion[:time].strftime("%H:%M") %>
                </div>
              </div>
              <div class="text-xs text-primary-600 dark:text-primary-400">
                <%= (suggestion[:confidence] * 100).round(0) %>%
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-xs text-gray-500 dark:text-gray-400 text-center py-4">
            No suggestions available
          </p>
        <% end %>
      </div>
    </div>
    
    <!-- Content Gaps -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Content Gaps</h3>
      
      <div id="content-gaps-list" class="space-y-2">
        <% if @content_gaps && @content_gaps.any? %>
          <% @content_gaps.first(3).each do |gap| %>
            <div class="p-2 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="text-xs font-medium text-amber-800 dark:text-amber-200">
                    <%= gap[:date].strftime("%b %d") %>
                  </div>
                  <div class="text-xs text-amber-700 dark:text-amber-300">
                    <%= gap[:reason] %>
                  </div>
                </div>
                <button 
                  class="text-xs text-amber-700 hover:text-amber-800 dark:text-amber-300 dark:hover:text-amber-200"
                  data-action="calendar#fillGap"
                  data-gap-date="<%= gap[:date].to_date %>"
                >
                  Fix
                </button>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-xs text-gray-500 dark:text-gray-400 text-center py-4">
            No content gaps found
          </p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Quick Schedule Modal -->
  <div id="quick-schedule-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full mx-4">
    <div class="p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Quick Schedule</h3>
        <button 
          class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
          data-action="calendar#closeModal"
        >
          <%= lucide_icon "x", class: "w-5 h-5" %>
        </button>
      </div>
      
      <div id="quick-schedule-content">
        <!-- Content will be loaded dynamically -->
      </div>
    </div>
  </div>
</div>
</div>