<div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50" data-controller="calendar" data-action="click->calendar#closeModal">
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-lg w-full mx-4" data-action="click->calendar#preventClose">
    <div class="p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Edit Scheduled Post</h3>
        <button 
          class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
          data-action="calendar#closeModal"
        >
          <%= lucide_icon "x", class: "w-5 h-5" %>
        </button>
      </div>
      
      <%= form_with model: @post, url: update_post_calendar_path(@post), method: :patch, local: false do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :scheduled_at, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.datetime_field :scheduled_at, 
                class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white",
                value: @post.scheduled_at.strftime("%Y-%m-%dT%H:%M") %>
          </div>
          
          <div>
            <%= f.label :content_id, "Content", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.collection_select :content_id, 
                current_user.contents.where(status: 'approved'), 
                :id, :title, 
                { include_blank: "Select content..." },
                class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white" %>
          </div>
          
          <div>
            <%= f.label :image_url, "Image URL", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.url_field :image_url, 
                class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white",
                placeholder: "https://..." %>
          </div>
          
          <div>
            <%= f.label :video_url, "Video URL", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.url_field :video_url, 
                class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white",
                placeholder: "https://..." %>
          </div>
          
          <div>
            <%= f.label :target_platforms, "Target Platforms", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <div class="flex flex-wrap gap-2">
              <% %w[instagram twitter linkedin facebook tiktok youtube].each do |platform| %>
                <label class="inline-flex items-center px-3 py-1.5 rounded-lg border cursor-pointer transition-colors
                  <%= @post.target_platforms&.include?(platform) ? 'bg-primary-100 border-primary-500 text-primary-700 dark:bg-primary-900/30 dark:border-primary-500 dark:text-primary-400' : 'bg-gray-50 border-gray-300 text-gray-700 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-300' %>">
                  <%= check_box_tag 'scheduled_post[target_platforms][]', platform, 
                      @post.target_platforms&.include?(platform),
                      class: "sr-only" %>
                  <span class="text-sm font-medium"><%= platform.titleize %></span>
                </label>
              <% end %>
            </div>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Select platforms to post to</p>
          </div>
        </div>
        
        <div class="mt-6 flex justify-end gap-3">
          <button type="button" 
                  class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
                  data-action="calendar#closeModal">
            Cancel
          </button>
          <%= f.submit "Save Changes", 
              class: "px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
