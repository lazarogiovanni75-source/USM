<%= turbo_stream.replace "post_modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50" data-action="click->calendar#closeModal">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-lg w-full mx-4 p-6" data-action="click->calendar#preventClose">
      <div class="text-center">
        <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
          <%= lucide_icon "alert-circle", class: "w-6 h-6 text-red-600 dark:text-red-400" %>
        </div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Update Failed</h3>
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          <%= @post.errors.full_messages.join(", ") %>
        </p>
        <button type="button" 
                class="px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors"
                data-action="calendar#closeModal">
          Close
        </button>
      </div>
    </div>
  </div>
<% end %>
