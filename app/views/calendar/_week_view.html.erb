<% # Week view calendar grid %>
<div class="p-6" data-controller="calendar">
  <!-- Week header -->
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
      Week of <%= current_date.beginning_of_week.strftime("%B %d") %> - <%= current_date.end_of_week.strftime("%B %d, %Y") %>
    </h3>
  </div>
  
  <!-- Days of the week -->
  <div class="space-y-4">
    <% (0..6).each do |i| %>
      <% day = current_date.beginning_of_week + i.days %>
      <% day_posts = scheduled_posts.select { |post| post.scheduled_at.to_date == day.to_date } %>
      <% is_today = day == Date.current %>
      
      <div class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4
                  <%= 'ring-2 ring-primary-200 dark:ring-primary-800' if is_today %>">
        
        <!-- Day header -->
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center space-x-3">
            <div class="text-center">
              <div class="text-xs text-gray-600 dark:text-gray-400 uppercase tracking-wide">
                <%= day.strftime("%a") %>
              </div>
              <div class="text-lg font-semibold 
                          <%= is_today ? 'text-primary-600 dark:text-primary-400' : 'text-gray-900 dark:text-white' %>">
                <%= day.day %>
              </div>
            </div>
            <% if is_today %>
              <span class="px-2 py-1 text-xs font-medium bg-primary-100 text-primary-700 dark:bg-primary-900/30 dark:text-primary-300 rounded-full">
                Today
              </span>
            <% end %>
          </div>
          
          <div class="flex items-center space-x-2">
            <span class="text-sm text-gray-600 dark:text-gray-400">
              <%= day_posts.count %> posts
            </span>
            <button class="p-1 hover:bg-white dark:hover:bg-gray-600 rounded transition-colors"
                    data-action="calendar#scheduleForDate"
                    data-date="<%= day.to_date %>">
              <%= lucide_icon "plus", class: "w-4 h-4 text-gray-600 dark:text-gray-400" %>
            </button>
          </div>
        </div>
        
        <!-- Posts for this day -->
        <div class="space-y-2">
          <% if day_posts.any? %>
            <% day_posts.sort_by(&:scheduled_at).each do |post| %>
              <div class="bg-white dark:bg-gray-800 rounded-lg p-3 border border-gray-200 dark:border-gray-600 hover:border-primary-300 dark:hover:border-primary-600 transition-colors cursor-pointer"
                   data-action="calendar#showPostDetails"
                   data-post-id="<%= post.id %>">
                
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 rounded-full <%= post.platform == 'instagram' ? 'bg-pink-500' :
                                                           post.platform == 'twitter' ? 'bg-blue-500' :
                                                           post.platform == 'linkedin' ? 'bg-blue-600' :
                                                           post.platform == 'facebook' ? 'bg-blue-700' :
                                                           post.platform == 'tiktok' ? 'bg-gray-900' : 'bg-gray-500' %>"></div>
                    <span class="text-sm font-medium text-gray-900 dark:text-white">
                      <%= post.platform.capitalize %>
                    </span>
                  </div>
                  <div class="flex items-center space-x-2">
                    <span class="text-sm text-gray-600 dark:text-gray-400">
                      <%= post.scheduled_at.strftime("%H:%M") %>
                    </span>
                    <div class="flex space-x-1">
                      <button class="p-1 hover:bg-gray-100 dark:hover:bg-gray-700 rounded"
                              data-action="calendar#editPost"
                              data-post-id="<%= post.id %>">
                        <%= lucide_icon "edit-2", class: "w-3 h-3 text-gray-500" %>
                      </button>
                      <button class="p-1 hover:bg-red-100 dark:hover:bg-red-900/30 rounded"
                              data-action="calendar#deletePost"
                              data-post-id="<%= post.id %>">
                        <%= lucide_icon "trash-2", class: "w-3 h-3 text-red-500" %>
                      </button>
                    </div>
                  </div>
                </div>
                
                <div class="text-sm text-gray-700 dark:text-gray-300 line-clamp-2">
                  <%= post.content.to_s.truncate(150) %>
                </div>
                
                <div class="flex items-center justify-between mt-2 text-xs text-gray-500 dark:text-gray-400">
                  <span>Status: <%= post.status.titleize %></span>
                  <% if post.predicted_engagement %>
                    <span class="flex items-center">
                      Predicted engagement: <%= (post.predicted_engagement * 100).round(0) %>%
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-8 text-gray-500 dark:text-gray-400">
              <%= lucide_icon "calendar", class: "w-8 h-8 mx-auto mb-2 opacity-50" %>
              <p class="text-sm">No posts scheduled</p>
              <button class="mt-2 px-3 py-1 text-xs bg-primary-100 text-primary-700 dark:bg-primary-900/30 dark:text-primary-300 rounded-lg hover:bg-primary-200 dark:hover:bg-primary-900/50 transition-colors"
                      data-action="calendar#scheduleForDate"
                      data-date="<%= day.to_date %>">
                Schedule content
              </button>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>