<% content_for :title, @trigger.name %>

<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated py-8">
  <div class="container-xl mx-auto px-4">
    <!-- Header -->
    <div class="mb-6">
      <%= link_to auto_response_triggers_path, class: "inline-flex items-center text-sm text-muted hover:text-primary transition-colors mb-4" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
        Back to Auto Responses
      <% end %>
      
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @trigger.name %></h1>
          <p class="text-muted"><%= @trigger.description %></p>
        </div>
        <div class="flex gap-2">
          <%= button_to test_trigger_auto_response_trigger_path(@trigger), method: :post, class: "btn-secondary" do %>
            <%= lucide_icon "play-circle", class: "w-4 h-4 mr-2" %>Test
          <% end %>
          <%= link_to edit_auto_response_trigger_path(@trigger), class: "btn-primary" do %>
            <%= lucide_icon "edit-2", class: "w-4 h-4 mr-2" %>Edit
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Details Card -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-4">Trigger Details</h2>
          
          <div class="space-y-4">
            <div>
              <span class="text-sm font-medium text-muted">Trigger Type</span>
              <p class="text-gray-900 font-medium mt-1"><%= @trigger.trigger_type&.titleize %></p>
            </div>
            
            <div>
              <span class="text-sm font-medium text-muted">Response Type</span>
              <p class="text-gray-900 font-medium mt-1"><%= @trigger.response_type&.titleize %></p>
            </div>
            
            <div>
              <span class="text-sm font-medium text-muted">Status</span>
              <div class="mt-1">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= @trigger.active? ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-700' %>">
                  <div class="w-2 h-2 rounded-full mr-2 <%= @trigger.active? ? 'bg-green-400' : 'bg-gray-400' %>"></div>
                  <%= @trigger.active? ? 'Active' : 'Inactive' %>
                </span>
              </div>
            </div>
            
            <% if @trigger.conditions.present? && @trigger.conditions.any? %>
              <div>
                <span class="text-sm font-medium text-muted">Conditions</span>
                <pre class="mt-2 p-3 bg-gray-50 rounded-lg text-xs font-mono overflow-x-auto"><%= JSON.pretty_generate(@trigger.conditions) %></pre>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Execution History -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50">
          <div class="px-6 py-4 border-b border-border/30">
            <h2 class="text-lg font-bold text-gray-900">Execution History</h2>
          </div>
          
          <% if @executions&.any? %>
            <div class="divide-y divide-border/30">
              <% @executions.first(10).each do |execution| %>
                <div class="p-4">
                  <div class="flex items-center justify-between">
                    <div class="flex-1">
                      <p class="text-sm text-gray-900 font-medium"><%= execution.action_taken || 'Executed' %></p>
                      <p class="text-xs text-muted mt-1"><%= execution.created_at.strftime('%b %d, %Y %I:%M %p') %></p>
                    </div>
                    <span class="px-2 py-1 rounded-full text-xs <%= execution.successful? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                      <%= execution.successful? ? 'Success' : 'Failed' %>
                    </span>
                  </div>
                  <% if execution.error_message.present? %>
                    <p class="text-xs text-red-600 mt-2"><%= execution.error_message %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="p-12 text-center">
              <%= lucide_icon "clock", class: "w-12 h-12 text-muted mx-auto mb-3" %>
              <p class="text-muted">No executions yet</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Stats -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-lg font-bold text-primary mb-4">Statistics</h3>
          
          <div class="space-y-4">
            <div>
              <span class="text-sm text-muted">Total Executions</span>
              <p class="text-2xl font-bold text-primary mt-1"><%= @statistics[:total_executions] || 0 %></p>
            </div>
            
            <div>
              <span class="text-sm text-muted">Successful</span>
              <p class="text-2xl font-bold text-green-600 mt-1"><%= @statistics[:successful_executions] || 0 %></p>
            </div>
            
            <div>
              <span class="text-sm text-muted">Success Rate</span>
              <p class="text-2xl font-bold text-primary mt-1">
                <%= @statistics[:successful_executions].to_i > 0 ? ((@statistics[:successful_executions].to_f / [@statistics[:total_executions], 1].max * 100).round(1)) : 0 %>%
              </p>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-lg font-bold text-primary mb-4">Quick Actions</h3>
          
          <div class="space-y-3">
            <%= button_to toggle_status_auto_response_trigger_path(@trigger), method: :post, class: "w-full btn-secondary justify-center" do %>
              <%= lucide_icon (@trigger.active? ? 'pause' : 'play'), class: "w-4 h-4 mr-2" %>
              <%= @trigger.active? ? 'Deactivate' : 'Activate' %>
            <% end %>
            
            <%= button_to test_trigger_auto_response_trigger_path(@trigger), method: :post, class: "w-full btn-secondary justify-center" do %>
              <%= lucide_icon "play-circle", class: "w-4 h-4 mr-2" %>
              Test Trigger
            <% end %>
            
            <%= link_to edit_auto_response_trigger_path(@trigger), class: "w-full btn-primary justify-center" do %>
              <%= lucide_icon "edit-2", class: "w-4 h-4 mr-2" %>
              Edit Trigger
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
