<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Auto-Response Triggers</h1>
          <p class="mt-2 text-gray-600">Automatically respond to engagement with AI-powered responses</p>
        </div>
        <div class="flex items-center space-x-3">
          <%= link_to new_auto_response_trigger_path, 
              class: "btn-primary inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
            <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
            New Trigger
          <% end %>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "message-circle", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @statistics[:total_executions] %>
            </div>
            <div class="text-sm text-gray-600">Responses Generated</div>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "send", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @statistics[:successful_executions] %>
            </div>
            <div class="text-sm text-gray-600">Sent Successfully</div>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-purple-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "clock", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @statistics[:successful_executions] > 0 ? ((@statistics[:successful_executions].to_f / @statistics[:total_executions] * 100).round(1)) : 0 %>%
            </div>
            <div class="text-sm text-gray-600">Success Rate</div>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "zap", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @triggers.active.count %>
            </div>
            <div class="text-sm text-gray-600">Active Triggers</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Trigger Templates -->
    <div class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Quick Start Templates</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @trigger_templates.each do |template| %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition-shadow">
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center">
                  <%= lucide_icon "message-circle", class: "w-6 h-6 text-blue-600 mr-3" %>
                  <span class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded-full">
                    <%= template[:response_type].gsub('_', ' ').titleize %>
                  </span>
                </div>
              </div>
              
              <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= template[:name] %></h3>
              <p class="text-gray-600 text-sm mb-4"><%= template[:description] %></p>
              
              <div class="space-y-2 mb-4">
                <span class="inline-block text-xs px-2 py-1 bg-blue-50 text-blue-600 rounded-full">
                  Trigger: <%= template[:trigger_type].gsub('_', ' ').titleize %>
                </span>
              </div>
              
              <%= link_to create_from_template_auto_response_triggers_path(template_id: template[:id]),
                  method: :post,
                  class: "w-full text-center py-2 px-4 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium" do %>
                Use Template
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Active Triggers -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold text-gray-900">Your Auto-Response Triggers</h2>
        </div>
      </div>
      
      <% if @triggers.any? %>
        <div class="divide-y divide-gray-200">
          <% @triggers.each do |trigger| %>
            <div class="p-6">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="flex items-center mb-2">
                    <h3 class="text-lg font-medium text-gray-900 mr-3"><%= trigger.name %></h3>
                    <% if trigger.active? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <div class="w-1.5 h-1.5 bg-green-400 rounded-full mr-1.5"></div>
                        Active
                      </span>
                    <% else %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                        <div class="w-1.5 h-1.5 bg-gray-400 rounded-full mr-1.5"></div>
                        Inactive
                      </span>
                    <% end %>
                  </div>
                  
                  <p class="text-gray-600 text-sm mb-3"><%= trigger.description %></p>
                  
                  <div class="flex flex-wrap gap-2">
                    <span class="inline-block text-xs px-2 py-1 bg-blue-100 text-blue-800 rounded-full">
                      <%= trigger.response_type.gsub('_', ' ').titleize %>
                    </span>
                    <span class="inline-block text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded-full">
                      Trigger: <%= trigger.trigger_type.gsub('_', ' ').titleize %>
                    </span>
                    <% if trigger.trigger_executions.recent.any? %>
                      <span class="inline-block text-xs px-2 py-1 bg-green-100 text-green-600 rounded-full">
                        <%= trigger.trigger_executions.recent.count %> recent executions
                      </span>
                    <% end %>
                  </div>
                </div>
                
                <div class="flex items-center space-x-2 ml-4">
                  <%= link_to test_trigger_auto_response_trigger_path(trigger), 
                      method: :post,
                      class: "text-blue-600 hover:text-blue-700 text-sm font-medium" do %>
                    Test
                  <% end %>
                  
                  <%= link_to toggle_status_auto_response_trigger_path(trigger), 
                      method: :post,
                      class: "text-gray-600 hover:text-gray-700 text-sm font-medium" do %>
                    <%= trigger.active? ? 'Disable' : 'Enable' %>
                  <% end %>
                  
                  <%= link_to edit_auto_response_trigger_path(trigger), 
                      class: "text-gray-600 hover:text-gray-700 text-sm font-medium" do %>
                    Edit
                  <% end %>
                  
                  <%= link_to auto_response_trigger_path(trigger), 
                      method: :delete,
                      data: { confirm: 'Are you sure?' },
                      class: "text-red-600 hover:text-red-700 text-sm font-medium" do %>
                    Delete
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-8 text-center">
          <%= lucide_icon "message-circle", class: "w-12 h-12 text-gray-300 mx-auto mb-4" %>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No auto-response triggers created</h3>
          <p class="text-gray-500 mb-4">Get started by creating your first auto-response trigger</p>
          <%= link_to new_auto_response_trigger_path, 
              class: "btn-primary inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
            <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
            Create First Trigger
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Information Section -->
    <div class="mt-8 bg-blue-50 border border-blue-200 rounded-lg p-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <%= lucide_icon "info", class: "w-5 h-5 text-blue-400" %>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-blue-800">How Auto-Response Triggers Work</h3>
          <div class="mt-2 text-sm text-blue-700">
            <ul class="list-disc list-inside space-y-1">
              <li>Automatically respond to comments, likes, shares, and mentions</li>
              <li>Use AI to generate contextual and engaging responses</li>
              <li>Set conditions for when triggers should activate</li>
              <li>Monitor response success rates and engagement impact</li>
              <li>All responses are reviewed before being sent to maintain quality</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>