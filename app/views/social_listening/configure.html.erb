<!-- Social Listening Configuration -->
<div data-controller="social-listening-tabs" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Configure Social Listening</h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">Set up keywords, hashtags, and competitor tracking</p>
  </div>

  <!-- Tabs Navigation -->
  <div class="flex gap-4 mb-8 border-b border-gray-200 dark:border-gray-700">
    <button
      data-section="keywords"
      data-action="social-listening-tabs#showSection"
      data-social-listening-tabs-target="button"
      id="btn-keywords"
      class="px-4 py-2 font-medium text-sm text-purple-600 border-b-2 border-purple-600">
      Keywords
    </button>
    <button
      data-section="hashtags"
      data-action="social-listening-tabs#showSection"
      data-social-listening-tabs-target="button"
      id="btn-hashtags"
      class="px-4 py-2 font-medium text-sm text-gray-500 hover:text-gray-700">
      Hashtags
    </button>
    <button
      data-section="competitors"
      data-action="social-listening-tabs#showSection"
      data-social-listening-tabs-target="button"
      id="btn-competitors"
      class="px-4 py-2 font-medium text-sm text-gray-500 hover:text-gray-700">
      Competitors
    </button>
  </div>

  <!-- Keywords Section -->
  <div id="section-keywords" data-social-listening-tabs-target="section" class="mb-8">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 mb-6">
      <div class="p-6 border-b border-gray-100 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Add Keywords</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Track mentions of specific words or phrases</p>
      </div>
      <div class="p-6">
        <%= form_with model: @new_keyword, url: keywords_social_listening_index_path, method: :post, class: 'flex gap-4' do |f| %>
          <div class="flex-1">
            <input type="text" name="keyword[term]" placeholder="Enter keyword (e.g., 'your brand', 'product name')" 
                   class="form-input w-full" required>
          </div>
          <div class="w-40">
            <select name="keyword[sentiment]" class="form-select w-full">
              <option value="any">Any Sentiment</option>
              <option value="positive">Positive Only</option>
              <option value="negative">Negative Only</option>
            </select>
          </div>
          <button type="submit" class="btn-primary">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            Add
          </button>
        <% end %>
      </div>
    </div>

    <!-- Keywords List -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
      <div class="p-6 border-b border-gray-100 dark:border-gray-700">
        <h3 class="font-medium text-gray-900 dark:text-white">Tracked Keywords (<%= @keywords.count %>)</h3>
      </div>
      <% if @keywords.any? %>
        <div class="divide-y divide-gray-100 dark:divide-gray-700">
          <% @keywords.each do |keyword| %>
            <div class="p-4 flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-700/50">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
                  </svg>
                </div>
                <div>
                  <span class="font-medium text-gray-900 dark:text-white"><%= keyword.term %></span>
                  <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    Created <%= time_ago_in_words(keyword.created_at) %> ago
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <% if keyword.sentiment_filter.present? && keyword.sentiment_filter != 'any' %>
                  <span class="badge 
                    <%= keyword.sentiment_filter == 'positive' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200' %>">
                    <%= keyword.sentiment_filter.titleize %>
                  </span>
                <% end %>
                <span class="badge bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                  <%= keyword.alerts_count || 0 %> alerts
                </span>
                <%= button_to keyword_path(keyword), method: :delete, class: 'btn-icon text-red-500 hover:text-red-600', title: 'Remove' do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No keywords tracked</h3>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Add keywords above to start tracking mentions</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Hashtags Section -->
  <div id="section-hashtags" data-social-listening-tabs-target="section" class="mb-8 hidden">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 mb-6">
      <div class="p-6 border-b border-gray-100 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Add Hashtags</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Monitor specific hashtags across platforms</p>
      </div>
      <div class="p-6">
        <%= form_with model: @new_hashtag, url: hashtags_social_listening_index_path, method: :post, class: 'flex gap-4' do |f| %>
          <div class="flex-1">
            <input type="text" name="hashtag[tag]" placeholder="Enter hashtag (e.g., #marketing, #socialmedia)" 
                   class="form-input w-full" required>
          </div>
          <div class="w-40">
            <select name="hashtag[platform]" class="form-select w-full">
              <option value="">All Platforms</option>
              <% %w[instagram twitter tiktok facebook linkedin youtube].each do |p| %>
                <option value="<%= p %>"><%= p.titleize %></option>
              <% end %>
            </select>
          </div>
          <button type="submit" class="btn-primary">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            Add
          </button>
        <% end %>
      </div>
    </div>

    <!-- Hashtags List -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
      <div class="p-6 border-b border-gray-100 dark:border-gray-700">
        <h3 class="font-medium text-gray-900 dark:text-white">Tracked Hashtags (<%= @hashtags.count %>)</h3>
      </div>
      <% if @hashtags.any? %>
        <div class="divide-y divide-gray-100 dark:divide-gray-700">
          <% @hashtags.each do |hashtag| %>
            <div class="p-4 flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-700/50">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center">
                  <span class="text-blue-600 dark:text-blue-400 font-bold">#</span>
                </div>
                <div>
                  <span class="font-medium text-gray-900 dark:text-white"><%= hashtag.tag %></span>
                  <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    <%= hashtag.platform.present? ? hashtag.platform.titleize : 'All platforms' %>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <span class="badge bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                  <%= hashtag.alerts_count || 0 %> alerts
                </span>
                <%= button_to hashtag_path(hashtag), method: :delete, class: 'btn-icon text-red-500 hover:text-red-600', title: 'Remove' do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No hashtags tracked</h3>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Add hashtags above to start monitoring</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Competitors Section -->
  <div id="section-competitors" data-social-listening-tabs-target="section" class="mb-8 hidden">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
      <div class="p-6 border-b border-gray-100 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Monitor Competitor Mentions</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Track when your competitors are mentioned</p>
      </div>
      <% if @competitors.any? %>
        <div class="divide-y divide-gray-100 dark:divide-gray-700">
          <% @competitors.each do |competitor| %>
            <div class="p-4 flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-700/50">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold">
                  <%= competitor.handle.first.upcase %>
                </div>
                <div>
                  <span class="font-medium text-gray-900 dark:text-white"><%= competitor.display_name %></span>
                  <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    @<%= competitor.handle %> • <%= competitor.platform.titleize %>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <span class="badge bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                  <%= competitor.alerts_count || 0 %> alerts
                </span>
                <%= link_to 'View', insights_competitor_tracking_path(competitor), class: 'btn-secondary btn-sm' %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No competitors tracked</h3>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Add competitors in the Competitor Tracking section</p>
          <%= link_to competitor_tracking_index_path, class: 'btn-primary mt-4' do %>
            Go to Competitor Tracking
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>