<!-- Content Creation Dashboard -->
<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-4">
        <div class="flex items-center space-x-4">
          <div class="w-10 h-10 bg-gradient-to-r from-green-500 to-blue-500 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-gray-900">Content Creation</h1>
            <p class="text-sm text-gray-600">AI-powered content generation and management</p>
          </div>
        </div>
        <div class="flex items-center space-x-3">
          <button id="new-draft-btn" class="btn-primary">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            New Draft
          </button>
          <button id="generate-content-btn" class="btn-secondary">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            Generate Content
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6" data-controller="content-creation">
      
      <!-- Sidebar: Quick Actions & Templates -->
      <div class="lg:col-span-1 space-y-6">
        
        <!-- AI Content Generation -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">AI Content Generator</h3>
          <form id="ai-generate-form" action="/content_creation/generate_content" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Topic</label>
              <input type="text" id="topic-input" data-content-creation-target="topic" name="topic" class="form-input w-full" placeholder="Enter your topic...">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Content Type</label>
              <select id="content-type-select" data-content-creation-target="contentType" name="content_type" class="form-select w-full">
                <option value="post">Social Media Post</option>
                <option value="caption">Caption</option>
                <option value="blog">Blog Post</option>
                <option value="story">Story</option>
                <option value="video_script">Video Script</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Platform</label>
              <select id="platform-select" data-content-creation-target="platform" name="platform" class="form-select w-full">
                <option value="instagram">Instagram</option>
                <option value="facebook">Facebook</option>
                <option value="twitter">Twitter/X</option>
                <option value="linkedin">LinkedIn</option>
                <option value="tiktok">TikTok</option>
                <option value="youtube">YouTube</option>
              </select>
            </div>
            <button type="submit" data-action="content-creation#handleSubmit" data-content-creation-target="submitBtn" class="btn-primary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Generate Content
            </button>
          </form>
        </div>

        <!-- AI Content Ideas (Auto-generation - Pro/Entrepreneur only) -->
        <% if current_user&.can_access_ai_content_ideas? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">AI Content Ideas</h3>
          <p class="text-sm text-gray-600 mb-4">Generate creative content ideas using GPT-5o Mini</p>
          <form action="/content_creation/generate_ideas" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Topic / Niche</label>
              <input type="text" name="topic" class="form-input w-full" placeholder="e.g., Fitness, Tech, Food..." required>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Platform</label>
              <select name="platform" class="form-select w-full">
                <option value="general">General</option>
                <option value="instagram">Instagram</option>
                <option value="twitter">Twitter/X</option>
                <option value="tiktok">TikTok</option>
                <option value="youtube">YouTube</option>
              </select>
            </div>
            <div>
              <p class="text-sm text-gray-600 mb-4">Generate creative content ideas using GPT-5o Mini (3 ideas per request)</p>
            </div>
            <button type="submit" class="btn-secondary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              Generate Ideas
            </button>
          </form>
        </div>
        <% else %>
        <!-- Upgrade Prompt for Starter users -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center justify-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2 text-center">Unlock AI Content Ideas</h3>
          <p class="text-sm text-gray-600 mb-4 text-center">Upgrade to Entrepreneur or Pro to automatically generate content ideas</p>
          <a href="/subscription" class="btn-primary w-full text-center block">
            Upgrade Plan
          </a>
        </div>
        <% end %>

        <!-- AI Image Generation (Sora 2 HD) -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">AI Image Generation</h3>
          <p class="text-sm text-gray-600 mb-4">Create images with AI</p>
          <form action="/content_creation/generate_image" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Image Description</label>
              <textarea name="prompt" rows="3" class="form-input w-full" placeholder="Describe the image you want..." required></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Size</label>
              <select name="size" class="form-select w-full">
                <option value="1024x1024">Square (1024x1024)</option>
                <option value="1792x1024">Landscape (1792x1024)</option>
                <option value="1024x1792">Portrait (1024x1792)</option>
              </select>
            </div>
            <button type="submit" class="btn-primary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              Generate Image
            </button>
          </form>
        </div>

        <!-- Edit Existing Image -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Edit Image</h3>
          <p class="text-sm text-gray-600 mb-4">Edit an existing generated image</p>
          <form action="/content_creation/edit_image" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Select Image</label>
              <select name="draft_id" class="form-select w-full">
                <option value="">Choose an image...</option>
                <% @drafts.where(content_type: 'image').each do |draft| %>
                  <option value="<%= draft.id %>"><%= draft.title %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Edit Instructions</label>
              <input type="text" name="edit_prompt" class="form-input w-full" placeholder="e.g., Make it brighter, add a border...">
            </div>
            <button type="submit" class="btn-secondary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
              Edit Image
            </button>
          </form>
        </div>

        <!-- AI Video Generation (Sora) - Manual input available to all plans -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">AI Video Generation</h3>
          <p class="text-sm text-gray-600 mb-4">Create videos with AI using OpenAI Sora</p>
          <form action="/content_creation/generate_video" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Video Description</label>
              <textarea name="prompt" rows="3" class="form-input w-full" placeholder="Describe the video you want..." required></textarea>
            </div>
            <button type="submit" class="btn-primary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
              Generate Video
            </button>
          </form>
        </div>

        <!-- Content Templates -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Content Templates</h3>
          <div class="space-y-2" id="templates-list">
            <% if @templates.any? %>
              <% @templates.each do |template| %>
                <div class="template-item p-3 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors" data-template-id="<%= template.id %>">
                  <div class="text-sm font-medium text-gray-900"><%= template.name %></div>
                  <div class="text-xs text-gray-500"><%= template.category %> • <%= template.platform %></div>
                </div>
              <% end %>
            <% else %>
              <div class="text-center py-4">
                <p class="text-sm text-gray-500">No templates available</p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Voice Commands (Entrepreneur+ only) -->
        <% if current_user&.can_use_voice_autopilot? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Voice Commands</h3>
          <div class="space-y-3">
            <button id="start-voice-btn" class="w-full btn-secondary flex items-center justify-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
              </svg>
              Start Voice Input
            </button>
            <div class="text-xs text-gray-500 text-center">
              "Create a post about [topic] for [platform]"
            </div>
          </div>
        </div>
        <% else %>
        <!-- Voice Commands Upgrade Prompt for Starter users -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center justify-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2 text-center">Unlock Voice Commands</h3>
          <p class="text-sm text-gray-600 mb-4 text-center">Upgrade to Entrepreneur or Pro for voice-controlled autopilot</p>
          <a href="/subscription" class="btn-primary w-full text-center block">
            Upgrade Plan
          </a>
        </div>
        <% end %>
      </div>

      <!-- Main Content Area -->
      <div class="lg:col-span-3 space-y-6">
        
        <%# Video Preview Section - shows the latest generated video %>
        <% video_draft = @latest_video_draft || (params[:video_draft_id] ? current_user.draft_contents.find_by(id: params[:video_draft_id]) : nil) %>
        <% if video_draft && video_draft.media_url.present? %>
          <div class="bg-gradient-to-r from-purple-600 to-pink-500 rounded-xl shadow-lg overflow-hidden">
            <div class="p-4 border-b border-white/20">
              <div class="flex items-center justify-between">
                <h2 class="text-xl font-bold text-white">Your Generated Video</h2>
                <span class="text-white/80 text-sm"><%= video_draft.updated_at.strftime('%b %d, %H:%M') %></span>
              </div>
            </div>
            <div class="p-6">
              <div class="relative rounded-lg overflow-hidden bg-black shadow-xl">
                <video controls class="w-full" poster="">
                  <source src="<%= video_draft.media_url %>" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
              </div>
              <div class="mt-4 flex items-center justify-between">
                <p class="text-white/90 text-sm truncate"><%= video_draft.title %></p>
                <div class="flex space-x-3">
                  <a href="<%= video_draft.media_url %>" download class="bg-white/20 hover:bg-white/30 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg>
                    Download
                  </a>
                  <button onclick="copyVideoUrl('<%= video_draft.media_url %>')" class="bg-white text-purple-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
                    </svg>
                    Copy Link
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Recent Drafts -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6 border-b border-gray-100">
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-semibold text-gray-900">Recent Drafts</h2>
              <a href="#" class="text-sm text-purple-600 hover:text-purple-800 font-medium">View All</a>
            </div>
          </div>
          <div class="p-6">
            <% if @drafts.any? %>
              <div class="space-y-4" id="drafts-list">
                <% @drafts.each do |draft| %>
                  <div class="draft-item p-4 border border-gray-200 rounded-lg hover:border-purple-300 cursor-pointer transition-colors" data-draft-id="<%= draft.id %>">
                    <div class="flex items-start justify-between">
                      <div class="flex-1">
                        <h3 class="font-medium text-gray-900"><%= draft.title %></h3>
                        <p class="text-sm text-gray-600 mt-1 line-clamp-2"><%= draft.content %></p>
                        <div class="flex items-center space-x-4 mt-2">
                          <span class="text-xs px-2 py-1 bg-blue-100 text-blue-800 rounded-full"><%= draft.content_type %></span>
                          <span class="text-xs px-2 py-1 bg-gray-100 text-gray-800 rounded-full"><%= draft.platform %></span>
                          <span class="text-xs px-2 py-1 bg-yellow-100 text-yellow-800 rounded-full"><%= draft.status %></span>
                          <span class="text-xs text-gray-500"><%= draft.updated_at.strftime('%b %d, %H:%M') %></span>
                        </div>
                      </div>
                      <div class="flex items-center space-x-2 ml-4">
                        <%= button_to publish_content_content_creation_path(draft), method: :post, class: "btn-primary btn-sm", title: "Post Directly" do %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                          </svg>
                        <% end %>
                        <%= link_to new_scheduled_post_path(draft_id: draft.id), class: "btn-secondary btn-sm", title: "Schedule Post" do %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                        <% end %>
                        <button class="btn-icon text-gray-400 hover:text-blue-600" data-action="edit" data-draft-id="<%= draft.id %>">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                          </svg>
                        </button>
                        <button class="btn-icon text-gray-400 hover:text-red-600" data-action="delete" data-draft-id="<%= draft.id %>">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-12">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900">No drafts yet</h3>
                <p class="mt-1 text-sm text-gray-500">Start creating content using AI or voice commands.</p>
                <div class="mt-6">
                  <button id="create-first-draft" class="btn-primary">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Create Your First Draft
                  </button>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- AI Content Suggestions (Auto-generation - Pro/Entrepreneur only) -->
        <% if current_user&.can_access_ai_content_ideas? %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6 border-b border-gray-100">
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-semibold text-gray-900">AI Content Suggestions</h2>
              <span class="text-sm text-gray-500">Powered by AI</span>
            </div>
          </div>
          <div class="p-6">
            <% if @suggestions.any? %>
              <div class="space-y-4" id="suggestions-list">
                <% @suggestions.each do |suggestion| %>
                  <div class="suggestion-item p-4 border border-gray-200 rounded-lg">
                    <div class="flex items-start justify-between">
                      <div class="flex-1">
                        <div class="flex items-center space-x-2 mb-2">
                          <span class="text-xs px-2 py-1 bg-purple-100 text-purple-800 rounded-full"><%= suggestion.content_type %></span>
                          <span class="text-xs text-gray-500">Confidence: <%= (suggestion.confidence * 100).round %>%</span>
                        </div>
                        <p class="text-sm text-gray-900"><%= suggestion.suggestion %></p>
                        <p class="text-xs text-gray-500 mt-1">Topic: <%= suggestion.topic %></p>
                      </div>
                      <div class="flex items-center space-x-2 ml-4">
                        <button class="btn-icon text-gray-400 hover:text-green-600" data-action="use-suggestion" data-suggestion-id="<%= suggestion.id %>">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-8">
                <svg class="mx-auto h-8 w-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                </svg>
                <p class="mt-2 text-sm text-gray-500">No suggestions yet. Start a conversation with AI to get content ideas.</p>
              </div>
            <% end %>
          </div>
        </div>
        <% else %>
        <!-- Upgrade Prompt for Starter users - Content Suggestions -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center justify-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2 text-center">Unlock AI Content Suggestions</h3>
          <p class="text-sm text-gray-600 mb-4 text-center">Upgrade to Entrepreneur or Pro for AI-powered content suggestions</p>
          <a href="/subscription" class="btn-primary w-full text-center block">
            Upgrade Plan
          </a>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- stimulus-validator: allow-script -->
<script>
function copyVideoUrl(url) {
  navigator.clipboard.writeText(url).then(function() {
    alert('Video URL copied to clipboard!');
  }, function(err) {
    console.error('Could not copy text: ', err);
    // Fallback
    var textArea = document.createElement('textarea');
    textArea.value = url;
    document.body.appendChild(textArea);
    textArea.select();
    document.execCommand('copy');
    document.body.removeChild(textArea);
    alert('Video URL copied to clipboard!');
  });
}
</script>