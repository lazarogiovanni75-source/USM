<!-- Content Creation Dashboard -->
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <!-- Header -->
  <div class="bg-white dark:bg-gray-800 shadow-sm border-b border-gray-200 dark:border-gray-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-4">
        <div class="flex items-center space-x-4">
          <div class="w-10 h-10 bg-gradient-to-r from-green-500 to-blue-500 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Media Creation</h1>
            <p class="text-sm text-gray-600 dark:text-gray-400">Create campaigns, content, images, and videos</p>
          </div>
        </div>
        <div class="flex items-center space-x-3">
          <button id="new-draft-btn" class="btn-primary">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            New Draft
          </button>
          <button id="generate-content-btn" class="btn-secondary">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            Generate Content
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6" data-controller="mobile-debug">
    <% subscription = current_user.user_subscriptions.active.first %>
    <% if subscription %>
      <% credits_info = subscription.credit_status %>
      <!-- Credits Display Banner -->
      <div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl shadow-lg p-4 mb-6 text-white">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div class="flex items-center gap-4">
            <div class="bg-white/20 rounded-full p-3">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm text-white/80">Your Credits</p>
              <p class="text-2xl font-bold"><%= credits_info[:remaining] %> / <%= credits_info[:total] %></p>
              <p class="text-xs text-white/70"><%= subscription.subscription_plan.name %> Plan</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-right">
              <p class="text-xs text-white/70">Resets</p>
              <p class="text-sm font-medium"><%= credits_info[:reset_at].strftime('%b %d, %Y') if credits_info[:reset_at] %></p>
            </div>
            <% if subscription.credits_remaining < 50 %>
              <a href="/subscription" class="bg-yellow-500 hover:bg-yellow-600 text-yellow-900 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                Top Up Credits
              </a>
            <% end %>
          </div>
        </div>
        <% credits_percentage = (credits_info[:remaining].to_f / credits_info[:total] * 100).round %>
        <div class="mt-3 bg-white/20 rounded-full h-2">
          <div class="bg-white rounded-full h-2 transition-all" style="width: <%= credits_percentage %>%"></div>
        </div>
      </div>
    <% else %>
      <!-- No Subscription Banner -->
      <div class="bg-gradient-to-r from-red-500 to-orange-500 rounded-xl shadow-lg p-4 mb-6 text-white">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="bg-white/20 rounded-full p-3">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
              </svg>
            </div>
            <div>
              <p class="text-lg font-bold">No Active Subscription</p>
              <p class="text-sm text-white/80">Subscribe to generate AI images and videos</p>
            </div>
          </div>
          <a href="/subscription" class="bg-white hover:bg-gray-100 text-red-600 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
            Subscribe Now
          </a>
        </div>
      </div>
    <% end %>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6" data-controller="content-creation">
      
      <!-- Sidebar: Quick Actions & Templates -->
      <div class="lg:col-span-1 space-y-6">
        
        <!-- Campaigns Section -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Campaigns</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400"><%= @campaigns.count %> total</span>
          </div>
          
          <% if @campaigns.any? %>
            <div class="space-y-2 mb-4">
              <% @campaigns.first(3).each do |campaign| %>
                <%= link_to campaign_path(campaign), class: "block p-3 rounded-lg border border-gray-100 dark:border-gray-700 hover:border-green-500 dark:hover:border-green-400 hover:bg-green-50/50 dark:hover:bg-green-900/20 transition-all" do %>
                  <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                      <p class="font-medium text-gray-900 dark:text-white truncate"><%= campaign.name %></p>
                      <p class="text-xs text-gray-500 dark:text-gray-400"><%= campaign.status.titleize %></p>
                    </div>
                    <svg class="w-4 h-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </div>
                <% end %>
              <% end %>
            </div>
            <div class="flex gap-2">
              <%= link_to "All", campaigns_path, class: "flex-1 text-center text-sm py-2 px-3 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg transition-colors" %>
              <%= link_to new_campaign_path, class: "flex-1 text-center text-sm py-2 px-3 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-colors" do %>
                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                New
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4">
              <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
              </div>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">No campaigns yet</p>
              <%= link_to "Create Campaign", new_campaign_path, class: "btn-primary w-full" %>
            </div>
          <% end %>
        </div>

        <!-- Connected Accounts Section -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Connected Accounts</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400"><%= @social_accounts.count %> connected</span>
          </div>
          
          <% if @social_accounts.any? %>
            <div class="space-y-2 mb-4">
              <% @social_accounts.first(3).each do |account| %>
                <div class="flex items-center justify-between p-3 rounded-lg border border-gray-100 dark:border-gray-700 hover:border-green-500 dark:hover:border-green-400 hover:bg-green-50/50 dark:hover:bg-green-900/20 transition-all">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-500 rounded-full flex items-center justify-center">
                      <span class="text-white text-sm font-medium"><%= account.platform&.first&.upcase || 'S' %></span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-medium text-gray-900 dark:text-white truncate"><%= account.account_name || account.platform.titleize %></p>
                      <p class="text-xs text-gray-500 dark:text-gray-400"><%= account.platform.titleize %></p>
                    </div>
                  </div>
                  <% if account.configured_for_postforme? %>
                    <span class="flex h-3 w-3">
                      <span class="animate-ping absolute inline-flex h-3 w-3 rounded-full bg-green-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
            <div class="flex gap-2">
              <%= link_to "Manage", social_account_connections_path, class: "flex-1 text-center text-sm py-2 px-3 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg transition-colors" %>
              <%= link_to social_account_connections_path, class: "flex-1 text-center text-sm py-2 px-3 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-colors" do %>
                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Add
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4">
              <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                </svg>
              </div>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">No accounts connected</p>
              <%= link_to "Connect Accounts", social_account_connections_path, class: "btn-primary w-full" %>
            </div>
          <% end %>
        </div>

        <!-- AI Content Generation -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">AI Content Generator</h3>
          <form id="ai-generate-form" action="/content_creation/generate_content" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Topic</label>
              <input type="text" id="topic-input" data-content-creation-target="topic" name="topic" class="form-input w-full" placeholder="Enter your topic...">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Content Type</label>
              <select id="content-type-select" data-content-creation-target="contentType" name="content_type" class="form-select w-full">
                <option value="post">Social Media Post</option>
                <option value="caption">Caption</option>
                <option value="blog">Blog Post</option>
                <option value="story">Story</option>
                <option value="video_script">Video Script</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Platform</label>
              <select id="platform-select" data-content-creation-target="platform" name="platform" class="form-select w-full">
                <option value="instagram">Instagram</option>
                <option value="facebook">Facebook</option>
                <option value="twitter">Twitter/X</option>
                <option value="linkedin">LinkedIn</option>
                <option value="tiktok">TikTok</option>
                <option value="youtube">YouTube</option>
              </select>
            </div>
            <button type="submit" data-content-creation-target="submitBtn" class="btn-primary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Generate Content
            </button>
          </form>
        </div>

        <!-- AI Content Ideas (Auto-generation - Pro/Entrepreneur only) -->
        <% if current_user&.can_access_ai_content_ideas? %>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">AI Content Ideas</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Generate creative content ideas for your niche</p>
          <form action="/content_creation/generate_ideas" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Topic / Niche</label>
              <input type="text" name="topic" class="form-input w-full" placeholder="e.g., Fitness, Tech, Food..." required>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Platform</label>
              <select name="platform" class="form-select w-full">
                <option value="general">General</option>
                <option value="instagram">Instagram</option>
                <option value="twitter">Twitter/X</option>
                <option value="tiktok">TikTok</option>
                <option value="youtube">YouTube</option>
              </select>
            </div>
            <div>

            </div>
            <button type="submit" class="btn-secondary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              Generate Ideas
            </button>
          </form>
        </div>
        <% else %>
        <!-- Upgrade Prompt for Starter users -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center justify-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 text-center">Unlock AI Content Ideas</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 text-center">Upgrade to Entrepreneur or Pro to automatically generate content ideas</p>
          <a href="/subscription" class="btn-primary w-full text-center block">
            Upgrade Plan
          </a>
        </div>
        <% end %>

        <!-- AI Image Generation -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">AI Image Generation</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Powered by Atlas Cloud</p>
          <form action="/content_creation/generate_image" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Image Description</label>
              <textarea name="prompt" rows="3" class="form-input w-full" placeholder="Describe the image you want..." required></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Model</label>
              <select name="model" class="form-select w-full">
                <% @image_models.each do |model_id, model_name| %>
                  <option value="<%= model_id %>" <%= 'selected' if model_id == 'openai/gpt-image-2/text-to-image' %>><%= model_name %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Aspect Ratio</label>
              <select name="size" class="form-select w-full">
                <option value="1:1">Square (1:1)</option>
                <option value="16:9">Landscape (16:9)</option>
                <option value="9:16">Portrait (9:16)</option>
                <option value="4:3">Standard (4:3)</option>
                <option value="3:4">Portrait (3:4)</option>
              </select>
            <div>
            <button type="submit" class="btn-primary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              Generate Image
            </button>
          </form>
        </div>

        <!-- AI Video Generation -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">AI Video Generation</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Powered by Atlas Cloud</p>
          <form action="/content_creation/generate_video" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Video Description</label>
              <textarea name="prompt" rows="3" class="form-input w-full" placeholder="Describe the video you want..." required></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Model</label>
              <select name="model" class="form-select w-full">
                <% @video_models.each do |model_id, model_name| %>
                  <option value="<%= model_id %>"><%= model_name %></option>
                <% end %>
              </select>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Aspect Ratio</label>
                <select name="aspect_ratio" class="form-select w-full">
                  <option value="16:9">Landscape (16:9)</option>
                  <option value="9:16">Portrait (9:16)</option>
                  <option value="1:1">Square (1:1)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Duration</label>
                <select name="duration" class="form-select w-full">
                  <option value="5">5 seconds</option>
                  <option value="10">10 seconds</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Source Image URL (optional)</label>
              <input type="url" name="source_image_url" class="form-input w-full" placeholder="https://... (for image-to-video)">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Text to display on video (optional)</label>
              <input type="text" name="overlay_text" class="form-input w-full" placeholder="Enter text to overlay on video...">
            </div>
            <div>
            <button type="submit" class="btn-primary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
              Generate Video
            </button>
          </form>
        </div>

        <!-- Image Editing -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Image Editing</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Edit an existing generated image</p>
          <form action="/content_creation/edit_image" method="post" class="space-y-4">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Select Image</label>
              <select name="draft_id" class="form-select w-full">
                <option value="">Choose an image...</option>
                <% @drafts.where(content_type: 'image').each do |draft| %>
                  <option value="<%= draft.id %>"><%= draft.title %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Edit Model</label>
              <select name="edit_model" class="form-select w-full">
                <% AtlasCloudImageService.available_image_edit_models.each do |model_id, model_name| %>
                  <option value="<%= model_id %>"><%= model_name %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Edit Instructions</label>
              <input type="text" name="edit_prompt" class="form-input w-full" placeholder="e.g., Make it brighter, add a border...">
            </div>
            <button type="submit" class="btn-secondary w-full">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
              Edit Image
            </button>
          </form>
        </div>

        <!-- Content Templates -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Content Templates</h3>
          <div class="space-y-2" id="templates-list">
            <% if @templates.any? %>
              <% @templates.each do |template| %>
                <div class="template-item p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 cursor-pointer transition-colors" data-template-id="<%= template.id %>">
                  <div class="text-sm font-medium text-gray-900 dark:text-white"><%= template.name %></div>
                  <div class="text-xs text-gray-500 dark:text-gray-400"><%= template.category %> • <%= template.platform %></div>
                </div>
              <% end %>
            <% else %>
              <div class="text-center py-4">
                <p class="text-sm text-gray-500 dark:text-gray-400">No templates available</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Main Content Area -->
      <div class="lg:col-span-3 space-y-6">
        
        <%# Image Gallery Section - shows generated images %>
        <% latest_image = @drafts.where(content_type: 'image').where.not(media_url: nil).order(updated_at: :desc).first %>
        <% if latest_image && latest_image.media_display_url.present? %>
          <div class="bg-gradient-to-r from-green-500 to-teal-500 rounded-xl shadow-lg overflow-hidden">
            <div class="p-4 border-b border-white/20">
              <div class="flex items-center justify-between">
                <h2 class="text-xl font-bold text-white">Your Generated Image</h2>
                <span class="text-white/80 text-sm"><%= latest_image.updated_at.strftime('%b %d, %H:%M') %></span>
              </div>
            </div>
            <div class="p-6">
              <div class="relative rounded-lg overflow-hidden bg-black shadow-xl">
                <img src="<%= latest_image.media_display_url %>" alt="<%= latest_image.title %>" class="w-full max-h-96 object-contain">
                <% if latest_image.quality_tier == 'hd' %>
                  <span class="absolute top-2 right-2 px-2 py-1 rounded text-xs font-medium bg-gradient-to-r from-amber-400 to-orange-500 text-white">
                    ✨ HD
                  </span>
                <% end %>
              </div>
              <div class="mt-4 flex items-center justify-between">
                <p class="text-white/90 text-sm truncate"><%= latest_image.title %></p>
                <div class="flex space-x-3">
                  <a href="<%= download_draft_path(latest_image) %>" class="bg-white/20 hover:bg-white/30 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg>
                    Download
                  </a>
                  <button onclick="copyImageUrl('<%= latest_image.media_display_url %>')" class="bg-white text-teal-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
                    </svg>
                    Copy Link
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% end %>
        
        <%# Video Preview Section - shows the latest generated video %>
        <% video_draft = @latest_video_draft || (params[:video_draft_id] ? current_user.draft_contents.find_by(id: params[:video_draft_id]) : nil) %>
        <% if video_draft && video_draft.media_url.present? %>
          <div class="bg-gradient-to-r from-purple-600 to-pink-500 rounded-xl shadow-lg overflow-hidden">
            <div class="p-4 border-b border-white/20">
              <div class="flex items-center justify-between">
                <h2 class="text-xl font-bold text-white">Your Generated Video</h2>
                <span class="text-white/80 text-sm"><%= video_draft.updated_at.strftime('%b %d, %H:%M') %></span>
              </div>
            </div>
            <div class="p-6">
              <div class="relative rounded-lg overflow-hidden bg-black shadow-xl">
                <video controls class="w-full" poster="">
                  <source src="<%= video_draft.media_url %>" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
                <% if video_draft.quality_tier == 'hd' %>
                  <span class="absolute top-2 right-2 px-2 py-1 rounded text-xs font-medium bg-gradient-to-r from-amber-400 to-orange-500 text-white">
                    ✨ HD
                  </span>
                <% end %>
              </div>
              <div class="mt-4 flex items-center justify-between">
                <p class="text-white/90 text-sm truncate"><%= video_draft.title %></p>
                <div class="flex space-x-3">
                  <a href="<%= download_draft_path(video_draft) %>" class="bg-white/20 hover:bg-white/30 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg>
                    Download
                  </a>
                  <button onclick="copyVideoUrl('<%= video_draft.media_url %>')" class="bg-white text-purple-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
                    </svg>
                    Copy Link
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Media Upload Section -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
          <div class="p-6 border-b border-gray-100 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Media Library</h2>
              <span class="text-sm text-gray-500 dark:text-gray-400"><%= current_user.draft_contents.where.not(media_url: nil).count %> items</span>
            </div>
          </div>
          
          <!-- Upload Form -->
          <div class="p-6 border-b border-gray-100 dark:border-gray-700">
            <form action="/content_creation/upload_media" method="post" enctype="multipart/form-data" class="space-y-4">
              <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
              
              <!-- Drag & Drop Zone -->
              <div class="relative">
                <div id="drop-zone" class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-xl p-8 text-center hover:border-purple-400 dark:hover:border-purple-500 transition-colors cursor-pointer bg-gray-50 dark:bg-gray-700/50">
                  <input type="file" name="media_file" id="media-file-input" accept="image/*,video/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="handleFileSelect(this)">
                  <div id="upload-preview-content">
                    <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                    </svg>
                    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Drag & drop or click to upload</p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-500">Images: JPG, PNG, GIF, WebP | Videos: MP4, MOV, WebM (max 50MB)</p>
                  </div>
                  <div id="file-selected-preview" class="hidden">
                    <svg class="mx-auto h-12 w-12 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <p id="file-name-display" class="mt-2 text-sm font-medium text-gray-900 dark:text-white"></p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Click to change file</p>
                  </div>
                </div>
              </div>
              
              <!-- Additional Options -->
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title (optional)</label>
                  <input type="text" name="title" placeholder="Media title" class="form-input w-full">
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Content Type</label>
                  <select name="content_type" class="form-select w-full">
                    <option value="image">Image</option>
                    <option value="video">Video</option>
                    <option value="story">Story</option>
                    <option value="reel">Reel</option>
                  </select>
                </div>
              </div>
              
              <div class="flex items-center justify-between">
                <div id="upload-status" class="text-sm"></div>
                <button type="submit" class="btn-primary">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
                  </svg>
                  Upload Media
                </button>
              </div>
            </form>
          </div>
          
          <!-- Uploaded Media Grid -->
          <div class="p-6">
            <% uploaded_media = current_user.draft_contents.where("media_url IS NOT NULL").order(updated_at: :desc).limit(20) %>
            <% if uploaded_media.any? %>
              <div id="uploaded-media-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
                <% uploaded_media.each do |draft| %>
                  <%= render 'content_creation/uploaded_media_item', draft: draft %>
                <% end %>
              </div>
            <% else %>
              <div id="upload-empty-state" class="text-center py-8">
                <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">No uploaded media yet</p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Recent Drafts -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
          <div class="p-6 border-b border-gray-100">
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Recent Drafts</h2>
              <a href="#" class="text-sm text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 font-medium">View All</a>
            </div>
          </div>
          <div class="p-6">
            <% if @drafts.any? %>
              <div class="space-y-4" id="drafts-list">
                <% @drafts.each do |draft| %>
                  <div class="draft-item p-4 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-purple-300 dark:hover:border-purple-500 cursor-pointer transition-colors" data-draft-id="<%= draft.id %>">
                    <% if draft.content_type == 'image' %>
                      <div class="mb-3">
                        <% if draft.media_display_url.present? %>
                          <img src="<%= draft.media_display_url %>" alt="<%= draft.title %>" class="w-full h-32 object-cover rounded-lg">
                        <% else %>
                          <div class="w-full h-32 bg-gradient-to-br from-purple-100 to-indigo-100 rounded-lg flex items-center justify-center">
                            <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                    <div class="flex items-start justify-between">
                      <div class="flex-1">
                        <h3 class="font-medium text-gray-900 dark:text-white"><%= draft.title %></h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 line-clamp-2"><%= draft.content %></p>
                        <div class="flex items-center space-x-4 mt-2">
                          <span class="text-xs px-2 py-1 bg-blue-100 text-blue-800 rounded-full"><%= draft.content_type %></span>
                          <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 rounded-full"><%= draft.platform %></span>
                          <span class="text-xs px-2 py-1 bg-yellow-100 text-yellow-800 rounded-full"><%= draft.status %></span>
                          <span class="text-xs text-gray-500 dark:text-gray-400"><%= draft.updated_at.strftime('%b %d, %H:%M') %></span>
                        </div>
                      </div>
                      <div class="flex items-center space-x-2 ml-4">
                        <%= button_to publish_content_content_creation_path(draft), method: :post, class: "btn-primary btn-sm", title: "Post Directly" do %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                          </svg>
                        <% end %>
                        <%= link_to new_scheduled_post_path(draft_id: draft.id), class: "btn-secondary btn-sm", title: "Schedule Post" do %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                        <% end %>
                        <button class="btn-icon text-gray-400 dark:text-gray-500 hover:text-blue-600 dark:hover:text-blue-400" data-action="edit" data-draft-id="<%= draft.id %>">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                          </svg>
                        </button>
                        <button class="btn-icon text-gray-400 dark:text-gray-500 hover:text-red-600 dark:hover:text-red-400" data-action="delete" data-draft-id="<%= draft.id %>">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-12">
                <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No drafts yet</h3>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Start creating content using AI or voice commands.</p>
                <div class="mt-6">
                  <button id="create-first-draft" class="btn-primary">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Create Your First Draft
                  </button>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- AI Content Suggestions (Auto-generation - Pro/Entrepreneur only) -->
        <% if current_user&.can_access_ai_content_ideas? %>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
          <div class="p-6 border-b border-gray-100 dark:border-gray-700">
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">AI Content Suggestions</h2>
              <span class="text-sm text-gray-500 dark:text-gray-400">Powered by AI</span>
            </div>
          </div>
          <div class="p-6">
            <% if @suggestions.any? %>
              <div class="space-y-4" id="suggestions-list">
                <% @suggestions.each do |suggestion| %>
                  <div class="suggestion-item p-4 border border-gray-200 dark:border-gray-700 rounded-lg">
                    <div class="flex items-start justify-between">
                      <div class="flex-1">
                        <div class="flex items-center space-x-2 mb-2">
                          <span class="text-xs px-2 py-1 bg-purple-100 text-purple-800 rounded-full"><%= suggestion.content_type %></span>
                          <span class="text-xs text-gray-500 dark:text-gray-400">Confidence: <%= (suggestion.confidence * 100).round %>%</span>
                        </div>
                        <p class="text-sm text-gray-900 dark:text-white"><%= suggestion.suggestion %></p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Topic: <%= suggestion.topic %></p>
                      </div>
                      <div class="flex items-center space-x-2 ml-4">
                        <button class="btn-icon text-gray-400 dark:text-gray-500 hover:text-green-600 dark:hover:text-green-400" data-action="use-suggestion" data-suggestion-id="<%= suggestion.id %>">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-8">
                <svg class="mx-auto h-8 w-8 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                </svg>
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">No suggestions yet. Start a conversation with AI to get content ideas.</p>
              </div>
            <% end %>
          </div>
        </div>
        <% else %>
        <!-- Upgrade Prompt for Starter users - Content Suggestions -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center justify-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 text-center">Unlock AI Content Suggestions</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 text-center">Upgrade to Entrepreneur or Pro for AI-powered content suggestions</p>
          <a href="/subscription" class="btn-primary w-full text-center block">
            Upgrade Plan
          </a>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- stimulus-validator: allow-script -->
<script>
function copyVideoUrl(url) {
  navigator.clipboard.writeText(url).then(function() {
    alert('Video URL copied to clipboard!');
  }, function(err) {
    console.error('Could not copy text: ', err);
    // Fallback
    var textArea = document.createElement('textarea');
    textArea.value = url;
    document.body.appendChild(textArea);
    textArea.select();
    document.execCommand('copy');
    document.body.removeChild(textArea);
    alert('Video URL copied to clipboard!');
  });
}

function copyImageUrl(url) {
  navigator.clipboard.writeText(url).then(function() {
    alert('Image URL copied to clipboard!');
  }, function(err) {
    console.error('Could not copy text: ', err);
    // Fallback
    var textArea = document.createElement('textarea');
    textArea.value = url;
    document.body.appendChild(textArea);
    textArea.select();
    document.execCommand('copy');
    document.body.removeChild(textArea);
    alert('Image URL copied to clipboard!');
  });
}

function handleFileSelect(input) {
  if (input.files && input.files[0]) {
    var file = input.files[0];
    var fileNameDisplay = document.getElementById('file-name-display');
    var previewContent = document.getElementById('upload-preview-content');
    var selectedPreview = document.getElementById('file-selected-preview');
    
    fileNameDisplay.textContent = file.name + ' (' + formatFileSize(file.size) + ')';
    previewContent.classList.add('hidden');
    selectedPreview.classList.remove('hidden');
  }
}

function formatFileSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

// Drag and drop handling
var dropZone = document.getElementById('drop-zone');
if (dropZone) {
  ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
    dropZone.addEventListener(eventName, preventDefaults, false);
  });
  
  function preventDefaults(e) {
    e.preventDefault();
    e.stopPropagation();
  }
  
  ['dragenter', 'dragover'].forEach(eventName => {
    dropZone.addEventListener(eventName, () => {
      dropZone.classList.add('border-purple-500', 'bg-purple-50', 'dark:bg-purple-900/20');
    }, false);
  });
  
  ['dragleave', 'drop'].forEach(eventName => {
    dropZone.addEventListener(eventName, () => {
      dropZone.classList.remove('border-purple-500', 'bg-purple-50', 'dark:bg-purple-900/20');
    }, false);
  });
  
  dropZone.addEventListener('drop', (e) => {
    var fileInput = document.getElementById('media-file-input');
    if (e.dataTransfer.files.length) {
      fileInput.files = e.dataTransfer.files;
      handleFileSelect(fileInput);
    }
  }, false);
}
</script>