<!-- Uploaded Media Item Partial -->
<%# This partial renders a single uploaded media item in the grid %>
<%= content_tag(:div, id: dom_id(draft), class: \"relative group cursor-pointer\", data: { draft_id: draft.id }) do %>
  <div class=\"aspect-square rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 hover:border-purple-400 dark:hover:border-purple-500 transition-all\">
    <% if draft.media.attached? %>
      <% if draft.media.image? %>
        <%= image_tag(draft.media, class: \"w-full h-full object-cover\", alt: draft.title) %>
      <% elsif draft.media.video? %>
        <video class=\"w-full h-full object-cover\" muted>
          <%= video_tag(draft.media, class: \"w-full h-full object-cover\", controls: false, muted: true) %>
        </video>
        <div class=\"absolute inset-0 flex items-center justify-center bg-black/30\">
          <svg class=\"w-12 h-12 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">
            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z\"></path>
            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path>
          </svg>
        </div>
      <% end %>
    <% elsif draft.media_url.present? %>
      <% if draft.media_url.match(/\\.(mp4|webm|mov)$/i) %>
        <video class=\"w-full h-full object-cover\" muted>
          <source src=\"<%= draft.media_url %>\" type=\"video/mp4\">
        </video>
        <div class=\"absolute inset-0 flex items-center justify-center bg-black/30\">
          <svg class=\"w-12 h-12 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">
            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z\"></path>
            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path>
          </svg>
        </div>
      <% else %>
        <img src=\"<%= draft.media_url %>\" alt=\"<%= draft.title %>\" class=\"w-full h-full object-cover\">
      <% end %>
    <% else %>
      <div class=\"w-full h-full flex items-center justify-center bg-gray-200 dark:bg-gray-600\">
        <svg class=\"w-12 h-12 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">
          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z\"></path>
        </svg>
      </div>
    <% end %>
    
    <!-- Hover Overlay -->
    <div class=\"absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center gap-2\">
      <p class=\"text-white text-sm font-medium px-2 text-center line-clamp-2\"><%= draft.title %></p>
      <div class=\"flex gap-2\">
        <%= link_to draft_path(draft), class: \"bg-white/20 hover:bg-white/30 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition-colors flex items-center\" do %>
          <svg class=\"w-3 h-3 mr-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">
            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\"></path>
            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\"></path>
          </svg>
          View
        <% end %>
        <%= button_to content_creation_delete_media_path(draft), method: :delete, form: { data: { turbo_confirm: 'Delete this media?' } }, class: \"bg-red-500/80 hover:bg-red-600 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition-colors flex items-center\" do %>
          <svg class=\"w-3 h-3 mr-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">
            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\"></path>
          </svg>
          Delete
        <% end %>
      </div>
    </div>
  </div>
<% end %>
