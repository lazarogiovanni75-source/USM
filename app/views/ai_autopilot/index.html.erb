<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">AI Autopilot</h1>
          <p class="mt-2 text-gray-600">Voice-activated AI assistant for managing your social media</p>
        </div>
        <div class="flex items-center space-x-4">
          <span class="px-4 py-2 bg-green-100 text-green-800 rounded-full text-sm font-medium">
            <%= current_user.voice_settings.first&.enabled? ? 'Active' : 'Inactive' %>
          </span>
        </div>
      </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Left Column: Voice Command Interface -->
      <div class="lg:col-span-2">
        <!-- Wake Word Detection -->
        <div class="mb-6">
          <%= render 'shared/wake_word_interface' %>
        </div>

        <!-- Voice Interface -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
          <!-- Voice Interface Header -->
          <div class="bg-gradient-to-r from-purple-600 to-blue-600 px-6 py-4">
            <h2 class="text-xl font-bold text-white flex items-center">
              <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
              </svg>
              Voice Command Center
            </h2>
            <p class="text-purple-100 text-sm mt-1">Click the microphone and speak your commands</p>
          </div>
          
          <!-- Voice Interface Body -->
          <div class="p-6">
            <%= render 'shared/voice_command_interface' %>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="mt-8 bg-white rounded-xl shadow-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Quick AI Actions</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <%= link_to generate_content_ai_autopilot_index_path(content_type: 'post'), method: :post, class: "flex flex-col items-center p-4 bg-purple-50 rounded-xl hover:bg-purple-100 transition-colors" do %>
              <svg class="w-8 h-8 text-purple-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              <span class="text-sm font-medium text-gray-700">Generate Post</span>
            <% end %>
            
            <%= link_to generate_content_ai_autopilot_index_path(content_type: 'story'), method: :post, class: "flex flex-col items-center p-4 bg-blue-50 rounded-xl hover:bg-blue-100 transition-colors" do %>
              <svg class="w-8 h-8 text-blue-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
              <span class="text-sm font-medium text-gray-700">Create Story</span>
            <% end %>
            
            <%= link_to analyze_engagement_ai_autopilot_index_path, method: :post, class: "flex flex-col items-center p-4 bg-green-50 rounded-xl hover:bg-green-100 transition-colors" do %>
              <svg class="w-8 h-8 text-green-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
              <span class="text-sm font-medium text-gray-700">Analytics</span>
            <% end %>
            
            <%= link_to logs_ai_autopilot_index_path, class: "flex flex-col items-center p-4 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors" do %>
              <svg class="w-8 h-8 text-orange-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <span class="text-sm font-medium text-gray-700">View Logs</span>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Right Column: Recent Commands & Status -->
      <div class="lg:col-span-1">
        <!-- Command History -->
        <div class="bg-white rounded-xl shadow-lg p-6 mb-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Recent Commands</h3>
          <% if @voice_commands.any? %>
            <div class="space-y-3">
              <% @voice_commands.limit(5).each do |command| %>
                <div class="flex items-start space-x-3 p-3 bg-gray-50 rounded-lg">
                  <div class="flex-shrink-0">
                    <div class="w-8 h-8 bg-<%= command.status == 'completed' ? 'green' : command.status == 'processing' ? 'yellow' : 'gray' %>-100 rounded-full flex items-center justify-center">
                      <svg class="w-4 h-4 text-<%= command.status == 'completed' ? 'green' : command.status == 'processing' ? 'yellow' : 'gray' %>-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
                      </svg>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900 truncate"><%= command.transcript || command.command_text %></p>
                    <p class="text-xs text-gray-500"><%= command.created_at.strftime('%b %d, %I:%M %p') %></p>
                  </div>
                  <span class="px-2 py-1 text-xs rounded-full <%= command.status == 'completed' ? 'bg-green-100 text-green-800' : command.status == 'processing' ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-800' %>">
                    <%= command.status %>
                  </span>
                </div>
              <% end %>
            </div>
            <div class="mt-4 text-center">
              <%= link_to "View All Commands", logs_ai_autopilot_index_path, class: "text-sm text-purple-600 hover:text-purple-800 font-medium" %>
            </div>
          <% else %>
            <div class="text-center py-8">
              <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
              </svg>
              <p class="text-gray-500 text-sm">No voice commands yet</p>
              <p class="text-gray-400 text-xs mt-1">Click the microphone to start</p>
            </div>
          <% end %>
        </div>

        <!-- Statistics -->
        <div class="bg-white rounded-xl shadow-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Statistics</h3>
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Total Commands</span>
              <span class="text-lg font-semibold text-gray-900"><%= @voice_commands.count %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Completed</span>
              <span class="text-lg font-semibold text-green-600"><%= @voice_commands.completed.count %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Processing</span>
              <span class="text-lg font-semibold text-yellow-600"><%= @voice_commands.processing.count %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Failed</span>
              <span class="text-lg font-semibold text-red-600"><%= @voice_commands.failed.count %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Help Section -->
    <div class="mt-8 bg-gradient-to-r from-purple-50 to-blue-50 rounded-xl p-6 border border-purple-100">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Voice Command Examples</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-white rounded-lg p-4 shadow-sm">
          <p class="text-purple-600 font-medium mb-1">Create Campaign</p>
          <p class="text-gray-600 text-sm">"Create a new campaign for summer products"</p>
        </div>
        <div class="bg-white rounded-lg p-4 shadow-sm">
          <p class="text-blue-600 font-medium mb-1">Generate Content</p>
          <p class="text-gray-600 text-sm">"Generate a post about our new feature"</p>
        </div>
        <div class="bg-white rounded-lg p-4 shadow-sm">
          <p class="text-green-600 font-medium mb-1">Schedule Post</p>
          <p class="text-gray-600 text-sm">"Schedule this for tomorrow at 2 PM"</p>
        </div>
        <div class="bg-white rounded-lg p-4 shadow-sm">
          <p class="text-orange-600 font-medium mb-1">Generate Video</p>
          <p class="text-gray-600 text-sm">"Generate a video about our brand"</p>
        </div>
        <div class="bg-white rounded-lg p-4 shadow-sm">
          <p class="text-red-600 font-medium mb-1">Analytics</p>
          <p class="text-gray-600 text-sm">"Show me my performance metrics"</p>
        </div>
        <div class="bg-white rounded-lg p-4 shadow-sm">
          <p class="text-gray-600 font-medium mb-1">General Help</p>
          <p class="text-gray-600 text-sm">"What can you help me with?"</p>
        </div>
      </div>
    </div>
  </div>
</div>
