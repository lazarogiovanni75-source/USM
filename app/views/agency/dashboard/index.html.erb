<% content_for :title, "Agency Dashboard" %>

<div class="container-xl">
  <!-- Page Header -->
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50">Agency Dashboard</h1>
    <p class="text-gray-600 dark:text-gray-400 mt-2">Manage all your clients and campaigns in one place</p>
  </div>

  <!-- Quick Stats -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <!-- Total Clients -->
    <div class="card bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/20 border border-blue-200 dark:border-blue-700">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-blue-600 dark:text-blue-400">Total Clients</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @clients.count %></p>
          </div>
          <div class="w-12 h-12 bg-blue-200 dark:bg-blue-700 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-600 dark:text-blue-300" fill="currentColor" viewBox="0 0 20 20">
              <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Running Campaigns -->
    <div class="card bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20 border border-green-200 dark:border-green-700">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-green-600 dark:text-green-400">Running Campaigns</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @campaigns_overview[:running] %></p>
          </div>
          <div class="w-12 h-12 bg-green-200 dark:bg-green-700 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-green-600 dark:text-green-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Tasks Pending -->
    <div class="card bg-gradient-to-br from-yellow-50 to-yellow-100 dark:from-yellow-900/20 dark:to-yellow-800/20 border border-yellow-200 dark:border-yellow-700">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-yellow-600 dark:text-yellow-400">Tasks Pending</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @tasks_overview[:pending] %></p>
          </div>
          <div class="w-12 h-12 bg-yellow-200 dark:bg-yellow-700 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-yellow-600 dark:text-yellow-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Failed Tasks -->
    <div class="card bg-gradient-to-br from-red-50 to-red-100 dark:from-red-900/20 dark:to-red-800/20 border border-red-200 dark:border-red-700">
      <div class="card-body">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-red-600 dark:text-red-400">Failed Tasks</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @tasks_overview[:failed] %></p>
          </div>
          <div class="w-12 h-12 bg-red-200 dark:bg-red-700 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-red-600 dark:text-red-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Campaigns Overview -->
    <div class="lg:col-span-2">
      <div class="card border border-gray-200 dark:border-gray-700">
        <div class="card-header bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-50">Campaigns Overview</h3>
          <div class="flex gap-2">
            <%= link_to agency_campaigns_path, class: "btn btn-sm btn-outline-primary" do %>
              View All
            <% end %>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="grid grid-cols-5 gap-4 p-4 border-b border-gray-200 dark:border-gray-700">
            <div class="text-center">
              <p class="text-2xl font-bold text-gray-900 dark:text-gray-50"><%= @campaigns_overview[:total] %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Total</p>
            </div>
            <div class="text-center">
              <p class="text-2xl font-bold text-green-600"><%= @campaigns_overview[:running] %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Running</p>
            </div>
            <div class="text-center">
              <p class="text-2xl font-bold text-yellow-600"><%= @campaigns_overview[:paused] %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Paused</p>
            </div>
            <div class="text-center">
              <p class="text-2xl font-bold text-blue-600"><%= @campaigns_overview[:completed] %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Completed</p>
            </div>
            <div class="text-center">
              <p class="text-2xl font-bold text-red-600"><%= @campaigns_overview[:failed] %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Failed</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Trending Content -->
      <div class="card border border-gray-200 dark:border-gray-700 mt-6">
        <div class="card-header bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-50">🔥 Trending Content</h3>
          <%= link_to agency_trending_path, class: "btn btn-sm btn-outline-primary" do %>
            View All
          <% end %>
        </div>
        <div class="card-body p-0">
          <% if @trending.any? %>
            <div class="divide-y divide-gray-200 dark:divide-gray-700">
              <% @trending.each do |metric| %>
                <div class="p-4 hover:bg-gray-50 dark:hover:bg-gray-800/50">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-1">
                        <span class="badge badge-success">#<%= metric.viral_rank %></span>
                        <span class="text-sm font-medium text-gray-900 dark:text-gray-50">
                          <%= metric.scheduled_post.platform&.titleize %>
                        </span>
                      </div>
                      <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
                        <%= metric.scheduled_post.content&.truncate(100) %>
                      </p>
                      <div class="flex items-center gap-4 mt-2 text-xs text-gray-500 dark:text-gray-400">
                        <span>📈 <%= (metric.engagement_rate * 100).round(2) %>%</span>
                        <span>⚡ <%= metric.share_velocity.round(2) %>/hr</span>
                        <span>🏷️ <%= metric.top_hashtags.first(3).join(', ') %></span>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="p-8 text-center text-gray-500 dark:text-gray-400">
              No trending content yet. Run some campaigns to see results!
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Alerts -->
      <div class="card border border-gray-200 dark:border-gray-700">
        <div class="card-header bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-50">⚠️ Alerts</h3>
        </div>
        <div class="card-body p-0">
          <% if @alerts.any? %>
            <div class="divide-y divide-gray-200 dark:divide-gray-700">
              <% @alerts.each do |alert| %>
                <div class="p-4 <%= alert[:severity] == 'high' ? 'bg-red-50 dark:bg-red-900/20' : '' %>">
                  <div class="flex items-start gap-3">
                    <div class="flex-shrink-0 mt-0.5">
                      <% case alert[:severity] %>
                      <% when 'high' %>
                        <span class="w-2 h-2 bg-red-500 rounded-full block"></span>
                      <% when 'medium' %>
                        <span class="w-2 h-2 bg-yellow-500 rounded-full block"></span>
                      <% else %>
                        <span class="w-2 h-2 bg-blue-500 rounded-full block"></span>
                      <% end %>
                    </div>
                    <div>
                      <p class="text-sm text-gray-900 dark:text-gray-50"><%= alert[:message] %></p>
                      <p class="text-xs text-gray-500 mt-1"><%= time_ago_in_words(alert[:created_at]) %> ago</p>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="p-6 text-center text-gray-500 dark:text-gray-400">
              No alerts at this time
            </div>
          <% end %>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="card border border-gray-200 dark:border-gray-700">
        <div class="card-header bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-50">Quick Actions</h3>
        </div>
        <div class="card-body">
          <div class="space-y-3">
            <%= link_to new_client_path, class: "w-full btn btn-outline-primary justify-start" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
              </svg>
              Add New Client
            <% end %>
            
            <%= link_to agency_campaigns_path, class: "w-full btn btn-outline-primary justify-start" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
              </svg>
              View All Campaigns
            <% end %>
            
            <%= link_to agency_costs_path, class: "w-full btn btn-outline-primary justify-start" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Cost Tracking
            <% end %>
            
            <%= link_to agency_trending_path, class: "w-full btn btn-outline-primary justify-start" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
              Viral Trends
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
