<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Trend Analysis</h1>
          <p class="mt-2 text-gray-600">AI-powered insights to optimize your content strategy</p>
        </div>
        <div class="flex items-center space-x-3">
          <%= link_to export_trends_trend_analyses_path(format: :csv), 
              class: "btn-secondary inline-flex items-center px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors" do %>
            <%= lucide_icon "download", class: "w-5 h-5 mr-2" %>
            Export CSV
          <% end %>
        </div>
      </div>
    </div>

    <!-- AI Insights -->
    <% if @insights.any? %>
      <div class="mb-8 bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-lg p-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <%= lucide_icon "brain", class: "w-6 h-6 text-blue-600" %>
          </div>
          <div class="ml-3">
            <h3 class="text-lg font-medium text-blue-900 mb-3">AI-Powered Insights</h3>
            <div class="space-y-2">
              <% @insights.each do |insight| %>
                <p class="text-sm text-blue-800">• <%= insight %></p>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Trend Overview Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <!-- Content Trends -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Content Types</h3>
          <%= link_to trend_analyses_path(type: 'content'), 
              class: "text-blue-600 hover:text-blue-700 text-sm font-medium" do %>
            View All
          <% end %>
        </div>
        
        <% if @trends[:content_trends].any? %>
          <div class="space-y-3">
            <% @trends[:content_trends].first(3).each do |trend| %>
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <p class="text-sm font-medium text-gray-900 capitalize"><%= trend[:content_type] %></p>
                  <p class="text-xs text-gray-500"><%= trend[:current_count] %> posts</p>
                </div>
                <% if trend[:trend_direction] == 'rising' %>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <%= lucide_icon "trending-up", class: "w-3 h-3 mr-1" %>
                    +<%= trend[:change_percent] %>%
                  </span>
                <% elsif trend[:trend_direction] == 'declining' %>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    <%= lucide_icon "trending-down", class: "w-3 h-3 mr-1" %>
                    <%= trend[:change_percent] %>%
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    <%= lucide_icon "minus", class: "w-3 h-3 mr-1" %>
                    Stable
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No content trends available</p>
        <% end %>
      </div>

      <!-- Platform Performance -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Platform Performance</h3>
          <%= link_to trend_analyses_path(type: 'platform'), 
              class: "text-blue-600 hover:text-blue-700 text-sm font-medium" do %>
            View All
          <% end %>
        </div>
        
        <% if @trends[:platform_trends].any? %>
          <div class="space-y-3">
            <% @trends[:platform_trends].first(3).each do |trend| %>
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <p class="text-sm font-medium text-gray-900 capitalize"><%= trend[:platform] %></p>
                  <p class="text-xs text-gray-500"><%= trend[:current_engagement] %>% engagement</p>
                </div>
                <% if trend[:trend_direction] == 'improving' %>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <%= lucide_icon "trending-up", class: "w-3 h-3 mr-1" %>
                    +<%= trend[:change_percent] %>%
                  </span>
                <% elsif trend[:trend_direction] == 'declining' %>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    <%= lucide_icon "trending-down", class: "w-3 h-3 mr-1" %>
                    <%= trend[:change_percent] %>%
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                    <%= lucide_icon "minus", class: "w-3 h-3 mr-1" %>
                    Stable
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No platform trends available</p>
        <% end %>
      </div>

      <!-- Optimal Timing -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Optimal Timing</h3>
          <%= link_to trend_analyses_path(type: 'timing'), 
              class: "text-blue-600 hover:text-blue-700 text-sm font-medium" do %>
            View All
          <% end %>
        </div>
        
        <% if @trends[:timing_trends].any? %>
          <div class="space-y-3">
            <% @trends[:timing_trends].first(3).each do |timing| %>
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <p class="text-sm font-medium text-gray-900">
                    <%= timing[:hour] %>:00
                  </p>
                  <p class="text-xs text-gray-500"><%= timing[:avg_engagement] %>% engagement</p>
                </div>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  <%= timing[:performance_score].titleize %>
                </span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No timing data available</p>
        <% end %>
      </div>
    </div>

    <!-- Detailed Trend Sections -->
    <div class="space-y-8">
      <!-- Topic Trends -->
      <% if @trends[:topic_trends].any? %>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200">
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-semibold text-gray-900">Topic Trends</h2>
              <%= link_to trend_analyses_path(type: 'topic'), 
                  class: "text-blue-600 hover:text-blue-700 text-sm font-medium" do %>
                View Detailed Analysis
              <% end %>
            </div>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              <% @trends[:topic_trends].first(6).each do |topic| %>
                <div class="border border-gray-200 rounded-lg p-4">
                  <div class="flex items-center justify-between mb-2">
                    <h4 class="text-sm font-medium text-gray-900 capitalize"><%= topic[:keyword] %></h4>
                    <% if topic[:trend_direction] == 'rising' %>
                      <%= lucide_icon "trending-up", class: "w-4 h-4 text-green-500" %>
                    <% elsif topic[:trend_direction] == 'declining' %>
                      <%= lucide_icon "trending-down", class: "w-4 h-4 text-red-500" %>
                    <% else %>
                      <%= lucide_icon "minus", class: "w-4 h-4 text-gray-500" %>
                    <% end %>
                  </div>
                  <p class="text-xs text-gray-500 mb-1">
                    Frequency: <%= topic[:recent_frequency] %> (<%= topic[:change_percent] %>%)
                  </p>
                  <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-blue-600 h-2 rounded-full" style="width: <%= [topic[:change_percent].abs, 100].min %>%"></div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Engagement Trends Chart -->
      <% if @trends[:engagement_trends].any? %>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-xl font-semibold text-gray-900">Engagement Trends Over Time</h2>
          </div>
          <div class="p-6">
            <div class="space-y-4">
              <% @trends[:engagement_trends].each do |engagement| %>
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                  <div class="flex-1">
                    <p class="text-sm font-medium text-gray-900">
                      <%= engagement[:date].strftime('%B %d') %>
                    </p>
                    <p class="text-xs text-gray-500">
                      <%= engagement[:engagement_rate] %>% engagement rate
                    </p>
                  </div>
                  <div class="flex items-center space-x-2">
                    <% if engagement[:trend_direction] == 'improving' %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <%= lucide_icon "trending-up", class: "w-3 h-3 mr-1" %>
                        +<%= engagement[:change_percent] %>%
                      </span>
                    <% elsif engagement[:trend_direction] == 'declining' %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                        <%= lucide_icon "trending-down", class: "w-3 h-3 mr-1" %>
                        <%= engagement[:change_percent] %>%
                      </span>
                    <% else %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                        <%= lucide_icon "minus", class: "w-3 h-3 mr-1" %>
                        Stable
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Summary Statistics -->
    <div class="mt-8 bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Analysis Summary</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-2xl font-bold text-blue-600">
            <%= @trends[:content_trends].count %>
          </div>
          <div class="text-sm text-gray-600">Content Types Analyzed</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-green-600">
            <%= @trends[:topic_trends].count %>
          </div>
          <div class="text-sm text-gray-600">Trending Topics Identified</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-purple-600">
            <%= @insights.count %>
          </div>
          <div class="text-sm text-gray-600">AI Insights Generated</div>
        </div>
      </div>
    </div>
  </div>
</div>