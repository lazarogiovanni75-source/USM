<!-- Postforme Analytics Dashboard -->
<div class="container mx-auto px-4 py-8">
  <!-- Header -->
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-8">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-lg">
        <%= lucide_icon "bar-chart-3", class: "w-7 h-7 text-white" %>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-primary">Analytics</h1>
        <p class="text-sm text-muted">Post performance insights from Postforme</p>
      </div>
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <!-- Time Period Selector -->
      <div class="flex items-center bg-surface-elevated rounded-lg p-1">
        <% [7, 30, 90].each do |days| %>
          <%= link_to "#{days}d",
              postforme_analytics_index_path(days: days),
              class: "px-3 py-1.5 text-sm rounded-lg transition-colors #{@days == days ? 'bg-primary text-white' : 'text-muted hover:bg-surface'}" %>
        <% end %>
      </div>
      <!-- Refresh Button -->
      <%= button_to refresh_postforme_analytics_path,
          method: :post,
          class: "btn-secondary inline-flex items-center" do %>
        <%= lucide_icon "refresh-cw", class: "w-4 h-4 mr-2" %>
        Refresh
      <% end %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4 mb-8">
    <div class="bg-white rounded-2xl p-5 shadow-sm border border-border/50">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/20 flex items-center justify-center">
          <%= lucide_icon "file-text", class: "w-5 h-5 text-blue-600" %>
        </div>
        <div>
          <p class="text-xs text-muted">Total Posts</p>
          <p class="text-xl font-bold text-primary"><%= @dashboard_data[:summary][:total_posts] %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl p-5 shadow-sm border border-border/50">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-pink-100 dark:bg-pink-900/20 flex items-center justify-center">
          <%= lucide_icon "heart", class: "w-5 h-5 text-pink-600" %>
        </div>
        <div>
          <p class="text-xs text-muted">Total Engagements</p>
          <p class="text-xl font-bold text-primary"><%= number_with_delimiter(@dashboard_data[:summary][:total_engagement]) %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl p-5 shadow-sm border border-border/50">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-purple-100 dark:bg-purple-900/20 flex items-center justify-center">
          <%= lucide_icon "eye", class: "w-5 h-5 text-purple-600" %>
        </div>
        <div>
          <p class="text-xs text-muted">Impressions</p>
          <p class="text-xl font-bold text-primary"><%= number_with_delimiter(@dashboard_data[:summary][:total_impressions]) %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl p-5 shadow-sm border border-border/50">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-green-100 dark:bg-green-900/20 flex items-center justify-center">
          <%= lucide_icon "percent", class: "w-5 h-5 text-green-600" %>
        </div>
        <div>
          <p class="text-xs text-muted">Avg Rate</p>
          <p class="text-xl font-bold text-primary"><%= @dashboard_data[:summary][:avg_engagement_rate] %>%</p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl p-5 shadow-sm border border-border/50">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-amber-100 dark:bg-amber-900/20 flex items-center justify-center">
          <%= lucide_icon "mouse-pointer-click", class: "w-5 h-5 text-amber-600" %>
        </div>
        <div>
          <p class="text-xs text-muted">Total Clicks</p>
          <p class="text-xl font-bold text-primary"><%= number_with_delimiter(@dashboard_data[:summary][:total_clicks]) %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts Section -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Engagement Over Time -->
    <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
      <h2 class="text-lg font-bold text-primary mb-4 flex items-center">
        <%= lucide_icon "trending-up", class: "w-5 h-5 mr-2 text-green-500" %>
        Engagement Over Time
      </h2>
      <div id="engagement-chart" class="h-64 flex items-end justify-around gap-2">
        <% @dashboard_data[:performance_trends].last(14).each do |trend| %>
          <div class="flex flex-col items-center flex-1">
            <div class="w-full bg-gradient-to-t from-primary to-secondary rounded-t transition-all hover:opacity-80"
                 style="height: <%= [trend[:engagement].to_i, 1].max %>px; min-height: 4px; max-height: 200px;">
            </div>
            <span class="text-xs text-muted mt-2"><%= trend[:label] %></span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Platform Comparison -->
    <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
      <h2 class="text-lg font-bold text-primary mb-4 flex items-center">
        <%= lucide_icon "layout", class: "w-5 h-5 mr-2 text-blue-500" %>
        Platform Performance
      </h2>
      <div class="space-y-4">
        <% @dashboard_data[:platform_breakdown].each do |platform| %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br <%= platform[:color_class] %> flex items-center justify-center">
                <%= lucide_icon platform[:icon], class: "w-4 h-4 text-white" %>
              </div>
              <div>
                <p class="font-medium text-primary"><%= platform[:display_name] %></p>
                <p class="text-xs text-muted"><%= platform[:post_count] %> posts</p>
              </div>
            </div>
            <div class="text-right">
              <p class="font-semibold text-primary"><%= number_with_delimiter(platform[:total_engagement]) %></p>
              <p class="text-xs text-muted"><%= platform[:engagement_rate] %>% rate</p>
            </div>
          </div>
          <div class="h-2 bg-surface-elevated rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r <%= platform[:color_class] %> rounded-full transition-all"
                 style="width: <%= [(platform[:total_engagement].to_f / [@dashboard_data[:platform_breakdown].max_by { |p| p[:total_engagement] }[:total_engagement], 1].max * 100), 5].max %>%;">
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- AI Insights Section -->
  <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6 mb-8">
    <h2 class="text-lg font-bold text-primary mb-4 flex items-center">
      <%= lucide_icon "brain", class: "w-5 h-5 mr-2 text-purple-500" %>
      AI Insights & Recommendations
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @dashboard_data[:content_insights].each do |insight| %>
        <div class="p-4 bg-surface-elevated rounded-xl border border-border/30">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900/20 flex items-center justify-center flex-shrink-0">
              <% case insight[:type] %>
              <% when 'content_type' %>
                <%= lucide_icon "file-text", class: "w-4 h-4 text-purple-600" %>
              <% when 'platform' %>
                <%= lucide_icon "share-2", class: "w-4 h-4 text-purple-600" %>
              <% when 'timing' %>
                <%= lucide_icon "clock", class: "w-4 h-4 text-purple-600" %>
              <% else %>
                <%= lucide_icon "lightbulb", class: "w-4 h-4 text-purple-600" %>
              <% end %>
            </div>
            <div>
              <h3 class="font-semibold text-primary"><%= insight[:title] %></h3>
              <p class="text-sm text-muted mt-1"><%= insight[:description] %></p>
              <p class="text-sm text-primary font-medium mt-2"><%= insight[:recommendation] %></p>
            </div>
          </div>
        </div>
      <% end %>
      <% if @dashboard_data[:content_insights].empty? %>
        <div class="col-span-full text-center py-8 text-muted">
          <%= lucide_icon "lightbulb", class: "w-8 h-8 mx-auto mb-2 opacity-50" %>
          <p>Publish more posts to get AI-powered insights</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Best Posting Times -->
  <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6 mb-8">
    <h2 class="text-lg font-bold text-primary mb-4 flex items-center">
      <%= lucide_icon "clock", class: "w-5 h-5 mr-2 text-amber-500" %>
      Best Posting Times
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">
      <% @dashboard_data[:best_posting_times].first(6).each do |time| %>
        <div class="p-4 bg-surface-elevated rounded-xl text-center border border-border/30 hover:border-primary/30 transition-colors">
          <p class="text-2xl font-bold text-primary"><%= time[:hour] %>:00</p>
          <p class="text-sm text-muted"><%= time[:post_count] %> posts</p>
          <p class="text-xs text-green-600 font-medium mt-1">+<%= time[:avg_engagement].round(1) %> avg eng</p>
        </div>
      <% end %>
      <% if @dashboard_data[:best_posting_times].empty? %>
        <div class="col-span-full text-center py-8 text-muted">
          <p>No data available yet. Post more content to see optimal times.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Top Performing Posts -->
  <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
    <h2 class="text-lg font-bold text-primary mb-4 flex items-center">
      <%= lucide_icon "trophy", class: "w-5 h-5 mr-2 text-amber-500" %>
      Top Performing Posts
    </h2>
    <div class="overflow-x-auto">
      <table class="min-w-full">
        <thead>
          <tr class="border-b border-border/50">
            <th class="text-left py-3 px-4 text-sm font-medium text-muted">Post</th>
            <th class="text-left py-3 px-4 text-sm font-medium text-muted">Platform</th>
            <th class="text-center py-3 px-4 text-sm font-medium text-muted">Likes</th>
            <th class="text-center py-3 px-4 text-sm font-medium text-muted">Comments</th>
            <th class="text-center py-3 px-4 text-sm font-medium text-muted">Shares</th>
            <th class="text-center py-3 px-4 text-sm font-medium text-muted">Impressions</th>
            <th class="text-center py-3 px-4 text-sm font-medium text-muted">Rate</th>
            <th class="text-center py-3 px-4 text-sm font-medium text-muted">Score</th>
          </tr>
        </thead>
        <tbody>
          <% @dashboard_data[:top_performers].each do |post| %>
            <tr class="border-b border-border/30 hover:bg-surface-elevated/50 transition-colors">
              <td class="py-3 px-4">
                <div class="flex items-center gap-3">
                  <% if post[:thumbnail].present? %>
                    <img src="<%= post[:thumbnail] %>" alt="" class="w-10 h-10 rounded-lg object-cover">
                  <% else %>
                    <div class="w-10 h-10 rounded-lg bg-surface-elevated flex items-center justify-center">
                      <%= lucide_icon "file-text", class: "w-5 h-5 text-muted" %>
                    </div>
                  <% end %>
                  <div class="min-w-0">
                    <p class="font-medium text-primary truncate max-w-xs"><%= post[:title] %></p>
                    <p class="text-xs text-muted"><%= post[:posted_at] %></p>
                  </div>
                </div>
              </td>
              <td class="py-3 px-4">
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gradient-to-r <%= post[:platform_color] %> text-white">
                  <%= lucide_icon post[:platform_icon], class: "w-3 h-3 mr-1" %>
                  <%= post[:platform]&.capitalize %>
                </span>
              </td>
              <td class="py-3 px-4 text-center">
                <span class="text-pink-500 font-medium"><%= number_with_delimiter(post[:metrics][:likes]) %></span>
              </td>
              <td class="py-3 px-4 text-center">
                <span class="text-blue-500 font-medium"><%= number_with_delimiter(post[:metrics][:comments]) %></span>
              </td>
              <td class="py-3 px-4 text-center">
                <span class="text-green-500 font-medium"><%= number_with_delimiter(post[:metrics][:shares]) %></span>
              </td>
              <td class="py-3 px-4 text-center">
                <span class="text-purple-500 font-medium"><%= number_with_delimiter(post[:metrics][:impressions]) %></span>
              </td>
              <td class="py-3 px-4 text-center">
                <span class="text-amber-500 font-medium"><%= post[:metrics][:engagement_rate] %>%</span>
              </td>
              <td class="py-3 px-4 text-center">
                <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br <%= score_color(post[:performance_score]) %> text-white font-bold">
                  <%= post[:performance_score] %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @dashboard_data[:top_performers].empty? %>
            <tr>
              <td colspan="8" class="py-12 text-center text-muted">
                <%= lucide_icon "bar-chart-3", class: "w-8 h-8 mx-auto mb-2 opacity-50" %>
                <p>No published posts with analytics data yet</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>


