<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Automation Rules</h1>
          <p class="mt-2 text-gray-600">Automate your content workflows with intelligent rules</p>
        </div>
        <div class="flex items-center space-x-3">
          <%= link_to export_rules_automation_rules_path(format: :csv), 
              class: "btn-secondary inline-flex items-center px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors" do %>
            <%= lucide_icon "download", class: "w-5 h-5 mr-2" %>
            Export
          <% end %>
          <%= link_to new_automation_rule_path, 
              class: "btn-primary inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
            <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
            New Rule
          <% end %>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "zap", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @statistics[:total_executions] %>
            </div>
            <div class="text-sm text-gray-600">Total Executions</div>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "check-circle", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @statistics[:successful_executions] %>
            </div>
            <div class="text-sm text-gray-600">Successful</div>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-red-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "x-circle", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @statistics[:failed_executions] %>
            </div>
            <div class="text-sm text-gray-600">Failed</div>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="w-8 h-8 bg-purple-500 rounded-lg flex items-center justify-center">
              <%= lucide_icon "trending-up", class: "w-5 h-5 text-white" %>
            </div>
          </div>
          <div class="ml-4">
            <div class="text-2xl font-semibold text-gray-900">
              <%= @statistics[:success_rate] %>%
            </div>
            <div class="text-sm text-gray-600">Success Rate</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Rule Templates -->
    <div class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Quick Start Templates</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @rule_templates.each do |template| %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition-shadow">
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center">
                  <%= lucide_icon "zap", class: "w-6 h-6 text-blue-600 mr-3" %>
                  <span class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded-full">
                    <%= template[:action_type].gsub('_', ' ').titleize %>
                  </span>
                </div>
              </div>
              
              <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= template[:name] %></h3>
              <p class="text-gray-600 text-sm mb-4"><%= template[:description] %></p>
              
              <div class="space-y-2 mb-4">
                <% template[:trigger_events].each do |event| %>
                  <span class="inline-block text-xs px-2 py-1 bg-blue-50 text-blue-600 rounded-full">
                    <%= event.gsub('_', ' ').titleize %>
                  </span>
                <% end %>
              </div>
              
              <%= link_to create_from_template_automation_rules_path(template_id: template[:id]),
                  method: :post,
                  class: "w-full text-center py-2 px-4 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium" do %>
                Use Template
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Active Rules -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold text-gray-900">Your Automation Rules</h2>
          <div class="flex items-center space-x-4">
            <%= form_with(url: automation_rules_path, method: :get, local: true, class: "flex items-center space-x-2") do |form| %>
              <%= form.text_field :search, 
                  value: params[:search], 
                  placeholder: "Search rules...", 
                  class: "px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 text-sm" %>
              <%= form.select :status_filter, 
                  [['All', ''], ['Active', 'active'], ['Inactive', 'inactive']], 
                  { selected: params[:status_filter] }, 
                  { class: "px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 text-sm" } %>
              <%= form.submit "Filter", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm" %>
            <% end %>
          </div>
        </div>
      </div>
      
      <% if @rules.any? %>
        <div class="divide-y divide-gray-200">
          <% @rules.each do |rule| %>
            <div class="p-6">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="flex items-center mb-2">
                    <h3 class="text-lg font-medium text-gray-900 mr-3"><%= rule.name %></h3>
                    <% if rule.active? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <div class="w-1.5 h-1.5 bg-green-400 rounded-full mr-1.5"></div>
                        Active
                      </span>
                    <% else %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                        <div class="w-1.5 h-1.5 bg-gray-400 rounded-full mr-1.5"></div>
                        Inactive
                      </span>
                    <% end %>
                  </div>
                  
                  <p class="text-gray-600 text-sm mb-3"><%= rule.description %></p>
                  
                  <div class="flex flex-wrap gap-2">
                    <span class="inline-block text-xs px-2 py-1 bg-blue-100 text-blue-800 rounded-full">
                      <%= rule.action_type.gsub('_', ' ').titleize %>
                    </span>
                    <% rule.trigger_events.each do |event| %>
                      <span class="inline-block text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded-full">
                        <%= event.gsub('_', ' ').titleize %>
                      </span>
                    <% end %>
                  </div>
                </div>
                
                <div class="flex items-center space-x-2 ml-4">
                  <%= link_to test_rule_automation_rule_path(rule), 
                      method: :post,
                      class: "text-blue-600 hover:text-blue-700 text-sm font-medium" do %>
                    Test
                  <% end %>
                  
                  <%= link_to toggle_status_automation_rule_path(rule), 
                      method: :post,
                      class: "text-gray-600 hover:text-gray-700 text-sm font-medium" do %>
                    <%= rule.active? ? 'Disable' : 'Enable' %>
                  <% end %>
                  
                  <%= link_to edit_automation_rule_path(rule), 
                      class: "text-gray-600 hover:text-gray-700 text-sm font-medium" do %>
                    Edit
                  <% end %>
                  
                  <%= link_to automation_rule_path(rule), 
                      method: :delete,
                      data: { confirm: 'Are you sure?' },
                      class: "text-red-600 hover:text-red-700 text-sm font-medium" do %>
                    Delete
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-8 text-center">
          <%= lucide_icon "zap", class: "w-12 h-12 text-gray-300 mx-auto mb-4" %>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No automation rules created</h3>
          <p class="text-gray-500 mb-4">Get started by creating your first automation rule</p>
          <%= link_to new_automation_rule_path, 
              class: "btn-primary inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors" do %>
            <%= lucide_icon "plus", class: "w-5 h-5 mr-2" %>
            Create First Rule
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>