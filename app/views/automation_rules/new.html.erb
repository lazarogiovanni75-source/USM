<% content_for :title, "New Automation Rule" %>

<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated">
  <div class="container-xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-4">
        <%= link_to automation_rules_path, class: "p-2 hover:bg-surface-elevated rounded-lg transition-colors" do %>
          <%= lucide_icon "arrow-left", class: "w-5 h-5 text-primary" %>
        <% end %>
        <h1 class="text-3xl font-bold text-gray-900">Create Automation Rule</h1>
      </div>
      <p class="text-muted">Set up automated workflows for your content</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Form -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <%= form_with(model: @rule, url: automation_rules_path, local: true) do |f| %>
            <!-- Basic Info -->
            <div class="mb-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">Basic Information</h3>
              <div class="space-y-4">
                <div>
                  <%= f.label :name, "Rule Name", class: "block text-sm font-medium text-gray-900 mb-2" %>
                  <%= f.text_field :name, class: "form-input w-full", placeholder: "e.g., Auto-schedule new content" %>
                </div>
                <div>
                  <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-900 mb-2" %>
                  <%= f.text_area :description, class: "form-input w-full", rows: 3, placeholder: "Describe what this automation does" %>
                </div>
              </div>
            </div>

            <!-- Trigger Events -->
            <div class="mb-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">Trigger Events</h3>
              <p class="text-sm text-muted mb-4">When should this automation run?</p>
              <div class="grid grid-cols-2 gap-3">
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.check_box :trigger_events, { multiple: true }, 'content_created', false %>
                  <span class="ml-2 text-sm">Content Created</span>
                </label>
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.check_box :trigger_events, { multiple: true }, 'content_published', false %>
                  <span class="ml-2 text-sm">Content Published</span>
                </label>
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.check_box :trigger_events, { multiple: true }, 'engagement_received', false %>
                  <span class="ml-2 text-sm">Engagement Received</span>
                </label>
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.check_box :trigger_events, { multiple: true }, 'draft_approved', false %>
                  <span class="ml-2 text-sm">Draft Approved</span>
                </label>
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.check_box :trigger_events, { multiple: true }, 'scheduled_time', false %>
                  <span class="ml-2 text-sm">Scheduled Time</span>
                </label>
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.check_box :trigger_events, { multiple: true }, 'daily', false %>
                  <span class="ml-2 text-sm">Daily Trigger</span>
                </label>
              </div>
            </div>

            <!-- Action Type -->
            <div class="mb-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">Action</h3>
              <p class="text-sm text-muted mb-4">What should happen?</p>
              <div class="grid grid-cols-2 gap-3">
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.radio_button :action_type, 'auto_schedule', class: "w-4 h-4 text-primary" %>
                  <span class="ml-2 text-sm">Auto-Schedule</span>
                </label>
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.radio_button :action_type, 'auto_notice', class: "w-4 h-4 text-primary" %>
                  <span class="ml-2 text-sm">Send Notification</span>
                </label>
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.radio_button :action_type, 'auto_tag', class: "w-4 h-4 text-primary" %>
                  <span class="ml-2 text-sm">Auto-Tag Content</span>
                </label>
                <label class="flex items-center p-3 border border-border rounded-lg cursor-pointer hover:bg-surface-elevated">
                  <%= f.radio_button :action_type, 'auto_move', class: "w-4 h-4 text-primary" %>
                  <span class="ml-2 text-sm">Change Status</span>
                </label>
              </div>
            </div>

            <!-- Submit -->
            <div class="flex justify-end gap-4">
              <%= link_to "Cancel", automation_rules_path, class: "btn-secondary" %>
              <%= f.submit "Create Rule", class: "btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Sidebar - Templates -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Quick Start Templates</h3>
          <div class="space-y-3">
            <% (@rule_templates || []).each do |template| %>
              <div class="p-4 border border-border rounded-lg hover:border-primary transition-colors">
                <h4 class="font-medium text-gray-900"><%= template[:name] %></h4>
                <p class="text-sm text-muted mt-1"><%= template[:description] %></p>
                <%= button_to "Use Template", create_from_template_automation_rules_path(template_id: template[:id]), 
                    method: :post, 
                    class: "mt-3 text-sm text-gray-900 hover:underline" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
