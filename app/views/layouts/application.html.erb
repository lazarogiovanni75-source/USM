<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <meta name="turbo-cache-control" content="no-cache">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#a172f3">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="user-id" content="<%= current_user&.id || 'anonymous' %>">
    <meta name="user-signed-in" content="<%= user_signed_in? %>">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="renderer" content="webkit">
    <meta http-equiv="cleartype" content="on">
    <meta name="HandheldFriendly" content="True">
    <meta name="MobileOptimized" content="320">
    <meta name="railway-backend-url" content="<%= ENV['RAILWAY_BACKEND_URL'] || 'https://backend-api-production-00f5.up.railway.app' %>">
    <% if @disable_error_tracking %>
      <meta name="disable-error-tracking" content="true">
    <% end %>
    <title>
    <%- if content_for?(:title) %>
      <%= yield(:title) + ' | ' + Rails.application.config.x.appname %>
    <%- else %>
      <%= Rails.application.config.x.appname %>
    <%- end %>
    </title>
    <%= csrf_meta_tags %>
    <%= action_cable_meta_tag %>
    <%= content_for?(:head) ? yield(:head) : '' %>
    <link rel="stylesheet" href="/dev-assets/application.css" media="all" />
    <!-- Load error handler early to catch all errors -->
    <!-- stimulus-validator: allow-script -->
    <script src="/dev-assets/error_handler.js"></script>
    <!-- stimulus-validator: allow-script -->
    <script src="/dev-assets/application.js" type="module"></script>
    <!-- Generate new favicon at `images/app-favicon.svg` at the first time, remove this line after generated  -->
    <%= favicon_link_tag asset_path("app-favicon.svg") unless Rails.env.test? %>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
  </head>
  <body class="flex flex-col min-h-screen text-foreground <%= body_class %>">
    <main class="flex-1 flex flex-col">
      <%= render 'shared/navbar' unless @full_render %>
      <%= render 'shared/flash_messages' %>
      <%= yield %>
    </main>
    <% if Rails.env.development? %>
      <div id="system-monitor-stream"
           data-controller="system-monitor"
           data-system-monitor-signed-name-value="<%= Turbo::StreamsChannel.signed_stream_name("system_monitor") %>"
           data-turbo-permanent>
      </div>
    <% end %>

    <!-- stimulus-validator: allow-script -->
      <script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/service-worker.js')
        .then(registration => console.log('ServiceWorker registered:', registration.scope))
        .catch(error => console.error('ServiceWorker registration failed:', error));
    });
  }
</script>

    <% if user_signed_in? && current_user.assistant_enabled? %>
      <%= render 'shared/assistant_bubble' %>
    <% end %>

  </body>
</html>
