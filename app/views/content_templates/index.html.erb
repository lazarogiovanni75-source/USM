<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Content Templates</h1>
    <div class="flex space-x-3">
      <%= link_to new_content_template_path, class: "btn-primary inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" do %>
        <%= lucide_icon "plus", class: "w-4 h-4 mr-2" %>
        Create Template
      <% end %>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Search</label>
        <%= form_tag content_templates_path, method: :get, class: "flex" do %>
          <%= text_field_tag :search, params[:search], class: "flex-1 rounded-l-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-white focus:border-blue-500 focus:ring-blue-500", placeholder: "Search templates..." %>
          <%= submit_tag "Search", class: "px-4 py-2 bg-blue-600 text-white rounded-r-md hover:bg-blue-700" %>
        <% end %>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Platform</label>
        <%= select_tag :platform, 
             options_for_select([['All Platforms', '']] + @platforms.map { |p| [p.capitalize, p] }, params[:platform]),
             { onchange: "this.form.submit()", class: "w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-white focus:border-blue-500 focus:ring-blue-500" } %>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Category</label>
        <%= select_tag :category, 
             options_for_select([['All Categories', '']] + @categories.map { |c| [c.humanize, c] }, params[:category]),
             { onchange: "this.form.submit()", class: "w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-white focus:border-blue-500 focus:ring-blue-500" } %>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Type</label>
        <%= select_tag :type, 
             options_for_select([['All Types', '']] + @types.map { |t| [t.humanize, t] }, params[:type]),
             { onchange: "this.form.submit()", class: "w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm text-gray-900 dark:text-white focus:border-blue-500 focus:ring-blue-500" } %>
      </div>
    </div>
  </div>

  <!-- Templates Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if @templates.any? %>
      <% @templates.each do |template| %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-md transition-shadow">
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white truncate">
                <%= template.name %>
              </h3>
              <% if template.is_featured? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/20 dark:text-yellow-400">
                  Featured
                </span>
              <% end %>
            </div>
            
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 line-clamp-2">
              <%= template.description %>
            </p>
            
            <div class="flex items-center justify-between mb-4">
              <div class="flex space-x-2">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-400">
                  <%= template.platform.capitalize %>
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-400">
                  <%= template.category.humanize %>
                </span>
              </div>
              <span class="text-xs text-gray-500 dark:text-gray-400">
                Used <%= template.usage_count %> times
              </span>
            </div>
            
            <div class="text-xs text-gray-500 dark:text-gray-400 mb-4">
              <%= template.template_type.humanize %>
            </div>
            
            <div class="flex justify-between items-center">
              <%= link_to content_template_path(template), class: "btn-secondary inline-flex items-center px-3 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors text-sm" do %>
                <%= lucide_icon "eye", class: "w-4 h-4 mr-1" %>
                Preview
              <% end %>
              
              <div class="flex space-x-2">
                <% if template.user_id == current_user.id %>
                  <%= link_to edit_content_template_path(template), class: "text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300" do %>
                    <%= lucide_icon "edit", class: "w-4 h-4" %>
                  <% end %>
                  
                  <%= link_to content_template_path(template), 
                               method: :delete, 
                               data: { turbo_confirm: 'Are you sure you want to delete this template?' },
                               class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300" do %>
                    <%= lucide_icon "trash-2", class: "w-4 h-4" %>
                  <% end %>
                <% else %>
                  <%= link_to duplicate_content_template_path(template), 
                               method: :post,
                               class: "text-green-600 hover:text-green-900 dark:text-green-400 dark:hover:text-green-300" do %>
                    <%= lucide_icon "copy", class: "w-4 h-4" %>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-span-full">
        <div class="text-center py-12">
          <%= lucide_icon "file-text", class: "w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-4" %>
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No templates found</h3>
          <p class="text-gray-500 dark:text-gray-400 mb-6">
            <% if params[:search] || params[:platform] || params[:category] %>
              Try adjusting your filters or search terms.
            <% else %>
              Get started by creating your first content template.
            <% end %>
          </p>
          <%= link_to new_content_template_path, class: "btn-primary inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" do %>
            <%= lucide_icon "plus", class: "w-4 h-4 mr-2" %>
            Create Template
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Pagination -->
  <% if @templates.respond_to?(:total_pages) && @templates.total_pages > 1 %>
    <div class="mt-8 flex justify-center">
      <%= paginate @templates %>
    </div>
  <% end %>
</div>