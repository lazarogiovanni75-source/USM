<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= @template.name %></h1>
        <div class="flex items-center space-x-4 mt-2">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-400">
            <%= @template.platform.capitalize %>
          </span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-400">
            <%= @template.category.humanize %>
          </span>
          <% if @template.is_featured? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/20 dark:text-yellow-400">
              Featured
            </span>
          <% end %>
        </div>
      </div>
      
      <div class="flex space-x-3">
        <% if @template.user_id == current_user.id %>
          <%= link_to edit_content_template_path(@template), class: "btn-secondary inline-flex items-center px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors" do %>
            <%= lucide_icon "edit", class: "w-4 h-4 mr-2" %>
            Edit Template
          <% end %>
        <% else %>
          <%= link_to duplicate_content_template_path(@template), 
                       method: :post,
                       class: "btn-primary inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors" do %>
            <%= lucide_icon "copy", class: "w-4 h-4 mr-2" %>
            Duplicate Template
          <% end %>
        <% end %>
        
        <%= link_to content_templates_path, class: "btn-secondary inline-flex items-center px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors" do %>
          <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
          Back to Templates
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Template Details -->
      <div>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
          <h2 class="text-xl font-semibold mb-4 text-gray-900 dark:text-white">Template Details</h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Description</label>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
                <%= @template.description || 'No description provided' %>
              </p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Type</label>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
                <%= @template.template_type.humanize %>
              </p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Usage Count</label>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
                <%= @template.usage_count %> times used
              </p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Created</label>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
                <%= @template.created_at.strftime('%B %d, %Y') %>
              </p>
            </div>
          </div>
        </div>

        <!-- Template Content Preview -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-xl font-semibold mb-4 text-gray-900 dark:text-white">Template Preview</h2>
          
          <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
            <pre class="whitespace-pre-wrap text-sm text-gray-800 dark:text-gray-200 font-mono"><%= @template.template_content %></pre>
          </div>
          
          <% if @template.content_template_variables.any? %>
            <div class="mt-4">
              <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Variables Used:</h3>
              <div class="flex flex-wrap gap-2">
                <% @template.content_template_variables.each do |variable| %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-400">
                    <%= variable.variable_name %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Variables Panel -->
      <div>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
          <h2 class="text-xl font-semibold mb-4 text-gray-900 dark:text-white">Template Variables</h2>
          
          <% if @template.content_template_variables.any? %>
            <div class="space-y-3">
              <% @template.content_template_variables.each do |variable| %>
                <div class="border border-gray-200 dark:border-gray-600 rounded-lg p-3">
                  <div class="flex items-center justify-between mb-2">
                    <label class="text-sm font-medium text-gray-900 dark:text-white">
                      <%= variable.variable_name.humanize %>
                    </label>
                    <span class="text-xs text-gray-500 dark:text-gray-400">
                      <%= variable.variable_type.humanize %>
                    </span>
                  </div>
                  
                  <% if variable.placeholder_text.present? %>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">
                      <%= variable.placeholder_text %>
                    </p>
                  <% end %>
                  
                  <% if variable.default_value.present? %>
                    <p class="text-xs text-gray-600 dark:text-gray-300">
                      Default: <%= variable.default_value %>
                    </p>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500 dark:text-gray-400">No variables defined for this template.</p>
          <% end %>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-xl font-semibold mb-4 text-gray-900 dark:text-white">Quick Actions</h2>
          
          <div class="space-y-3">
            <% if @template.user_id != current_user.id %>
              <%= link_to new_content_path(template_id: @template.id), 
                          class: "w-full btn-primary inline-flex items-center justify-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" do %>
                <%= lucide_icon "plus", class: "w-4 h-4 mr-2" %>
                Create Content from Template
              <% end %>
            <% end %>
            
            <%= link_to content_templates_path(category: @template.category), 
                        class: "w-full btn-secondary inline-flex items-center justify-center px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors" do %>
              <%= lucide_icon "folder", class: "w-4 h-4 mr-2" %>
              More <%= @template.category.humanize %> Templates
            <% end %>
            
            <% if @template.platform != 'general' %>
              <%= link_to content_templates_path(platform: @template.platform), 
                          class: "w-full btn-secondary inline-flex items-center justify-center px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors" do %>
                <%= lucide_icon "smartphone", class: "w-4 h-4 mr-2" %>
                More <%= @template.platform.capitalize %> Templates
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>