<% content_for :title, "Voice Command" %>

<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated">
  <div class="bg-white/80 backdrop-blur-lg border-b border-border/50 sticky top-16 z-30">
    <div class="container-xl mx-auto px-4 py-4">
      <div class="flex items-center gap-4">
        <%= link_to voice_commands_path, class: "btn-ghost" do %>
          <%= lucide_icon "arrow-left", class: "w-5 h-5" %>
        <% end %>
        <div>
          <h1 class="text-2xl font-bold text-primary">Voice Command</h1>
          <p class="text-sm text-muted"><%= @voice_command.command_type&.humanize %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="container-xl mx-auto px-4 py-6 max-w-2xl">
    <div class="space-y-6">
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-border/50">
        <h3 class="text-lg font-semibold text-primary mb-4">Command Details</h3>
        <dl class="space-y-3">
          <div>
            <dt class="text-sm font-medium text-muted">Command</dt>
            <dd class="text-primary mt-1"><%= @voice_command.transcribed_text %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-muted">Type</dt>
            <dd class="text-primary mt-1"><%= @voice_command.command_type&.humanize || "General" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-muted">Status</dt>
            <dd class="mt-1">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                <%= case @voice_command.status
                  when 'completed' then 'bg-green-100 text-green-700'
                  when 'processing' then 'bg-blue-100 text-blue-700'
                  when 'failed' then 'bg-red-100 text-red-700'
                  else 'bg-gray-100 text-gray-700'
                end %>">
                <%= @voice_command.status.humanize %>
              </span>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-muted">Created</dt>
            <dd class="text-primary mt-1"><%= @voice_command.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
          </div>
        </dl>
      </div>

      <% if @voice_command.result.present? %>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-border/50">
          <h3 class="text-lg font-semibold text-primary mb-4">Result</h3>
          <div class="bg-surface-elevated rounded-xl p-4 text-sm text-primary">
            <%= @voice_command.result %>
          </div>
        </div>
      <% end %>

      <% if @voice_command.error_message.present? %>
        <div class="bg-red-50 rounded-2xl p-6 border border-red-200">
          <h3 class="text-lg font-semibold text-red-700 mb-2">Error</h3>
          <p class="text-sm text-red-600"><%= @voice_command.error_message %></p>
        </div>
      <% end %>

      <div class="flex gap-3">
        <%= button_to "Re-run Command", execute_voice_command_path(@voice_command),
            method: :post,
            class: "btn-primary",
            data: { turbo: false } %>
        <%= link_to "Back to Commands", voice_commands_path, class: "btn-secondary" %>
      </div>
    </div>
  </div>
</div>
