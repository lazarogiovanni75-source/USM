<!-- Competitor Tracking Index -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Competitor Tracking</h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">Monitor competitors across 9 social platforms</p>
  </div>

  <!-- Search Section -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 mb-6">
    <div class="p-6 border-b border-gray-100 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Find Competitors</h2>
      <%= form_tag search_competitor_tracking_index_path, method: :get, class: 'flex gap-4' do %>
        <div class="flex-1">
          <input type="text" name="query" placeholder="Enter competitor name or handle" 
                 class="form-input w-full" required>
        </div>
        <div class="w-48">
          <select name="platform" class="form-select w-full">
            <option value="">All Platforms</option>
            <% %w[instagram facebook twitter linkedin tiktok youtube pinterest threads snapchat].each do |p| %>
              <option value="<%= p %>"><%= p.titleize %></option>
            <% end %>
          </select>
        </div>
        <button type="submit" class="btn-primary">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          Search
        </button>
      <% end %>
    </div>

    <!-- Search Results -->
    <% if @suggested_competitors.any? %>
      <div class="p-6 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-700/50">
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-4">
          Search Results for "<%= @search_query %>"<%= " on #{@search_platform.titleize}" if @search_platform %>
        </h3>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          <% @suggested_competitors.each do |competitor| %>
            <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-600 p-4">
              <div class="flex items-start justify-between">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold">
                    <%= competitor[:handle].first.upcase %>
                  </div>
                  <div>
                    <h4 class="font-medium text-gray-900 dark:text-white"><%= competitor[:display_name] %></h4>
                    <p class="text-sm text-gray-500 dark:text-gray-400">@<%= competitor[:handle] %></p>
                  </div>
                </div>
                <span class="badge bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                  <%= competitor[:platform].titleize %>
                </span>
              </div>
              <div class="mt-4 flex items-center justify-between text-sm">
                <span class="text-gray-600 dark:text-gray-400">
                  <%= number_to_human(competitor[:follower_count]) %> followers
                </span>
                <% if competitor[:is_verified] %>
                  <svg class="w-5 h-5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                <% end %>
              </div>
              <div class="mt-4">
                <% if competitor[:existing] %>
                  <span class="text-sm text-green-600 dark:text-green-400">Already tracking</span>
                <% else %>
                  <%= button_to add_competitor_tracking_index_path(
                    platform: competitor[:platform],
                    handle: competitor[:handle],
                    display_name: competitor[:display_name],
                    profile_url: competitor[:profile_url],
                    follower_count: competitor[:follower_count],
                    is_verified: competitor[:is_verified]
                  ), method: :post, class: 'btn-secondary w-full text-sm' do %>
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Track This Competitor
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Summary Stats -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
      <div class="text-3xl font-bold text-purple-600 dark:text-purple-400"><%= @total_competitors %></div>
      <div class="text-sm text-gray-500 dark:text-gray-400">Competitors Tracked</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
      <div class="text-3xl font-bold text-blue-600 dark:text-blue-400"><%= number_to_human(@total_followers) %></div>
      <div class="text-sm text-gray-500 dark:text-gray-400">Total Followers</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
      <div class="text-3xl font-bold text-green-600 dark:text-green-400"><%= number_to_percentage(@avg_engagement, precision: 1) %></div>
      <div class="text-sm text-gray-500 dark:text-gray-400">Avg Engagement</div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
      <%= button_to refresh_all_competitor_tracking_index_path, method: :post, class: 'btn-secondary w-full' do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
        </svg>
        Refresh All
      <% end %>
    </div>
  </div>

  <!-- Tracked Competitors -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
    <div class="p-6 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Your Competitors</h2>
    </div>

    <% if @competitors.any? %>
      <div class="divide-y divide-gray-100 dark:divide-gray-700">
        <% @competitors.each do |competitor| %>
          <div class="p-6 flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-700/50">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-gradient-to-br from-gray-400 to-gray-600 rounded-full flex items-center justify-center text-white font-bold text-xl">
                <%= competitor.handle.first.upcase %>
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <h3 class="font-medium text-gray-900 dark:text-white"><%= competitor.display_name %></h3>
                  <% if competitor.is_verified? %>
                    <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                  <% end %>
                </div>
                <p class="text-sm text-gray-500 dark:text-gray-400">@<%= competitor.handle %> • <%= competitor.platform.titleize %></p>
              </div>
            </div>

            <div class="flex items-center gap-8">
              <div class="text-center">
                <div class="text-lg font-semibold text-gray-900 dark:text-white"><%= number_to_human(competitor.follower_count) %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Followers</div>
              </div>
              <div class="text-center">
                <div class="text-lg font-semibold text-green-600 dark:text-green-400"><%= number_to_percentage(competitor.engagement_rate, precision: 1) %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Engagement</div>
              </div>
              <div class="text-center">
                <div class="text-lg font-semibold text-blue-600 dark:text-blue-400"><%= competitor.posts_per_day %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Posts/Day</div>
              </div>
              <div class="flex items-center gap-2">
                <%= link_to insights_competitor_tracking_path(competitor), class: 'btn-secondary btn-sm' do %>
                  View Insights
                <% end %>
                <%= button_to refresh_competitor_tracking_path(competitor), method: :post, class: 'btn-icon', title: 'Refresh' do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                  </svg>
                <% end %>
                <%= button_to competitor_tracking_path(competitor), method: :delete, class: 'btn-icon text-red-500 hover:text-red-600', title: 'Remove', data: { turbo_confirm: 'Remove this competitor?' } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No competitors tracked yet</h3>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Search for competitors above to start tracking them</p>
      </div>
    <% end %>
  </div>
</div>