<div class="page-header">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Post Analytics</h1>
      <p class="text-sm text-gray-500 mt-1">Track your post performance and engagement metrics across all platforms</p>
    </div>
    <div class="flex gap-3">
      <%= button_to sync_buffer_analytics_path, method: :post, class: "btn-primary" do %>
        <%= lucide_icon "refresh-cw", class: "w-4 h-4 mr-2" %>
        Sync All
      <% end %>
    </div>
  </div>
</div>

<% if @analytics.empty? %>
  <div class="card p-12 text-center">
    <div class="mx-auto w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mb-4">
      <%= lucide_icon "bar-chart-2", class: "w-8 h-8 text-gray-400" %>
    </div>
    <h3 class="text-lg font-medium text-gray-900 mb-2">No Analytics Data Yet</h3>
    <p class="text-gray-500 mb-6">Sync your data to see post performance metrics.</p>
    <%= button_to sync_buffer_analytics_path, method: :post, class: "btn-primary" do %>
      <%= lucide_icon "refresh-cw", class: "w-4 h-4 mr-2" %>
      Sync Now
    <% end %>
  </div>
<% else %>
  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="card p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Total Clicks</p>
          <p class="text-2xl font-bold text-gray-900"><%= @totals[:clicks] %></p>
        </div>
        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
          <%= lucide_icon "mouse-pointer", class: "w-5 h-5 text-blue-600" %>
        </div>
      </div>
    </div>

    <div class="card p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Impressions</p>
          <p class="text-2xl font-bold text-gray-900"><%= number_with_delimiter(@totals[:impressions]) %></p>
        </div>
        <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
          <%= lucide_icon "eye", class: "w-5 h-5 text-purple-600" %>
        </div>
      </div>
    </div>

    <div class="card p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Engagement</p>
          <p class="text-2xl font-bold text-gray-900"><%= @totals[:engagement] %></p>
        </div>
        <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
          <%= lucide_icon "heart", class: "w-5 h-5 text-green-600" %>
        </div>
      </div>
    </div>

    <div class="card p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Engagement Rate</p>
          <p class="text-2xl font-bold text-gray-900"><%= @engagement_rate %>%</p>
        </div>
        <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center">
          <%= lucide_icon "trending-up", class: "w-5 h-5 text-orange-600" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Platform Breakdown -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2 card">
      <div class="card-header">
        <h2 class="text-lg font-semibold">Recent Post Performance</h2>
      </div>
      <div class="card-body">
        <table class="w-full">
          <thead>
            <tr class="text-left text-sm text-gray-500 border-b">
              <th class="pb-3 font-medium">Post</th>
              <th class="pb-3 font-medium">Platform</th>
              <th class="pb-3 font-medium text-right">Clicks</th>
              <th class="pb-3 font-medium text-right">Impressions</th>
              <th class="pb-3 font-medium text-right">Engagement</th>
              <th class="pb-3 font-medium text-right">Rate</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_posts.each do |analytic| %>
              <% post = analytic.scheduled_post %>
              <% social_account = post&.social_account %>
              <tr class="border-b last:border-0">
                <td class="py-3">
                  <p class="font-medium text-gray-900 truncate max-w-xs"><%= post&.content&.title || 'Untitled' %></p>
                  <p class="text-xs text-gray-500"><%= analytic.posted_at&.strftime('%b %d, %Y') || 'N/A' %></p>
                </td>
                <td class="py-3">
                  <span class="badge badge-<%= social_account&.platform %>">
                    <%= social_account&.platform&.titleize || 'Unknown' %>
                  </span>
                </td>
                <td class="py-3 text-right font-medium"><%= analytic.clicks %></td>
                <td class="py-3 text-right"><%= number_with_delimiter(analytic.impressions) %></td>
                <td class="py-3 text-right font-medium"><%= analytic.engagement %></td>
                <td class="py-3 text-right">
                  <span class="badge badge-<%= analytic.engagement_rate > 3 ? 'success' : analytic.engagement_rate > 1 ? 'warning' : 'error' %>">
                    <%= analytic.engagement_rate %>%
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h2 class="text-lg font-semibold">Platform Breakdown</h2>
      </div>
      <div class="card-body">
        <% if @platform_stats.any? %>
          <div class="space-y-4">
            <% @platform_stats.each do |stat| %>
              <div>
                <div class="flex justify-between items-center mb-1">
                  <span class="text-sm font-medium capitalize"><%= stat.platform %></span>
                  <span class="text-sm text-gray-500"><%= stat.post_count %> posts</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2">
                  <div class="bg-primary-500 h-2 rounded-full" style="width: <%= [(stat.clicks.to_f / @totals[:clicks] * 100).round(0), 100].max %>%"></div>
                </div>
                <div class="flex justify-between text-xs text-gray-500 mt-1">
                  <span><%= stat.clicks %> clicks</span>
                  <span><%= number_with_delimiter(stat.impressions) %> impressions</span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 text-center py-4">No platform data available</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- All Posts Table -->
  <div class="card">
    <div class="card-header">
      <h2 class="text-lg font-semibold">All Post Analytics</h2>
    </div>
    <div class="card-body">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="text-left text-sm text-gray-500 border-b">
              <th class="pb-3 font-medium">Post</th>
              <th class="pb-3 font-medium">Platform</th>
              <th class="pb-3 font-medium text-right">Clicks</th>
              <th class="pb-3 font-medium text-right">Impressions</th>
              <th class="pb-3 font-medium text-right">Reach</th>
              <th class="pb-3 font-medium text-right">Likes</th>
              <th class="pb-3 font-medium text-right">Comments</th>
              <th class="pb-3 font-medium text-right">Shares</th>
              <th class="pb-3 font-medium text-right">Synced</th>
            </tr>
          </thead>
          <tbody>
            <% @analytics.each do |analytic| %>
              <% post = analytic.scheduled_post %>
              <% social_account = post&.social_account %>
              <tr class="border-b last:border-0 hover:bg-gray-50">
                <td class="py-3">
                  <p class="font-medium text-gray-900 truncate max-w-xs"><%= post&.content&.title || 'Untitled' %></p>
                </td>
                <td class="py-3">
                  <span class="badge badge-<%= social_account&.platform %>">
                    <%= social_account&.platform&.titleize || 'Unknown' %>
                  </span>
                </td>
                <td class="py-3 text-right"><%= analytic.clicks %></td>
                <td class="py-3 text-right"><%= number_with_delimiter(analytic.impressions) %></td>
                <td class="py-3 text-right"><%= number_with_delimiter(analytic.reach) %></td>
                <td class="py-3 text-right"><%= analytic.likes %></td>
                <td class="py-3 text-right"><%= analytic.comments %></td>
                <td class="py-3 text-right"><%= analytic.shares %></td>
                <td class="py-3 text-right text-gray-500 text-sm">
                  <%= analytic.synced_at&.strftime('%m/%d %H:%M') || 'N/A' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="mt-4">
        <%= paginate @analytics %>
      </div>
    </div>
  </div>
<% end %>
