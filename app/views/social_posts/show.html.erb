<div class="container-lg">
  <div class="page-header">
    <div class="flex items-center gap-4">
      <%= link_to social_posts_path, class: "btn btn-ghost btn-sm" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4" %>
      <% end %>
      <h1 class="page-title">Post Details</h1>
    </div>
  </div>

  <% if @error %>
    <div class="alert alert-danger">
      <%= lucide_icon "alert-circle", class: "w-5 h-5 mr-2" %>
      <%= @error %>
    </div>
  <% elsif @post %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2">
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Post Content</h2>
            <div class="flex items-center gap-2">
              <% if @post['published'] == true %>
                <span class="badge badge-success">Published</span>
              <% elsif @post['scheduled_at'].present? %>
                <span class="badge badge-warning">Scheduled</span>
              <% else %>
                <span class="badge badge-neutral">Draft</span>
              <% end %>
            </div>
          </div>
          <div class="card-body">
            <div class="prose max-w-none">
              <p><%= @post['caption'] || '-' %></p>
            </div>

            <% if @post['media'].present? %>
              <div class="mt-4">
                <h3 class="text-sm font-medium mb-2">Media</h3>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
                  <% Array(@post['media']).each do |media| %>
                    <div class="aspect-square bg-surface-elevated rounded-lg overflow-hidden">
                      <% if media['url'] =~ /\.(jpg|jpeg|png|gif|webp)$/i %>
                        <img src="<%= media['url'] %>" alt="Media" class="w-full h-full object-cover">
                      <% elsif media['url'] =~ /\.(mp4|webm|mov)$/i %>
                        <video src="<%= media['url'] %>" class="w-full h-full object-cover" controls></video>
                      <% else %>
                        <div class="flex items-center justify-center h-full">
                          <%= lucide_icon "file", class: "w-8 h-8 text-muted" %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div class="card mt-6">
          <div class="card-header">
            <h2 class="card-title">Accounts</h2>
          </div>
          <div class="card-body">
            <% if @post['accounts'].present? %>
              <div class="space-y-3">
                <% Array(@post['accounts']).each do |account| %>
                  <div class="flex items-center justify-between p-3 border rounded-lg">
                    <div class="flex items-center gap-3">
                      <% platform_icon = case account['platform']&.downcase
                                          when 'instagram' then 'instagram'
                                          when 'facebook' then 'facebook'
                                          when 'twitter', 'x' then 'twitter'
                                          when 'linkedin' then 'linkedin'
                                          when 'tiktok' then 'video'
                                          else 'share-2'
                                          end %>
                      <%= lucide_icon platform_icon, class: "w-5 h-5 text-muted" %>
                      <div>
                        <p class="font-medium"><%= account['name'] || account['username'] || 'Unknown' %></p>
                        <p class="text-sm text-muted"><%= account['platform']&.titleize || 'Unknown' %></p>
                      </div>
                    </div>
                    <% if account['status'].present? %>
                      <span class="badge badge-<%= account['status'] == 'published' ? 'success' : 'warning' %>">
                        <%= account['status'].titleize %>
                      </span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted">No accounts linked to this post.</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="lg:col-span-1">
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Post Info</h2>
          </div>
          <div class="card-body">
            <dl class="space-y-4">
              <% if @post['scheduled_at'].present? %>
                <div>
                  <dt class="text-sm text-muted">Scheduled For</dt>
                  <dd class="font-medium"><%= Time.parse(@post['scheduled_at']).strftime("%b %d, %Y %H:%M") rescue @post['scheduled_at'] %></dd>
                </div>
              <% end %>
              <% if @post['created_at'].present? %>
                <div>
                  <dt class="text-sm text-muted">Created</dt>
                  <dd class="font-medium"><%= Time.parse(@post['created_at']).strftime("%b %d, %Y %H:%M") rescue '-' %></dd>
                </div>
              <% end %>
              <% if @post['updated_at'].present? %>
                <div>
                  <dt class="text-sm text-muted">Updated</dt>
                  <dd class="font-medium"><%= Time.parse(@post['updated_at']).strftime("%b %d, %Y %H:%M") rescue '-' %></dd>
                </div>
              <% end %>
            </dl>
          </div>
        </div>

        <div class="card mt-4">
          <div class="card-header">
            <h2 class="card-title">Actions</h2>
          </div>
          <div class="card-body">
            <div class="space-y-2">
              <% if @post['scheduled_at'].present? && !@post['published'] %>
                <%= button_to share_now_social_post_path(params[:id]), 
                              method: :post,
                              class: "btn btn-primary w-full" do %>
                  <%= lucide_icon "send", class: "w-4 h-4 mr-2" %>
                  Share Now
                <% end %>
              <% end %>
              <%= link_to preview_social_post_path(params[:id]), class: "btn btn-secondary w-full" do %>
                <%= lucide_icon "eye", class: "w-4 h-4 mr-2" %>
                Preview
              <% end %>
              <%= link_to results_social_post_path(params[:id]), class: "btn btn-secondary w-full" do %>
                <%= lucide_icon "bar-chart-2", class: "w-4 h-4 mr-2" %>
                View Results
              <% end %>
              <%= button_to social_post_path(params[:id]), 
                            method: :delete,
                            class: "btn btn-danger w-full",
                            data: { confirm: "Are you sure you want to delete this post?" } do %>
                <%= lucide_icon "trash-2", class: "w-4 h-4 mr-2" %>
                Delete Post
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="alert alert-warning">
      <%= lucide_icon "alert-triangle", class: "w-5 h-5 mr-2" %>
      Post not found.
    </div>
  <% end %>
</div>
