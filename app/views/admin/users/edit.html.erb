<!-- Admin User Management - Role Assignment -->
<div class="min-h-screen bg-gray-50">
  <!-- Header Section -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">User Management</h1>
          <p class="mt-1 text-gray-600">Manage user roles and permissions</p>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to "Back to Users", admin_users_path, class: "px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- User Information Card -->
    <div class="bg-white rounded-xl shadow-sm p-6 mb-8 border border-gray-100">
      <h2 class="text-xl font-semibold text-gray-900 mb-6">User Information</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700">Name</label>
          <p class="mt-1 text-lg text-gray-900"><%= @user.name || 'N/A' %></p>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Email</label>
          <p class="mt-1 text-lg text-gray-900"><%= @user.email %></p>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Current Role</label>
          <div class="mt-1">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
              <% case @user.role %>
              <% when 'admin' %>
                bg-purple-100 text-purple-800
              <% when 'moderator' %>
                bg-blue-100 text-blue-800
              <% when 'premium' %>
                bg-green-100 text-green-800
              <% else %>
                bg-gray-100 text-gray-800
              <% end %>">
              <%= @user.role&.humanize || 'User' %>
            </span>
          </div>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Subscription Plan</label>
          <div class="mt-1">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
              <% case @user.subscription_plan %>
              <% when 'enterprise' %>
                bg-indigo-100 text-indigo-800
              <% when 'premium' %>
                bg-yellow-100 text-yellow-800
              <% when 'basic' %>
                bg-green-100 text-green-800
              <% else %>
                bg-gray-100 text-gray-800
              <% end %>">
              <%= @user.subscription_plan&.humanize || 'Free' %>
            </span>
          </div>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Member Since</label>
          <p class="mt-1 text-lg text-gray-900"><%= @user.created_at.strftime('%B %d, %Y') %></p>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700">Last Active</label>
          <p class="mt-1 text-lg text-gray-900"><%= @user.updated_at.strftime('%B %d, %Y') %></p>
        </div>
      </div>
    </div>

    <!-- Role Assignment Form -->
    <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
      <h2 class="text-xl font-semibold text-gray-900 mb-6">Role & Permission Management</h2>
      
      <%= form_with model: [:admin, @user], local: true, class: "space-y-6" do |form| %>
        
        <!-- Role Selection -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">User Role</label>
          <%= form.select :role, 
              options_for_select(User::ROLES.map { |role| [role.humanize, role] }, @user.role),
              { include_blank: 'Select Role' },
              { class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" } %>
          <p class="mt-1 text-sm text-gray-500">
            Define user's access level and permissions within the platform.
          </p>
        </div>

        <!-- Subscription Plan Selection -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Subscription Plan</label>
          <%= form.select :subscription_plan, 
              options_for_select(User::SUBSCRIPTION_PLANS.map { |plan| [plan.humanize, plan] }, @user.subscription_plan),
              { include_blank: 'Select Plan' },
              { class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" } %>
          <p class="mt-1 text-sm text-gray-500">
            Determine which features and limits apply to this user.
          </p>
        </div>

        <!-- Feature Access Preview -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-3">Current Access Permissions</label>
          <div class="grid grid-cols-2 gap-4">
            <div class="flex items-center">
              <div class="w-5 h-5 rounded-full flex items-center justify-center mr-3
                <%= @user.can_access_feature?('ai_advanced') ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-400' %>">
                <% if @user.can_access_feature?('ai_advanced') %>
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                <% else %>
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                  </svg>
                <% end %>
              </div>
              <span class="text-sm text-gray-700">Advanced AI Features</span>
            </div>
            
            <div class="flex items-center">
              <div class="w-5 h-5 rounded-full flex items-center justify-center mr-3
                <%= @user.can_access_feature?('voice_premium') ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-400' %>">
                <% if @user.can_access_feature?('voice_premium') %>
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                <% else %>
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                  </svg>
                <% end %>
              </div>
              <span class="text-sm text-gray-700">Premium Voice Features</span>
            </div>
            
            <div class="flex items-center">
              <div class="w-5 h-5 rounded-full flex items-center justify-center mr-3
                <%= @user.can_access_feature?('analytics_advanced') ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-400' %>">
                <% if @user.can_access_feature?('analytics_advanced') %>
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                <% else %>
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                  </svg>
                <% end %>
              </div>
              <span class="text-sm text-gray-700">Advanced Analytics</span>
            </div>
            
            <div class="flex items-center">
              <div class="w-5 h-5 rounded-full flex items-center justify-center mr-3
                <%= @user.can_manage_automation? ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-400' %>">
                <% if @user.can_manage_automation? %>
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                <% else %>
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                  </svg>
                <% end %>
              </div>
              <span class="text-sm text-gray-700">Automation Management</span>
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex justify-end space-x-4 pt-6 border-t border-gray-200">
          <%= link_to "Cancel", admin_users_path, 
              class: "px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors" %>
          <%= form.submit "Update User", 
              class: "px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>