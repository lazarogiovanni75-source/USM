<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Publish Queue</h1>
    <div class="flex space-x-3">
      <%= link_to new_publish_queue_path, class: "btn-primary inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" do %>
        <%= lucide_icon "plus", class: "w-4 h-4 mr-2" %>
        Add to Queue
      <% end %>
      
      <%= button_to process_publish_queues_path, method: :post, class: "btn-secondary inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors" do %>
        <%= lucide_icon "play", class: "w-4 h-4 mr-2" %>
        Process Queue
      <% end %>
      
      <%= button_to clear_completed_publish_queues_path, method: :delete, class: "btn-secondary inline-flex items-center px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors", data: { turbo_confirm: "Are you sure you want to clear all completed items?" } do %>
        <%= lucide_icon "trash-2", class: "w-4 h-4 mr-2" %>
        Clear Completed
      <% end %>
    </div>
  </div>

  <!-- Queue Status Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
      <div class="flex items-center">
        <div class="p-2 bg-blue-100 dark:bg-blue-900/20 rounded-lg">
          <%= lucide_icon "clock", class: "w-6 h-6 text-blue-600 dark:text-blue-400" %>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Queue</p>
          <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @queue_status[:total] %></p>
        </div>
      </div>
    </div>
    
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
      <div class="flex items-center">
        <div class="p-2 bg-yellow-100 dark:bg-yellow-900/20 rounded-lg">
          <%= lucide_icon "hourglass", class: "w-6 h-6 text-yellow-600 dark:text-yellow-400" %>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Pending</p>
          <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @queue_status[:pending] %></p>
        </div>
      </div>
    </div>
    
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
      <div class="flex items-center">
        <div class="p-2 bg-green-100 dark:bg-green-900/20 rounded-lg">
          <%= lucide_icon "check-circle", class: "w-6 h-6 text-green-600 dark:text-green-400" %>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Published</p>
          <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @queue_status[:published] %></p>
        </div>
      </div>
    </div>
    
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
      <div class="flex items-center">
        <div class="p-2 bg-red-100 dark:bg-red-900/20 rounded-lg">
          <%= lucide_icon "x-circle", class: "w-6 h-6 text-red-600 dark:text-red-400" %>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Failed</p>
          <p class="text-2xl font-semibold text-gray-900 dark:text-white"><%= @queue_status[:failed] %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Queue Items Table -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold">Queue Items</h2>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Content
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Platform
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Scheduled
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Status
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Priority
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
          <% if @publish_queues.any? %>
            <% @publish_queues.each do |queue_item| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900 dark:text-white">
                        <%= queue_item.content_data&.dig('title') || 'Untitled' %>
                      </div>
                      <div class="text-sm text-gray-500 dark:text-gray-400 truncate max-w-xs">
                        <%= queue_item.content_data&.dig('body') %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-400">
                    <%= queue_item.platform&.capitalize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                  <%= queue_item.scheduled_at.strftime('%Y-%m-%d %H:%M') %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= render 'publish_queues/status_badge', queue_item: queue_item %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= render 'publish_queues/priority_badge', priority: queue_item.priority %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-2">
                    <% if queue_item.status.in?([:pending, :retrying]) %>
                      <%= button_to cancel_item_publish_queue_path(queue_item), method: :post, class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300", data: { turbo_confirm: "Are you sure you want to cancel this queue item?" } do %>
                        <%= lucide_icon "x", class: "w-4 h-4" %>
                      <% end %>
                    <% end %>
                    
                    <% if queue_item.status == :failed %>
                      <%= button_to retry_item_publish_queue_path(queue_item), method: :post, class: "text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300" do %>
                        <%= lucide_icon "rotate-cw", class: "w-4 h-4" %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                <div class="flex flex-col items-center">
                  <%= lucide_icon "inbox", class: "w-12 h-12 mb-4 text-gray-300 dark:text-gray-600" %>
                  <p class="text-lg font-medium">No queue items</p>
                  <p class="text-sm">Start by adding content to your publishing queue</p>
                  <%= link_to "Add First Item", new_publish_queue_path, class: "mt-4 btn-primary inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>