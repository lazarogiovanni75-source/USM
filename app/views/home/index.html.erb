        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          Ultimate Social Media
          <span class="block text-3xl sm:text-4xl lg:text-5xl text-white/90 mt-2">
            Enterprise AI Marketing Platform
          </span>
        </h1>
        <p class="text-xl sm:text-2xl text-white/80 mb-8 max-w-2xl">
          The next-generation social media management platform combining voice-activated AI, automated content creation, and predictive analytics. Trusted by forward-thinking brands to scale their digital presence.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <%= link_to "Start Free Trial", sign_up_path, class: "bg-white text-purple-600 hover:bg-gray-100 font-semibold px-8 py-4 rounded-xl shadow-xl text-center" %>
          <%= link_to "Sign In", sign_in_path, class: "border-2 border-white text-white hover:bg-white hover:text-purple-600 font-semibold px-8 py-4 rounded-xl text-center" %>
        </div>
        <div class="mt-8 flex items-center justify-center lg:justify-start space-x-6 text-white/70">
          <div class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>30 day money back guarantee</span>
          </div>
        </div>
      </div>
      
      <!-- Hero Image -->
      <div class="relative">
        <div class="bg-white/10 backdrop-blur-sm rounded-3xl p-8 shadow-2xl">
          <img src="https://images.unsplash.com/photo-1611224923853-80b023f02d71?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80" 
