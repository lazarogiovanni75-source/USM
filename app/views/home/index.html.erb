            <div class="flex items-center space-x-2">
              <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
              <span class="text-sm font-medium text-gray-800">AI Active</span>
            </div>
          </div>
          <div class="absolute -bottom-4 -left-4 bg-white rounded-xl p-4 shadow-xl">
            <div class="text-sm text-gray-600">
              <div class="font-semibold text-gray-800">Campaign Generated</div>
              <div>3 posts • 2 videos • 1 story</div>
            </div>
          </div>
        </div>
      </div>
    </div>
