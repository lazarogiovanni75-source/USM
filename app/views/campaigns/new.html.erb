<% content_for :title, "Create Campaign" %>

<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated">
  <!-- Header -->
  <div class="bg-white/80 backdrop-blur-lg border-b border-border/50 sticky top-16 z-30">
    <div class="container-xl mx-auto px-4 py-4">
      <div class="flex items-center gap-4">
        <%= link_to campaigns_path, class: "w-10 h-10 rounded-xl bg-white shadow-sm flex items-center justify-center hover:shadow-md transition-shadow" do %>
          <%= lucide_icon "arrow-left", class: "w-5 h-5 text-primary" %>
        <% end %>
        <div>
          <h1 class="text-2xl font-bold text-primary">Create Campaign</h1>
          <p class="text-sm text-muted">Create a new marketing campaign with AI assistance</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="container-xl mx-auto px-4 py-6">
    <div class="max-w-4xl mx-auto">
      <div data-controller="campaign-workflow">
        <%= form_with model: @campaign, url: campaigns_path, class: "space-y-6" do |f| %>
        
        <!-- AI Workflow Section - NEW -->
        <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl border border-green-200/50 p-6">
          <h2 class="text-lg font-bold text-primary mb-1 flex items-center gap-2">
            <%= lucide_icon "sparkles", class: "w-5 h-5 text-green-600" %>
            AI Campaign Wizard
          </h2>
          <p class="text-sm text-muted mb-4">Describe your campaign and let AI create content, images, and schedule posts automatically.</p>
          
          <!-- AI Prompt Input -->
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-900 mb-1">What do you want to create?</label>
              <textarea 
                name="ai_prompt" 
                class="form-textarea w-full" 
                rows="3" 
                placeholder="e.g., Create a summer sale campaign for my fashion brand. Post about new arrivals, special discounts, and customer testimonials."
                data-campaign-workflow-target="prompt"
              ></textarea>
            </div>
            
            <!-- AI Options -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <!-- Generate Image -->
              <label class="flex items-center gap-3 p-4 bg-white rounded-xl border border-border/50 hover:border-green-300 cursor-pointer transition-colors">
                <input type="checkbox" name="generate_image" value="1" class="rounded border-border text-green-600 focus:ring-green-500" data-campaign-workflow-target="generateImage">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center">
                    <%= lucide_icon "image", class: "w-4 h-4 text-white" %>
                  </div>
                  <span class="text-sm font-medium text-gray-900">Generate Image</span>
                </div>
              </label>
              
              <!-- Generate Video -->
              <label class="flex items-center gap-3 p-4 bg-white rounded-xl border border-border/50 hover:border-green-300 cursor-pointer transition-colors">
                <input type="checkbox" name="generate_video" value="1" class="rounded border-border text-green-600 focus:ring-green-500" data-campaign-workflow-target="generateVideo">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-red-500 to-rose-500 flex items-center justify-center">
                    <%= lucide_icon "video", class: "w-4 h-4 text-white" %>
                  </div>
                  <span class="text-sm font-medium text-gray-900">Generate Video</span>
                </div>
              </label>
              
              <!-- Auto-Post Now -->
              <label class="flex items-center gap-3 p-4 bg-white rounded-xl border border-border/50 hover:border-green-300 cursor-pointer transition-colors">
                <input type="checkbox" name="post_now" value="1" class="rounded border-border text-green-600 focus:ring-green-500" data-campaign-workflow-target="postNow" data-action="change->campaign-workflow#toggleScheduleOptions">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center">
                    <%= lucide_icon "send", class: "w-4 h-4 text-white" %>
                  </div>
                  <span class="text-sm font-medium text-gray-900">Post Immediately</span>
                </div>
              </label>
            </div>
            
            <!-- Schedule Option (shown when not posting now) -->
            <div data-campaign-workflow-target="scheduleOptions" class="hidden">
              <label class="block text-sm font-medium text-gray-900 mb-1">Schedule for later (optional)</label>
              <input type="datetime-local" name="scheduled_at" class="form-input w-full" data-campaign-workflow-target="scheduledAt">
            </div>
            
            <!-- Social Accounts -->
            <div>
              <label class="block text-sm font-medium text-gray-900 mb-1">Post to social accounts (optional)</label>
              <% if @social_accounts.any? %>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                  <% @social_accounts.each do |account| %>
                    <label class="flex items-center gap-2 p-2 bg-white rounded-lg border border-border/50 hover:border-green-300 cursor-pointer">
                      <input type="checkbox" name="social_account_ids[]" value="<%= account.id %>" class="rounded border-border text-green-600 focus:ring-green-500">
                      <span class="text-xs font-medium text-gray-900 truncate"><%= account.platform.titleize %> - <%= account.username %></span>
                    </label>
                  <% end %>
                </div>
              <% else %>
                <p class="text-sm text-muted">No social accounts connected. <%= link_to "Connect accounts", social_account_connections_path, class: "text-green-600 hover:underline" %></p>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Basic Info -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h2 class="text-lg font-bold text-primary mb-4 flex items-center gap-2">
            <%= lucide_icon "info", class: "w-5 h-5 text-primary" %>
            Basic Information
          </h2>
          <div class="space-y-4">
            <div>
              <%= f.label :name, class: "block text-sm font-medium text-gray-900 mb-1" %>
              <%= f.text_field :name, class: "form-input w-full", placeholder: "Enter campaign name" %>
            </div>
            <div>
              <%= f.label :description, class: "block text-sm font-medium text-gray-900 mb-1" %>
              <%= f.text_area :description, class: "form-textarea w-full", rows: 3, placeholder: "Describe your campaign" %>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= f.label :status, class: "block text-sm font-medium text-gray-900 mb-1" %>
                <%= f.select :status, Campaign.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "form-select w-full" %>
              </div>
              <div>
                <%= f.label :campaign_type, class: "block text-sm font-medium text-gray-900 mb-1" %>
                <%= f.select :campaign_type, Campaign.campaign_types.keys.map { |s| [s.titleize, s] }, {}, class: "form-select w-full" %>
              </div>
            </div>
          </div>
        </div>

        <!-- Goals -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h2 class="text-lg font-bold text-primary mb-4 flex items-center gap-2">
            <%= lucide_icon "target", class: "w-5 h-5 text-primary" %>
            Goals
          </h2>
          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= f.label :goal, class: "block text-sm font-medium text-gray-900 mb-1" %>
                <%= f.select :goal, Campaign.goals.keys.map { |s| [s.titleize, s] }, {}, class: "form-select w-full" %>
              </div>
              <div>
                <%= f.label :goal_value, class: "block text-sm font-medium text-gray-900 mb-1" %>
                <%= f.number_field :goal_value, class: "form-input w-full", placeholder: "Target value" %>
              </div>
            </div>
            <div>
              <%= f.label :target_audience, class: "block text-sm font-medium text-gray-900 mb-1" %>
              <%= f.text_area :target_audience, class: "form-textarea w-full", rows: 2, placeholder: "Describe your target audience" %>
            </div>
          </div>
        </div>

        <!-- Timeline & Budget -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h2 class="text-lg font-bold text-primary mb-4 flex items-center gap-2">
            <%= lucide_icon "calendar", class: "w-5 h-5 text-primary" %>
            Timeline & Budget
          </h2>
          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= f.label :start_date, class: "block text-sm font-medium text-gray-900 mb-1" %>
                <%= f.date_field :start_date, class: "form-input w-full" %>
              </div>
              <div>
                <%= f.label :end_date, class: "block text-sm font-medium text-gray-900 mb-1" %>
                <%= f.date_field :end_date, class: "form-input w-full" %>
              </div>
            </div>
            <div>
              <%= f.label :budget, class: "block text-sm font-medium text-gray-900 mb-1" %>
              <%= f.number_field :budget, class: "form-input w-full", step: 0.01, placeholder: "Campaign budget" %>
            </div>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <%= f.label :content_count, class: "block text-sm font-medium text-gray-900 mb-1" %>
                <%= f.number_field :content_count, class: "form-input w-full", placeholder: "Content pieces" %>
              </div>
              <div>
                <%= f.label :video_count, "Videos (10s)", class: "block text-sm font-medium text-gray-900 mb-1" %>
                <%= f.number_field :video_count, class: "form-input w-full", placeholder: "2" %>
                <p class="text-xs text-muted mt-1">10-second videos</p>
              </div>
              <div>
                <%= f.label :image_count, class: "block text-sm font-medium text-gray-900 mb-1" %>
                <%= f.number_field :image_count, class: "form-input w-full", placeholder: "3" %>
              </div>
            </div>
          </div>
        </div>

        <!-- Platforms -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h2 class="text-lg font-bold text-primary mb-4 flex items-center gap-2">
            <%= lucide_icon "share-2", class: "w-5 h-5 text-primary" %>
            Platforms
          </h2>
          <div class="grid grid-cols-3 gap-3">
            <% ['twitter', 'facebook', 'instagram', 'linkedin', 'tiktok', 'youtube'].each do |platform| %>
              <label class="flex items-center gap-2 p-3 rounded-xl border border-border/50 hover:bg-surface-elevated cursor-pointer transition-colors">
                <%= f.check_box :platforms, { multiple: true, class: "rounded border-border text-primary focus:ring-primary" }, platform, false %>
                <span class="text-sm font-medium text-gray-900 capitalize"><%= platform %></span>
              </label>
            <% end %>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center justify-end gap-3">
          <%= link_to "Cancel", campaigns_path, class: "btn-secondary" %>
          <button type="submit" name="create_with_ai" value="1" class="btn-primary flex items-center gap-2">
            <%= lucide_icon "sparkles", class: "w-4 h-4" %>
            Create with AI
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
