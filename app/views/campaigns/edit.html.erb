<!-- Campaign Edit -->
<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Edit Campaign</h1>
          <p class="mt-1 text-gray-600">Update campaign information</p>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to "View Campaign", campaign_path(@campaign), class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium" %>
          <%= link_to "Back to Campaigns", campaigns_path, class: "bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="p-6">
        <p class="text-gray-600">Campaign edit form will be here.</p>
      </div>
    </div>
  </div>
</div>