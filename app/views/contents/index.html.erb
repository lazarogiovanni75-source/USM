<!-- Content Review & Approval Interface -->
<div class="min-h-screen bg-gray-50" data-controller="content-index">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Content Review & Approval</h1>
          <p class="mt-1 text-gray-600">Review and approve content before scheduling</p>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to "New Content", new_content_path, class: "bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium flex items-center space-x-2" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Tabs Navigation -->
    <div class="border-b border-gray-200 mb-8">
      <nav class="-mb-px flex space-x-8">
        <button data-content-index-target="tabButton" data-tab="pending" class="tab-button active whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
          Pending Review
          <span class="ml-2 py-0.5 px-2 rounded-full text-xs bg-yellow-100 text-yellow-800">
            <%= @pending_contents.count %>
          </span>
        </button>
        <button data-content-index-target="tabButton" data-tab="approved" class="tab-button whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300">
          Approved
          <span class="ml-2 py-0.5 px-2 rounded-full text-xs bg-green-100 text-green-800">
            <%= @approved_contents.count %>
          </span>
        </button>
        <button data-content-index-target="tabButton" data-tab="rejected" class="tab-button whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300">
          Rejected
          <span class="ml-2 py-0.5 px-2 rounded-full text-xs bg-red-100 text-red-800">
            <%= @rejected_contents.count %>
          </span>
        </button>
      </nav>
    </div>

    <!-- Pending Content Tab -->
    <div id="pending-tab" class="tab-content" data-content-index-target="tabContent">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="p-6 border-b border-gray-100">
          <div class="flex items-center justify-between">
            <h2 class="text-lg font-semibold text-gray-900">Content Awaiting Review</h2>
            <div class="flex items-center space-x-4">
              <button data-content-index-target="bulkApprove" class="bg-green-600 hover:bg-green-700 text-white px-3 py-1.5 rounded-md text-sm font-medium">
                Approve Selected
              </button>
              <button data-content-index-target="bulkReject" class="bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded-md text-sm font-medium">
                Reject Selected
              </button>
            </div>
          </div>
        </div>
        <div class="divide-y divide-gray-200">
          <% if @pending_contents.any? %>
            <% @pending_contents.each do |content| %>
              <div class="p-6 hover:bg-gray-50">
                <div class="flex items-start space-x-4">
                  <input type="checkbox" class="content-checkbox mt-1" data-content-id="<%= content.id %>" data-content-index-target="contentCheckbox">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                      <div class="flex-1">
                        <h3 class="text-lg font-medium text-gray-900">
                          <%= link_to content.title, content, class: "hover:text-purple-600" %>
                        </h3>
                        <div class="mt-2 flex items-center space-x-4 text-sm text-gray-500">
                          <span>Campaign: <%= content.campaign&.name || 'No Campaign' %></span>
                          <span>•</span>
                          <span><%= content.content_type %></span>
                          <span>•</span>
                          <span><%= time_ago_in_words(content.created_at) %> ago</span>
                        </div>
                        <p class="mt-2 text-gray-600 text-sm">
                          <%= content.body&.truncate(200) %>
                        </p>
                      </div>
                      <div class="flex items-center space-x-2">
                        <%= link_to "Preview", preview_content_path(content, platform: 'instagram'), 
                                    class: "text-purple-600 hover:text-purple-800 text-sm font-medium" %>
                        <%= link_to "Edit", edit_content_path(content), 
                                    class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
                        <div class="flex space-x-2">
                          <%= button_to "Approve", approve_content_path(content), 
                                        method: :post, 
                                        class: "bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded text-sm" %>
                          <%= button_to "Reject", reject_content_path(content), 
                                        method: :post, 
                                        class: "bg-red-600 hover:bg-red-700 text-white px-3 py-1 rounded text-sm" %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="p-12 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No pending content</h3>
              <p class="mt-1 text-sm text-gray-500">All content has been reviewed or there's no content awaiting approval.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Approved Content Tab -->
    <div id="approved-tab" class="tab-content hidden" data-content-index-target="tabContent">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="p-6 border-b border-gray-100">
          <h2 class="text-lg font-semibold text-gray-900">Approved Content</h2>
        </div>
        <div class="divide-y divide-gray-200">
          <% if @approved_contents.any? %>
            <% @approved_contents.each do |content| %>
              <div class="p-6 hover:bg-gray-50">
                <div class="flex items-start space-x-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                      <div class="flex-1">
                        <h3 class="text-lg font-medium text-gray-900">
                          <%= link_to content.title, content, class: "hover:text-purple-600" %>
                        </h3>
                        <div class="mt-2 flex items-center space-x-4 text-sm text-gray-500">
                          <span>Campaign: <%= content.campaign&.name || 'No Campaign' %></span>
                          <span>•</span>
                          <span><%= content.content_type %></span>
                          <span>•</span>
                          <span>Approved <%= time_ago_in_words(content.approved_at) %> ago</span>
                        </div>
                        <p class="mt-2 text-gray-600 text-sm">
                          <%= content.body&.truncate(200) %>
                        </p>
                      </div>
                      <div class="flex items-center space-x-2">
                        <span class="px-2 py-1 text-xs bg-green-100 text-green-800 rounded-full">Approved</span>
                        <%= link_to "Preview", preview_content_path(content, platform: 'instagram'), 
                                    class: "text-purple-600 hover:text-purple-800 text-sm font-medium" %>
                        <%= link_to "Duplicate", duplicate_content_path(content), 
                                    method: :post,
                                    class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="p-12 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No approved content</h3>
              <p class="mt-1 text-sm text-gray-500">Content will appear here once approved.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Rejected Content Tab -->
    <div id="rejected-tab" class="tab-content hidden" data-content-index-target="tabContent">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="p-6 border-b border-gray-100">
          <h2 class="text-lg font-semibold text-gray-900">Rejected Content</h2>
        </div>
        <div class="divide-y divide-gray-200">
          <% if @rejected_contents.any? %>
            <% @rejected_contents.each do |content| %>
              <div class="p-6 hover:bg-gray-50">
                <div class="flex items-start space-x-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                      <div class="flex-1">
                        <h3 class="text-lg font-medium text-gray-900">
                          <%= link_to content.title, content, class: "hover:text-purple-600" %>
                        </h3>
                        <div class="mt-2 flex items-center space-x-4 text-sm text-gray-500">
                          <span>Campaign: <%= content.campaign&.name || 'No Campaign' %></span>
                          <span>•</span>
                          <span><%= content.content_type %></span>
                          <span>•</span>
                          <span>Rejected <%= time_ago_in_words(content.rejected_at) %> ago</span>
                        </div>
                        <p class="mt-2 text-gray-600 text-sm">
                          <%= content.body&.truncate(200) %>
                        </p>
                      </div>
                      <div class="flex items-center space-x-2">
                        <span class="px-2 py-1 text-xs bg-red-100 text-red-800 rounded-full">Rejected</span>
                        <%= link_to "Edit", edit_content_path(content), 
                                    class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
                        <%= link_to "Duplicate", duplicate_content_path(content), 
                                    method: :post,
                                    class: "text-purple-600 hover:text-purple-800 text-sm font-medium" %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="p-12 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No rejected content</h3>
              <p class="mt-1 text-sm text-gray-500">Rejected content will appear here.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>