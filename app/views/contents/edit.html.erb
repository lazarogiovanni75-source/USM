<!-- Content Edit Form -->
<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Edit Content</h1>
          <p class="mt-1 text-gray-600">Update your content details</p>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to "View Content", content_path(@content), class: "bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium" %>
          <%= link_to "Back to Content", contents_path, class: "bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Main Form -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6 border-b border-gray-100">
            <h2 class="text-xl font-semibold text-gray-900">Edit Content</h2>
          </div>
          
          <div class="p-6">
            <%= form_with model: @content, local: true do |form| %>
              <div class="space-y-6">
                
                <!-- Title -->
                <div>
                  <%= form.label :title, "Content Title", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.text_field :title, 
                       class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent",
                       placeholder: "Enter a compelling title for your content..." %>
                </div>

                <!-- Body -->
                <div>
                  <%= form.label :body, "Content Body", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.text_area :body, 
                       rows: 8,
                       class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent",
                       placeholder: "Write your content here..." %>
                </div>

                <!-- Campaign Selection -->
                <div>
                  <%= form.label :campaign_id, "Campaign", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.select :campaign_id, 
                       options_from_collection_for_select(current_user&.campaigns, :id, :name, @content.campaign_id),
                       { include_blank: "Select a campaign..." },
                       class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
                </div>

                <!-- Content Type and Platform -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <%= form.label :content_type, "Content Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
                    <%= form.select :content_type, 
                         options_for_select([
                           ['Post', 'post'],
                           ['Story', 'story'],
                           ['Video', 'video'],
                           ['Image', 'image'],
                           ['Link', 'link']
                         ], @content.content_type),
                         class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
                  </div>

                  <div>
                    <%= form.label :platform, "Platform", class: "block text-sm font-medium text-gray-700 mb-2" %>
                    <%= form.select :platform, 
                         options_for_select([
                           ['Instagram', 'instagram'],
                           ['Twitter', 'twitter'],
                           ['LinkedIn', 'linkedin'],
                           ['Facebook', 'facebook'],
                           ['TikTok', 'tiktok'],
                           ['Multiple', 'general']
                         ], @content.platform),
                         class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
                  </div>
                </div>

                <!-- Form Actions -->
                <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-200">
                  <%= link_to "Cancel", content_path(@content), class: "bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-lg font-medium" %>
                  <%= form.submit "Update Content", 
                       class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        
        <!-- Content Actions -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Actions</h3>
            <div class="space-y-3">
              <% if @content.status == 'draft' %>
                <button type="button" class="w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium">
                  Approve Content
                </button>
                <button type="button" class="w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium">
                  Reject Content
                </button>
              <% end %>
              
              <button type="button" class="w-full bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium">
                Generate Variation
              </button>
              
              <%= link_to "Preview Content", preview_content_path(@content), class: "w-full bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium text-center block" %>
            </div>
          </div>
        </div>

        <!-- Content Stats -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Content Stats</h3>
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Word Count</span>
                <span class="text-sm font-medium"><%= @content.body.split(' ').count %></span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Character Count</span>
                <span class="text-sm font-medium"><%= @content.body.length %></span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Status</span>
                <span class="text-xs font-medium bg-blue-100 text-blue-800 px-2 py-1 rounded-full capitalize">
                  <%= @content.status %>
                </span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Created</span>
                <span class="text-sm font-medium"><%= @content.created_at.strftime('%m/%d/%Y') %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>