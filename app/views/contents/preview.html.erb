<!-- Content Preview for Platform -->
<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <nav class="flex" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-4">
              <li>
                <div>
                  <%= link_to "Content", contents_path, class: "text-gray-400 hover:text-gray-500" %>
                </div>
              </li>
              <li>
                <div class="flex items-center">
                  <svg class="flex-shrink-0 h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="ml-4 text-sm font-medium text-gray-500"><%= @content.title %></span>
                </div>
              </li>
            </ol>
          </nav>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to "Back", "/contents/#{@content.id}", class: "bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium" %>
          <%= link_to "Schedule", "#", class: "bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Platform Preview -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6 border-b border-gray-100">
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-semibold text-gray-900">Preview for <%= @platform.titleize %></h2>
              <div class="flex items-center space-x-2">
                <% if @platform == 'instagram' %>
                  <div class="w-6 h-6 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                  </div>
                <% elsif @platform == 'twitter' %>
                  <div class="w-6 h-6 bg-blue-400 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                    </svg>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
          
          <div class="p-6">
            <!-- Instagram Preview -->
            <% if @platform == 'instagram' %>
              <div class="bg-white border border-gray-300 rounded-lg overflow-hidden max-w-sm mx-auto" style="width: 375px;">
                <!-- Instagram Header -->
                <div class="flex items-center p-3 border-b border-gray-200">
                  <div class="w-8 h-8 bg-gray-300 rounded-full mr-3"></div>
                  <div class="flex-1">
                    <div class="text-sm font-semibold text-gray-900"><%= current_user.email.split('@')[0] %></div>
                    <div class="text-xs text-gray-500">Just now</div>
                  </div>
                  <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M6 10a2 2 0 11-4 0 2 2 0 014 0zM12 10a2 2 0 11-4 0 2 2 0 014 0zM16 12a2 2 0 100-4 2 2 0 000 4z"/>
                  </svg>
                </div>
                
                <!-- Image Placeholder -->
                <div class="aspect-square bg-gray-100 flex items-center justify-center">
                  <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </div>
                
                <!-- Content -->
                <div class="p-3">
                  <div class="text-sm font-semibold text-gray-900 mb-1">124 likes</div>
                  <div class="text-sm text-gray-900">
                    <span class="font-semibold"><%= current_user.email.split('@')[0] %></span> 
                    <%= simple_format(@content.body) %>
                  </div>
                </div>
              </div>
              
            <!-- Twitter Preview -->
            <% elsif @platform == 'twitter' %>
              <div class="bg-white border border-gray-300 rounded-lg overflow-hidden max-w-lg mx-auto">
                <div class="flex items-center p-4 border-b border-gray-200">
                  <div class="w-10 h-10 bg-gray-300 rounded-full mr-3"></div>
                  <div class="flex-1">
                    <div class="flex items-center">
                      <div class="text-sm font-semibold text-gray-900 mr-2"><%= current_user.email.split('@')[0] %></div>
                      <span class="text-sm text-gray-500">@<%= current_user.email.split('@')[0] %> · Just now</span>
                    </div>
                  </div>
                </div>
                
                <div class="p-4">
                  <div class="text-gray-900">
                    <%= simple_format(@content.body) %>
                  </div>
                  <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-200">
                    <div class="flex items-center space-x-4 text-gray-500">
                      <button class="flex items-center space-x-1 hover:text-blue-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                        </svg>
                        <span>12</span>
                      </button>
                      <button class="flex items-center space-x-1 hover:text-green-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                        </svg>
                        <span>45</span>
                      </button>
                      <button class="flex items-center space-x-1 hover:text-blue-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                        </svg>
                        <span>Share</span>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        
        <!-- Content Details -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Content Details</h3>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700">Title</label>
                <p class="mt-1 text-sm text-gray-900"><%= @content.title %></p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700">Platform</label>
                <p class="mt-1 text-sm text-gray-900"><%= @platform.titleize %></p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700">Character Count</label>
                <p class="mt-1 text-sm text-gray-900"><%= @content.body.length %> / <%= @platform == 'twitter' ? '280' : '2200' %></p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700">Word Count</label>
                <p class="mt-1 text-sm text-gray-900"><%= @content.body.split(/\s+/).count %> words</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Preview for Other Platforms -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Preview for Other Platforms</h3>
            <div class="space-y-3">
              <% ['instagram', 'twitter', 'linkedin', 'facebook'].each do |platform| %>
                <% next if platform == @platform %>
                <%= link_to "Preview for #{platform.titleize}", 
                            "/contents/#{@content.id}/preview?platform=#{platform}", 
                            class: "block w-full text-left px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md" %>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Actions</h3>
            <div class="space-y-3">
              <%= button_to "Approve Content", 
                            "/contents/#{@content.id}/approve", 
                            method: :post,
                            class: "w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium" %>
              <%= link_to "Edit Content", 
                          "/contents/#{@content.id}/edit", 
                          class: "w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium text-center block" %>
              <%= link_to "Generate Variation", 
                          "/contents/#{@content.id}/generate_variation", 
                          method: :post,
                          class: "w-full bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-medium text-center block" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>