<!-- Content Creation Form -->
<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Create New Content</h1>
          <p class="mt-1 text-gray-600">Write and format your social media content</p>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to "Back to Content", contents_path, class: "bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8" data-controller="content-new">
      
      <!-- Main Form -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6 border-b border-gray-100">
            <h2 class="text-xl font-semibold text-gray-900">Content Details</h2>
          </div>
          
          <div class="p-6">
            <%= form_with model: @content, local: true do |form| %>
              <div class="space-y-6">
                
                <!-- Title -->
                <div>
                  <%= form.label :title, "Content Title", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.text_field :title, 
                       class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent",
                       placeholder: "Enter a compelling title for your content..." %>
                </div>

                <!-- Body -->
                <div>
                  <%= form.label :body, "Content Body", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <div data-content-new-target="textarea">
                    <%= form.text_area :body, 
                         rows: 8,
                         class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent",
                         placeholder: "Write your content here..." %>
                  </div>
                  
                  <!-- Character Counter -->
                  <div class="mt-2 text-sm text-gray-500">
                    <span data-content-new-target="charCount" id="char-count">0</span> characters
                  </div>
                </div>

                <!-- Campaign Selection -->
                <div>
                  <%= form.label :campaign_id, "Campaign", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.select :campaign_id, 
                       options_from_collection_for_select(current_user&.campaigns, :id, :name, @content.campaign_id),
                       { include_blank: "Select a campaign..." },
                       class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
                </div>

                <!-- Content Type and Platform -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <%= form.label :content_type, "Content Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
                    <%= form.select :content_type, 
                         options_for_select([
                           ['Post', 'post'],
                           ['Story', 'story'],
                           ['Video', 'video'],
                           ['Image', 'image'],
                           ['Link', 'link']
                         ], @content.content_type),
                         class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
                  </div>

                  <div>
                    <%= form.label :platform, "Platform", class: "block text-sm font-medium text-gray-700 mb-2" %>
                    <%= form.select :platform, 
                         options_for_select([
                           ['Instagram', 'instagram'],
                           ['Twitter', 'twitter'],
                           ['LinkedIn', 'linkedin'],
                           ['Facebook', 'facebook'],
                           ['TikTok', 'tiktok'],
                           ['Multiple', 'general']
                         ], @content.platform),
                         class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
                  </div>
                </div>

                <!-- AI Suggestions -->
                <div class="bg-purple-50 border border-purple-200 rounded-lg p-4">
                  <div class="flex items-center mb-2">
                    <svg class="w-5 h-5 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                    </svg>
                    <h3 class="text-sm font-medium text-purple-900">AI Content Suggestions</h3>
                  </div>
                  <p class="text-sm text-purple-700 mb-3">Get AI-powered suggestions to improve your content quality and engagement.</p>
                  <button type="button" 
                          class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-md text-sm font-medium"
                          data-action="content-new#generateAISuggestions">
                    Generate Suggestions
                  </button>
                </div>

                <!-- Form Actions -->
                <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-200">
                  <%= link_to "Cancel", contents_path, class: "bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-lg font-medium" %>
                  <%= form.submit "Save Draft", 
                       class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        
        <!-- Content Tips -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Content Tips</h3>
            <div class="space-y-3 text-sm text-gray-600">
              <div class="flex items-start space-x-2">
                <div class="w-1.5 h-1.5 bg-purple-500 rounded-full mt-2 flex-shrink-0"></div>
                <p>Keep your content concise and engaging for better reach</p>
              </div>
              <div class="flex items-start space-x-2">
                <div class="w-1.5 h-1.5 bg-purple-500 rounded-full mt-2 flex-shrink-0"></div>
                <p>Use relevant hashtags to increase discoverability</p>
              </div>
              <div class="flex items-start space-x-2">
                <div class="w-1.5 h-1.5 bg-purple-500 rounded-full mt-2 flex-shrink-0"></div>
                <p>Include a call-to-action to drive engagement</p>
              </div>
              <div class="flex items-start space-x-2">
                <div class="w-1.5 h-1.5 bg-purple-500 rounded-full mt-2 flex-shrink-0"></div>
                <p>Consider the optimal posting time for your audience</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Content Preview -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Live Preview</h3>
            <div data-content-new-target="preview" id="content-preview" class="bg-gray-50 rounded-lg p-4 min-h-[200px]">
              <div class="text-sm text-gray-500">
                Your content preview will appear here as you type...
              </div>
            </div>
          </div>
        </div>

        <!-- Content Quality Score -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Content Quality</h3>
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Readability</span>
                <div class="flex items-center">
                  <div class="w-20 bg-gray-200 rounded-full h-2 mr-2">
                    <div class="bg-green-500 h-2 rounded-full" style="width: 85%"></div>
                  </div>
                  <span class="text-sm font-medium">85%</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Engagement</span>
                <div class="flex items-center">
                  <div class="w-20 bg-gray-200 rounded-full h-2 mr-2">
                    <div class="bg-blue-500 h-2 rounded-full" style="width: 72%"></div>
                  </div>
                  <span class="text-sm font-medium">72%</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">SEO Score</span>
                <div class="flex items-center">
                  <div class="w-20 bg-gray-200 rounded-full h-2 mr-2">
                    <div class="bg-purple-500 h-2 rounded-full" style="width: 68%"></div>
                  </div>
                  <span class="text-sm font-medium">68%</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

