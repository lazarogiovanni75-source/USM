<!-- Content Show Page -->
<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900"><%= @content.title %></h1>
          <p class="mt-1 text-gray-600">Content Details</p>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to "Edit", edit_content_path(@content), class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium" %>
          <%= link_to "Back to Content", contents_path, class: "bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6 border-b border-gray-100">
            <h2 class="text-xl font-semibold text-gray-900">Content Details</h2>
          </div>
          
          <div class="p-6">
            <div class="space-y-6">
              
              <!-- Title -->
              <div>
                <h3 class="text-sm font-medium text-gray-700 mb-2">Title</h3>
                <p class="text-gray-900"><%= @content.title %></p>
              </div>

              <!-- Body -->
              <div>
                <h3 class="text-sm font-medium text-gray-700 mb-2">Content</h3>
                <div class="bg-gray-50 rounded-lg p-4">
                  <p class="text-gray-900 whitespace-pre-wrap"><%= @content.body %></p>
                </div>
              </div>

              <!-- Campaign -->
              <div>
                <h3 class="text-sm font-medium text-gray-700 mb-2">Campaign</h3>
                <p class="text-gray-900"><%= @content.campaign&.name || 'No campaign assigned' %></p>
              </div>

              <!-- Content Type and Platform -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <h3 class="text-sm font-medium text-gray-700 mb-2">Content Type</h3>
                  <p class="text-gray-900 capitalize"><%= @content.content_type %></p>
                </div>

                <div>
                  <h3 class="text-sm font-medium text-gray-700 mb-2">Platform</h3>
                  <p class="text-gray-900 capitalize"><%= @content.platform %></p>
                </div>
              </div>

              <!-- Status -->
              <div>
                <h3 class="text-sm font-medium text-gray-700 mb-2">Status</h3>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 capitalize">
                  <%= @content.status %>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        
        <!-- Actions -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Actions</h3>
            <div class="space-y-3">
              <%= link_to "Edit Content", edit_content_path(@content), class: "w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium text-center block" %>
              
              <% if @content.status == 'draft' %>
                <button type="button" class="w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium">
                  Approve Content
                </button>
                <button type="button" class="w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium">
                  Reject Content
                </button>
              <% end %>
              
              <button type="button" class="w-full bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium">
                Generate Variation
              </button>
            </div>
          </div>
        </div>

        <!-- Content Stats -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Content Stats</h3>
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Word Count</span>
                <span class="text-sm font-medium"><%= @content.body.split(' ').count %></span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Character Count</span>
                <span class="text-sm font-medium"><%= @content.body.length %></span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Created</span>
                <span class="text-sm font-medium"><%= @content.created_at.strftime('%m/%d/%Y') %></span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Last Updated</span>
                <span class="text-sm font-medium"><%= @content.updated_at.strftime('%m/%d/%Y') %></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Related Content -->
        <% if @related_contents.any? %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-100">
            <div class="p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">Related Content</h3>
              <div class="space-y-3">
                <% @related_contents.each do |related_content| %>
                  <div class="border-l-4 border-purple-200 pl-3">
                    <%= link_to related_content.title, content_path(related_content), class: "text-sm text-blue-600 hover:text-blue-800 font-medium" %>
                    <p class="text-xs text-gray-500"><%= related_content.content_type %> • <%= related_content.platform %></p>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>