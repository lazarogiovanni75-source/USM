<% content_for :title, "Strategy History" %>

<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated relative overflow-hidden">
  <!-- Decorative Background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-64 h-64 bg-primary/5 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute top-40 right-20 w-96 h-96 bg-secondary/5 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  </div>

  <!-- Header -->
  <div class="bg-surface-elevated/80 backdrop-blur-lg border-b border-border/50 sticky top-0 z-40 relative">
    <div class="container-xl mx-auto px-4 py-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
          <%= link_to ai_marketing_strategy_index_path, class: "p-2 hover:bg-primary/5 rounded-lg transition-colors" do %>
            <%= lucide_icon "arrow-left", class: "w-5 h-5 text-primary" %>
          <% end %>
          <div>
            <h1 class="text-xl font-bold text-gray-900">Strategy History</h1>
            <p class="text-sm text-muted">View your past marketing strategies and trends</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container-xl mx-auto px-4 py-6">
    <% if @histories.any? %>
      <!-- Trend Summary -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-sm font-semibold text-muted mb-2">Total Strategies</h3>
          <p class="text-3xl font-bold text-gray-900"><%= @histories.count %></p>
        </div>
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-sm font-semibold text-muted mb-2">Avg Score</h3>
          <p class="text-3xl font-bold text-gray-900"><%= (@histories.average(:overall_score) || 0).round %>%</p>
        </div>
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-sm font-semibold text-muted mb-2">Latest Trend</h3>
          <% latest = @histories.first %>
          <% if latest %>
            <span class="inline-flex items-center gap-1 text-lg font-semibold 
              <%= latest.overall_score >= 50 ? 'text-success' : 'text-error' %>">
              <%= lucide_icon latest.overall_score >= 50 ? 'trending-up' : 'trending-down', class: "w-5 h-5" %>
              <%= latest.overall_score %>%
            </span>
          <% else %>
            <span class="text-muted">N/A</span>
          <% end %>
        </div>
      </div>

      <!-- History List -->
      <div class="space-y-4">
        <% @histories.each_with_index do |history, index| %>
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-sm border border-border/50 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center
                  <%= history.overall_score >= 70 ? 'bg-success/10' : history.overall_score >= 40 ? 'bg-amber-500/10' : 'bg-error/10' %>">
                  <%= lucide_icon history.overall_score >= 70 ? 'trending-up' : history.overall_score >= 40 ? 'minus' : 'trending-down', 
                      class: "w-6 h-6 #{history.overall_score >= 70 ? 'text-success' : history.overall_score >= 40 ? 'text-amber-500' : 'text-error'}" %>
                </div>
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="text-lg font-semibold text-gray-900"><%= history.focus_area.titleize %></h3>
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium
                      <%= history.generated_by == 'auto_weekly' ? 'bg-primary/10 text-gray-900' : 'bg-gray-100 text-gray-600' %>">
                      <%= history.generated_by == 'auto_weekly' ? 'Auto' : 'Manual' %>
                    </span>
                  </div>
                  <p class="text-sm text-muted mb-2">
                    <%= history.generated_at.strftime("%B %d, %Y at %I:%M %p") %>
                  </p>
                  <p class="text-sm text-muted line-clamp-2"><%= history.recommendations&.first(200) %>...</p>
                </div>
              </div>
              <div class="text-right">
                <div class="text-2xl font-bold <%= history.overall_score >= 70 ? 'text-success' : history.overall_score >= 40 ? 'text-amber-500' : 'text-error' %>">
                  <%= history.overall_score %>%
                </div>
                <p class="text-xs text-muted">Score</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-16">
        <div class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
          <%= lucide_icon "history", class: "w-10 h-10 text-primary" %>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">No Strategy History</h3>
        <p class="text-sm text-muted mb-6">Generate your first marketing strategy to start tracking</p>
        <%= link_to ai_marketing_strategy_index_path, class: "btn-primary cursor-pointer" do %>
          <%= lucide_icon "plus", class: "w-4 h-4 mr-2" %>
          Generate Strategy
        <% end %>
      </div>
    <% end %>
  </div>
</div>
