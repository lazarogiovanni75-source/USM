<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Post Performance Overview</h1>
    
    <div class="flex items-center space-x-4">
      <!-- Filter Controls -->
      <select onchange="filterPosts(this.value)" class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-1 text-sm text-gray-900 dark:text-white focus:border-blue-500 focus:ring-blue-500">
        <option value="">All Platforms</option>
        <option value="instagram">Instagram</option>
        <option value="twitter">Twitter</option>
        <option value="linkedin">LinkedIn</option>
        <option value="facebook">Facebook</option>
        <option value="tiktok">TikTok</option>
      </select>
      
      <!-- Compare Button -->
      <button onclick="showCompareModal()" class="btn-secondary inline-flex items-center px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors">
        <%= lucide_icon "bar-chart-3", class: "w-5 h-5 mr-2" %>
        Compare
      </button>
    </div>
  </div>

  <!-- Performance Summary Cards -->
  <% if @posts_summary[:summary] && @posts_summary[:summary].any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <div class="flex items-center">
          <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/20 rounded-lg flex items-center justify-center">
            <%= lucide_icon "file-text", class: "w-6 h-6 text-blue-600 dark:text-blue-400" %>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Posts</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @posts_summary[:summary][:total_posts] %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <div class="flex items-center">
          <div class="w-12 h-12 bg-green-100 dark:bg-green-900/20 rounded-lg flex items-center justify-center">
            <%= lucide_icon "heart", class: "w-6 h-6 text-green-600 dark:text-green-400" %>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Engagements</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @posts_summary[:summary][:total_engagements] %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <div class="flex items-center">
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/20 rounded-lg flex items-center justify-center">
            <%= lucide_icon "trending-up", class: "w-6 h-6 text-purple-600 dark:text-purple-400" %>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Avg Engagement Rate</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @posts_summary[:summary][:avg_engagement_rate] %>%</p>
          </div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <div class="flex items-center">
          <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/20 rounded-lg flex items-center justify-center">
            <%= lucide_icon "star", class: "w-6 h-6 text-orange-600 dark:text-orange-400" %>
          </div>
          <div class="ml-4">
            <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Avg Performance Score</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @posts_summary[:summary][:avg_performance_score] %></p>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Top Performers & Insights Section -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
    <!-- Top Performers -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
        <%= lucide_icon "trending-up", class: "w-6 h-6 text-green-500 mr-2" %>
        Top Performers
      </h2>
      
      <% if @posts_summary[:top_performers] && @posts_summary[:top_performers].any? %>
        <div class="space-y-3">
          <% @posts_summary[:top_performers].each_with_index do |post, index| %>
            <div class="flex items-center justify-between p-3 bg-green-50 dark:bg-green-900/20 rounded-lg">
              <div class="flex items-center space-x-3">
                <span class="inline-flex items-center justify-center w-6 h-6 bg-green-100 dark:bg-green-900/20 rounded-full text-xs font-medium text-green-600 dark:text-green-400">
                  <%= index + 1 %>
                </span>
                <div>
                  <h3 class="text-sm font-medium text-gray-900 dark:text-white truncate max-w-xs">
                    <%= post[:title] %>
                  </h3>
                  <p class="text-sm text-gray-500 dark:text-gray-400">
                    <%= post[:platform].capitalize %> • Score: <%= post[:performance_score] %>
                  </p>
                </div>
              </div>
              <div class="text-right">
                <div class="text-lg font-semibold text-green-600 dark:text-green-400">
                  <%= post[:total_engagements] %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400">engagements</div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8 text-gray-500 dark:text-gray-400">
          <%= lucide_icon "trending-up", class: "w-8 h-8 mx-auto mb-2" %>
          <p class="text-sm">No top performers yet</p>
        </div>
      <% end %>
    </div>

    <!-- Performance Insights -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
        <%= lucide_icon "brain", class: "w-6 h-6 text-purple-500 mr-2" %>
        AI Insights
      </h2>
      
      <% if @insights && @insights.any? %>
        <div class="space-y-4">
          <% @insights.each do |insight| %>
            <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg border border-blue-200 dark:border-blue-800">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <h3 class="text-sm font-medium text-blue-900 dark:text-blue-100">
                    <%= insight[:title] %>
                  </h3>
                  <p class="mt-1 text-sm text-blue-700 dark:text-blue-300">
                    <%= insight[:description] %>
                  </p>
                </div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/20 text-blue-800 dark:text-blue-400">
                  <%= insight[:type].titleize %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-8 text-center">
          <%= lucide_icon "brain", class: "w-8 h-8 mx-auto mb-2 text-purple-500" %>
          <p class="text-sm">Collecting insights... Post more content to get AI-powered recommendations.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Posts Table -->
  <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md border border-gray-200 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">All Posts Performance</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Post</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Platform</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Engagements</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Engagement Rate</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Performance Score</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-600">
          <% if @posts_summary[:posts] && @posts_summary[:posts].any? %>
            <% @posts_summary[:posts].each do |post_data| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div>
                      <div class="text-sm font-medium text-gray-900 dark:text-white">
                        <%= post_data[:title] %>
                      </div>
                      <div class="text-sm text-gray-500 dark:text-gray-400">
                        <%= post_data[:scheduled_at].strftime("%b %d, %Y") %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/20 text-blue-800 dark:text-blue-400">
                    <%= post_data[:platform].capitalize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                  <%= post_data[:total_engagements] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="text-sm font-medium text-gray-900 dark:text-white">
                    <%= post_data[:engagement_rate] %>%
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="text-sm font-medium text-gray-900 dark:text-white mr-2">
                      <%= post_data[:performance_score] %>
                    </div>
                    <div class="w-16 bg-gray-200 dark:bg-gray-600 rounded-full h-2">
                      <div class="bg-blue-600 h-2 rounded-full" style="width: <%= post_data[:performance_score] %>%"></div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <%= link_to "View Details", post_performance_overview_path(post_data[:post_id]), class: "text-blue-600 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">
                No posts found. Start creating and posting content to see performance metrics.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>