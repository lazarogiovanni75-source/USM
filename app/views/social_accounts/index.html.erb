<!-- Social Accounts Management -->
<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Social Accounts</h1>
          <p class="mt-1 text-gray-600">Connect and manage your social media platforms</p>
        </div>
        <div class="flex items-center space-x-4">
          <button class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium flex items-center space-x-2" 
                  data-action="connect-platform">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            <span>Connect Platform</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Connection Status Overview -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div class="bg-gradient-to-r from-pink-500 to-purple-600 rounded-xl shadow-sm p-6 text-white">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-semibold">Instagram</h3>
            <p class="text-sm opacity-90">Business accounts</p>
            <p class="text-2xl font-bold mt-2"><%= @connected_instagram %>/<%= @total_instagram %></p>
            <p class="text-sm opacity-75">Connected</p>
          </div>
          <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-gradient-to-r from-blue-400 to-blue-600 rounded-xl shadow-sm p-6 text-white">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-semibold">Twitter/X</h3>
            <p class="text-sm opacity-90">Personal & business</p>
            <p class="text-2xl font-bold mt-2"><%= @connected_twitter %>/<%= @total_twitter %></p>
            <p class="text-sm opacity-75">Connected</p>
          </div>
          <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-gradient-to-r from-red-500 to-pink-600 rounded-xl shadow-sm p-6 text-white">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-semibold">TikTok</h3>
            <p class="text-sm opacity-90">Creator accounts</p>
            <p class="text-2xl font-bold mt-2"><%= @connected_tiktok %>/<%= @total_tiktok %></p>
            <p class="text-sm opacity-75">Connected</p>
          </div>
          <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Connected Accounts List -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="p-6 border-b border-gray-100">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-semibold text-gray-900">Connected Accounts</h3>
          <div class="flex items-center space-x-4">
            <button class="text-sm text-gray-600 hover:text-gray-900">Refresh All</button>
            <button class="text-sm text-purple-600 hover:text-purple-800 font-medium">View Analytics</button>
          </div>
        </div>
      </div>

      <div class="divide-y divide-gray-200">
        <% if @social_accounts.any? %>
          <% @social_accounts.each do |account| %>
            <div class="p-6 hover:bg-gray-50">
              <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4">
                  <div class="flex-1">
                    <h4 class="text-lg font-medium text-gray-900"><%= account.display_name %></h4>
                    <div class="flex items-center space-x-4 mt-1 text-sm text-gray-500">
                      <span class="capitalize"><%= account.platform %></span>
                      <span>•</span>
                      <span><%= account.followers_count %> followers</span>
                      <span>•</span>
                      <span class="<%= account.active ? 'text-green-600' : 'text-gray-400' %>">
                        <%= account.active ? 'Active' : 'Inactive' %>
                      </span>
                    </div>
                    <% if account.last_sync_at %>
                      <p class="text-sm text-gray-400 mt-1">
                        Last synced <%= time_ago_in_words(account.last_sync_at) %> ago
                      </p>
                    <% end %>
                  </div>
                </div>
                <div class="flex items-center space-x-4">
                  <div class="text-right">
                    <div class="text-sm font-medium text-gray-900">
                      <%= account.stats_posts || 0 %> posts
                    </div>
                    <div class="text-sm text-gray-500">
                      <%= account.stats_engagement || 0 %> engagement
                    </div>
                  </div>
                  <div class="flex items-center space-x-2">
                    <button class="text-blue-600 hover:text-blue-800 text-sm font-medium"
                            data-action="edit-account"
                            data-account-id="<%= account.id %>">
                      Edit
                    </button>
                    <button class="text-purple-600 hover:text-purple-800 text-sm font-medium"
                            data-action="sync-account"
                            data-account-id="<%= account.id %>">
                      Sync
                    </button>
                    <button class="text-red-600 hover:text-red-800 text-sm font-medium"
                            data-action="disconnect-account"
                            data-account-id="<%= account.id %>">
                      Disconnect
                    </button>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="p-12 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">No social accounts connected</h3>
            <p class="mt-1 text-sm text-gray-500">Connect your first social media account to start managing your content.</p>
            <div class="mt-6">
              <button class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700"
                      data-action="connect-platform">
                Connect Your First Account
              </button>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>