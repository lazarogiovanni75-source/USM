<% content_for :title, "Dashboard" %>

<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated">
  <!-- Header -->
  <div class="bg-white/80 backdrop-blur-lg border-b border-border/50 sticky top-0 z-40">
    <div class="container-xl mx-auto px-4 py-4">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-lg">
            <span class="text-white font-bold text-xl"><%= current_user.name.present? ? current_user.name.first : current_user.email.first.upcase %></span>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-primary">Welcome back, <%= current_user.name.present? ? current_user.name.split.first : 'there' %>! 👋</h1>
            <p class="text-sm text-muted">Your social media command center</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="bg-white rounded-xl px-4 py-2 shadow-sm border border-border/50">
            <p class="text-xs text-muted">Messages</p>
            <p class="text-lg font-bold text-primary"><%= @ai_conversations_count || 0 %></p>
          </div>
          <div class="bg-white rounded-xl px-4 py-2 shadow-sm border border-border/50">
            <p class="text-xs text-muted">Content</p>
            <p class="text-lg font-bold text-primary"><%= @total_contents || 0 %></p>
          </div>
          <div class="bg-white rounded-xl px-4 py-2 shadow-sm border border-border/50">
            <p class="text-xs text-muted">Scheduled</p>
            <p class="text-lg font-bold text-primary"><%= @scheduled_posts_count || 0 %></p>
          </div>
          <div class="bg-white rounded-xl px-4 py-2 shadow-sm border border-border/50">
            <p class="text-xs text-muted">Engagement</p>
            <p class="text-lg font-bold text-primary"><%= @engagement_rate || 0 %>%</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container-xl mx-auto px-4 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- LEFT: Inbox -->
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 overflow-hidden">
          <div class="bg-gradient-to-r from-primary/10 to-secondary/10 px-6 py-4 border-b border-border/50">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center">
                  <%= lucide_icon "inbox", class: "w-5 h-5 text-white" %>
                </div>
                <div>
                  <h2 class="text-lg font-bold text-primary">Unified Inbox</h2>
                  <p class="text-xs text-muted"><%= @ai_conversations_count || 0 %> conversations</p>
                </div>
              </div>
            </div>
          </div>
          <div class="divide-y divide-border/30 max-h-[500px] overflow-y-auto">
            <% if @ai_conversations && @ai_conversations.any? %>
              <% @ai_conversations.each do |conversation| %>
                <%= link_to dashboard_path(conversation_id: conversation.id), class: "flex items-start gap-4 p-4 hover:bg-surface-elevated/50 #{params[:conversation_id].to_i == conversation.id ? 'bg-primary/5 border-l-4 border-primary' : ''}" do %>
                  <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-semibold flex-shrink-0">
                    <%= conversation.title.present? ? conversation.title.first.upcase : 'C' %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                      <h3 class="font-semibold text-primary truncate"><%= conversation.title || 'Untitled' %></h3>
                      <span class="text-xs text-muted"><%= time_ago_in_words(conversation.updated_at) %> ago</span>
                    </div>
                    <p class="text-sm text-muted line-clamp-2"><%= conversation.ai_messages.last&.content&.truncate(80) || 'No messages' %></p>
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <div class="flex flex-col items-center justify-center py-16">
                <div class="w-20 h-20 rounded-full bg-gray-100 flex items-center justify-center mb-4">
                  <%= lucide_icon "message-circle", class: "w-10 h-10 text-muted" %>
                </div>
                <h3 class="text-lg font-semibold text-primary mb-1">No conversations yet</h3>
                <%= link_to ai_chat_index_path, class: "btn-primary mt-2" do %>
                  <%= lucide_icon "plus", class: "w-4 h-4 mr-2" %>Start Chat
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <%= link_to ai_chat_index_path, class: "group bg-white rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-lg hover:border-primary/30 transition-all" do %>
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
              <%= lucide_icon "bot", class: "w-6 h-6 text-white" %>
            </div>
            <h3 class="font-semibold text-primary">AI Chat</h3>
            <p class="text-xs text-muted">Assistant</p>
          <% end %>
          <%= link_to content_creation_index_path, class: "group bg-white rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-lg hover:border-secondary/30 transition-all" do %>
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
              <%= lucide_icon "sparkles", class: "w-6 h-6 text-white" %>
            </div>
            <h3 class="font-semibold text-primary">Create</h3>
            <p class="text-xs text-muted">Content</p>
          <% end %>
          <%= link_to content_templates_path, class: "group bg-white rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-lg hover:border-pink-500/30 transition-all" do %>
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-pink-500 to-rose-500 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
              <%= lucide_icon "layout-template", class: "w-6 h-6 text-white" %>
            </div>
            <h3 class="font-semibold text-primary">Templates</h3>
            <p class="text-xs text-muted">Library</p>
          <% end %>
          <%= link_to engagement_analytics_path, class: "group bg-white rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-lg hover:border-green-500/30 transition-all" do %>
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500 to-emerald-500 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
              <%= lucide_icon "bar-chart-3", class: "w-6 h-6 text-white" %>
            </div>
            <h3 class="font-semibold text-primary">Analytics</h3>
            <p class="text-xs text-muted">Insights</p>
          <% end %>
        </div>
      </div>

      <!-- RIGHT: Thread -->
      <div class="space-y-6">
        <% if params[:conversation_id] && (@selected_conversation = @ai_conversations&.find_by(id: params[:conversation_id])) %>
          <div class="bg-white rounded-2xl shadow-sm border border-border/50 overflow-hidden sticky top-24">
            <div class="bg-gradient-to-r from-primary/10 to-secondary/10 px-4 py-3 border-b border-border/50">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary to-secondary flex items-center justify-center">
                    <%= lucide_icon "message-circle", class: "w-4 h-4 text-white" %>
                  </div>
                  <h3 class="font-semibold text-primary text-sm"><%= @selected_conversation.title || 'Conversation' %></h3>
                </div>
              </div>
            </div>
            <div class="p-4 space-y-4 max-h-[400px] overflow-y-auto bg-gray-50/30">
              <% @selected_conversation.ai_messages.order(created_at: :asc).each do |message| %>
                <div class="flex <%= message.role == 'user' ? 'justify-end' : 'justify-start' %>">
                  <div class="max-w-[85%]">
                    <div class="<%= message.role == 'user' ? 'bg-gradient-to-br from-primary to-secondary text-white' : 'bg-white border border-border/50' %> rounded-2xl px-4 py-3 shadow-sm">
                      <p class="text-sm <%= message.role == 'user' ? 'text-white' : 'text-primary' %>"><%= message.content %></p>
                    </div>
                    <p class="text-xs text-muted mt-1 <%= message.role == 'user' ? 'text-right' : 'text-left' %>"><%= message.created_at.strftime('%b %e, %l:%M %p') %></p>
                  </div>
                </div>
              <% end %>
            </div>
            <div class="p-4 border-t border-border/50 bg-white">
              <%= form_with url: respond_dashboard_path(@selected_conversation), method: :post, local: true do |f| %>
                <div class="relative">
                  <%= f.text_area :content, placeholder: "Type your reply...", rows: 2, class: "form-input w-full pr-12 resize-none" %>
                  <%= f.button type: :submit, class: "absolute right-2 bottom-2 p-2 bg-primary text-white rounded-lg hover:bg-primary-dark" do %>
                    <%= lucide_icon "send", class: "w-4 h-4" %>
                  <% end %>
                </div>
              <% end %>
              <div class="flex flex-wrap gap-2 mt-3">
                <button class="px-3 py-1 bg-surface-elevated text-muted text-xs rounded-full hover:bg-primary/10 hover:text-primary" onclick="document.querySelector('[name=&quot;content&quot;]').value = 'Thanks!'">Thanks!</button>
                <button class="px-3 py-1 bg-surface-elevated text-muted text-xs rounded-full hover:bg-primary/10 hover:text-primary" onclick="document.querySelector('[name=&quot;content&quot;]').value = 'Let me check'">Check</button>
                <button class="px-3 py-1 bg-surface-elevated text-muted text-xs rounded-full hover:bg-primary/10 hover:text-primary" onclick="document.querySelector('[name=&quot;content&quot;]').value = 'Sounds good'">Good</button>
              </div>
            </div>
          </div>
        <% else %>
          <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-8 sticky top-24">
            <div class="flex flex-col items-center justify-center text-center">
              <div class="w-24 h-24 rounded-full bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center mb-4">
                <%= lucide_icon "message-square", class: "w-12 h-12 text-primary" %>
              </div>
              <h3 class="text-xl font-bold text-primary mb-2">Select a Conversation</h3>
              <p class="text-sm text-muted mb-4">Choose a conversation to view and respond.</p>
              <%= link_to ai_chat_index_path, class: "btn-primary" do %>
                <%= lucide_icon "plus", class: "w-4 h-4 mr-2" %>New Chat
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Activity -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-lg font-bold text-primary mb-4 flex items-center gap-2">
            <%= lucide_icon "activity", class: "w-5 h-5 text-primary" %>Recent Activity
          </h3>
          <div class="space-y-4">
            <% if @scheduled_posts && @scheduled_posts.any? %>
              <% @scheduled_posts.each do |post| %>
                <div class="flex items-start gap-3 pb-3 border-b border-border/30 last:border-0">
                  <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center flex-shrink-0">
                    <%= lucide_icon "clock", class: "w-4 h-4 text-white" %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-primary truncate"><%= post.title || 'Scheduled Post' %></p>
                    <p class="text-xs text-muted"><%= post.scheduled_time&.strftime('%b %e, %l:%M %p') || 'No time' %></p>
                  </div>
                </div>
              <% end %>
            <% else %>
              <p class="text-sm text-muted text-center py-4">No scheduled posts</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
