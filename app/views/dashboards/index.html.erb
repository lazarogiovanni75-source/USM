<% content_for :title, "Dashboard" %>

<!-- Dashboard with Enhanced Design -->
<div class="min-h-screen bg-gradient-to-br from-surface via-surface to-surface-elevated relative overflow-hidden">
  <!-- Decorative Background Bubbles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-64 h-64 bg-primary/5 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute top-40 right-20 w-96 h-96 bg-secondary/5 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute bottom-20 left-1/3 w-80 h-80 bg-success/5 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute top-1/2 left-1/4 w-48 h-48 bg-purple-500/5 rounded-full blur-3xl animate-pulse" style="animation-delay: 3s;"></div>
  </div>

  <!-- Header -->
  <div class="bg-white/60 backdrop-blur-lg border-b border-border/50 sticky top-0 z-40 relative">
    <div class="container-xl mx-auto px-4 py-6">
      <!-- Centralized App Title -->
      <div class="text-center mb-6">
        <div class="inline-flex items-center gap-3 px-6 py-3 bg-gradient-to-r from-primary/10 to-secondary/10 rounded-2xl border border-primary/20">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-lg">
            <%= lucide_icon "rocket", class: "w-6 h-6 text-white" %>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-primary tracking-tight">Ultimate Social Media</h1>
            <p class="text-xs text-muted uppercase tracking-wider">AI-Powered Marketing Platform</p>
          </div>
        </div>
      </div>
      
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <!-- Welcome Section with User Avatar -->
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-lg ring-4 ring-primary/10">
            <span class="text-white font-bold text-xl"><%= current_user.name.present? ? current_user.name.first : current_user.email.first.upcase %></span>
          </div>
          <div>
            <h1 class="text-xl font-bold text-primary">Welcome back, <%= current_user.name.present? ? current_user.name.split.first : 'there' %>! 👋</h1>
            <p class="text-sm text-muted flex items-center gap-2">
              <span class="w-2 h-2 bg-success rounded-full animate-pulse"></span>
              Your social media command center
            </p>
          </div>
        </div>
        <!-- Metrics Cards with Bubbling Effect -->
        <div class="flex flex-wrap gap-3">
          <!-- Messages -->
          <div class="group relative bg-white rounded-2xl px-5 py-3 shadow-sm border border-border/50 hover:shadow-lg hover:border-primary/30 transition-all cursor-pointer">
            <div class="absolute inset-0 bg-gradient-to-r from-primary/5 to-secondary/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center">
                <%= lucide_icon "message-circle", class: "w-5 h-5 text-white" %>
              </div>
              <div>
                <p class="text-xs text-muted">Messages</p>
                <p class="text-xl font-bold text-primary"><%= @ai_conversations_count || 0 %></p>
              </div>
            </div>
          </div>
          
          <!-- Content -->
          <div class="group relative bg-white rounded-2xl px-5 py-3 shadow-sm border border-border/50 hover:shadow-lg hover:border-secondary/30 transition-all cursor-pointer">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-500/5 to-cyan-500/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center">
                <%= lucide_icon "file-text", class: "w-5 h-5 text-white" %>
              </div>
              <div>
                <p class="text-xs text-muted">Content</p>
                <p class="text-xl font-bold text-primary"><%= @total_contents || 0 %></p>
              </div>
            </div>
          </div>
          
          <!-- Scheduled -->
          <div class="group relative bg-white rounded-2xl px-5 py-3 shadow-sm border border-border/50 hover:shadow-lg hover:border-pink-500/30 transition-all cursor-pointer">
            <div class="absolute inset-0 bg-gradient-to-r from-pink-500/5 to-rose-500/5 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-pink-500 to-rose-500 flex items-center justify-center">
                <%= lucide_icon "calendar", class: "w-5 h-5 text-white" %>
              </div>
              <div>
                <p class="text-xs text-muted">Scheduled</p>
                <p class="text-xl font-bold text-primary"><%= @scheduled_posts_count || 0 %></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container-xl mx-auto px-4 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Feature Action Tabs -->
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h2 class="text-lg font-bold text-primary mb-4 flex items-center gap-2">
            <%= lucide_icon "zap", class: "w-5 h-5 text-primary" %>Quick Actions
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <%= link_to ai_autopilot_index_path, class: "flex flex-col items-center gap-2 p-4 bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-xl border border-purple-500/20 hover:from-purple-500/20 hover:to-pink-500/20 hover:border-purple-500/30 transition-all group" do %>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <%= lucide_icon "bot", class: "w-6 h-6 text-white" %>
              </div>
              <span class="text-sm font-semibold text-primary text-center">Autopilot</span>
              <span class="text-xs text-muted text-center">Hands-free posting</span>
            <% end %>

            <%= link_to scheduled_posts_path, class: "flex flex-col items-center gap-2 p-4 bg-gradient-to-br from-blue-500/10 to-cyan-500/10 rounded-xl border border-blue-500/20 hover:from-blue-500/20 hover:to-cyan-500/20 hover:border-blue-500/30 transition-all group" do %>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <%= lucide_icon "calendar", class: "w-6 h-6 text-white" %>
              </div>
              <span class="text-sm font-semibold text-primary text-center">Scheduling</span>
              <span class="text-xs text-muted text-center">Unlimited posts</span>
            <% end %>

            <%= link_to campaigns_path, class: "flex flex-col items-center gap-2 p-4 bg-gradient-to-br from-green-500/10 to-emerald-500/10 rounded-xl border border-green-500/20 hover:from-green-500/20 hover:to-emerald-500/20 hover:border-green-500/30 transition-all group" do %>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500 to-emerald-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <%= lucide_icon "megaphone", class: "w-6 h-6 text-white" %>
              </div>
              <span class="text-sm font-semibold text-primary text-center">Campaigns</span>
              <span class="text-xs text-muted text-center">AI strategies</span>
            <% end %>

            <%= link_to voice_commands_path, class: "flex flex-col items-center gap-2 p-4 bg-gradient-to-br from-amber-500/10 to-orange-500/10 rounded-xl border border-amber-500/20 hover:from-amber-500/20 hover:to-orange-500/20 hover:border-amber-500/30 transition-all group" do %>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <%= lucide_icon "mic", class: "w-6 h-6 text-white" %>
              </div>
              <span class="text-sm font-semibold text-primary text-center">Voice</span>
              <span class="text-xs text-muted text-center">Commands</span>
            <% end %>

            <%= link_to content_creation_index_path, class: "flex flex-col items-center gap-2 p-4 bg-gradient-to-br from-red-500/10 to-rose-500/10 rounded-xl border border-red-500/20 hover:from-red-500/20 hover:to-rose-500/20 hover:border-red-500/30 transition-all group" do %>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-red-500 to-rose-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <%= lucide_icon "video", class: "w-6 h-6 text-white" %>
              </div>
              <span class="text-sm font-semibold text-primary text-center">Sora 2 Pro</span>
              <span class="text-xs text-muted text-center">Video generation</span>
            <% end %>

            <%= link_to ai_chat_index_path, class: "flex flex-col items-center gap-2 p-4 bg-gradient-to-br from-indigo-500/10 to-violet-500/10 rounded-xl border border-indigo-500/20 hover:from-indigo-500/20 hover:to-violet-500/20 hover:border-indigo-500/30 transition-all group" do %>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <%= lucide_icon "message-square", class: "w-6 h-6 text-white" %>
              </div>
              <span class="text-sm font-semibold text-primary text-center">AI Chat</span>
              <span class="text-xs text-muted text-center">Conversations</span>
            <% end %>
          </div>
        </div>
      </div>

      <!-- RIGHT: Sidebar -->
      <div class="space-y-6">
        <!-- Recent Activity -->
        <div class="bg-white rounded-2xl shadow-sm border border-border/50 p-6">
          <h3 class="text-lg font-bold text-primary mb-4 flex items-center gap-2">
            <%= lucide_icon "activity", class: "w-5 h-5 text-primary" %>Recent Activity
          </h3>
          <div class="space-y-4">
            <% if @scheduled_posts && @scheduled_posts.any? %>
              <% @scheduled_posts.each do |post| %>
                <div class="flex items-start gap-3 pb-3 border-b border-border/30 last:border-0">
                  <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center flex-shrink-0">
                    <%= lucide_icon "clock", class: "w-4 h-4 text-white" %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-primary truncate"><%= post.title || 'Scheduled Post' %></p>
                    <p class="text-xs text-muted"><%= post.scheduled_time&.strftime('%b %e, %l:%M %p') || 'No time' %></p>
                  </div>
                </div>
              <% end %>
            <% else %>
              <p class="text-sm text-muted text-center py-4">No scheduled posts</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
