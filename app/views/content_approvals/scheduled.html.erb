<!DOCTYPE html>
<html>
<head>
  <title>Post Scheduled</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 500px; margin: 60px auto; padding: 0 20px; color: #1e293b; text-align: center; }
    .icon { font-size: 64px; margin-bottom: 20px; }
    h1 { font-size: 24px; color: #2563eb; margin-bottom: 12px; }
    p { color: #64748b; line-height: 1.6; }
    .time { font-weight: 600; color: #1e293b; }
    .btn { display: inline-block; margin-top: 24px; padding: 12px 24px; background: #2563eb; color: white; text-decoration: none; border-radius: 8px; font-weight: 600; }
    .btn:hover { background: #1d4ed8; }
  </style>
</head>
<body>
  <div class="icon">📅</div>
  <h1>Post Scheduled!</h1>
  <p>Your content has been approved and will be posted on<br><span class="time"><%= @draft.scheduled_for.strftime("%B %d, %Y at %I:%M %p") %></span></p>
  <a href="/" class="btn">Go to Dashboard</a>
</body>
</html>
