const CACHE_VERSION = 'v2.0.1';
const CACHE_NAME = `social-media-pwa-${CACHE_VERSION}`;
const CACHE_MAX_AGE = 30 * 24 * 60 * 60 * 1000; // 30 days for WebView

// Static assets to cache
const STATIC_CACHE_URLS = [
  '/',
  '/dashboard',
  '/content',
  '/manifest.json',
  '<%= asset_path("application.css") %>',
  '<%= asset_path("application.js") %>',
  '/icon-192x192.png',
  '/icon-512x512.png'
];

// API endpoints to cache (with network-first strategy)
const API_CACHE_URLS = [
  '/api/v1/profiles',
  '/api/v1/health',
  '/dashboard/metrics'
];

// Critical pages that should always be available offline
const CRITICAL_PAGES = [
  '/',
  '/dashboard',
  '/login',
  '/register'
];

self.addEventListener('install', event => {
  console.log('Service Worker: Installing...');
  
  event.waitUntil(
    caches.open(CACHE_NAME)
      .then(cache => {
        console.log('Service Worker: Caching critical assets');
        return cache.addAll(STATIC_CACHE_URLS.concat(CRITICAL_PAGES));
      })
      .then(() => {
        console.log('Service Worker: Skip waiting');
        return self.skipWaiting();
      })
      .catch(error => {
        console.error('Service Worker: Cache failed:', error);
      })
  );
});

self.addEventListener('activate', event => {
  console.log('Service Worker: Activating...');
  
  event.waitUntil(
    caches.keys().then(cacheNames => {
      return Promise.all(
        cacheNames
          .filter(cacheName => cacheName.startsWith('social-media-pwa-') && cacheName !== CACHE_NAME)
          .map(cacheName => {
            console.log('Service Worker: Deleting old cache:', cacheName);
            return caches.delete(cacheName);
          })
      );
    }).then(() => {
      console.log('Service Worker: Claiming clients');
      return self.clients.claim();
    })
  );
});

// Enhanced fetch handler with WebView optimizations
self.addEventListener('fetch', event => {
  const { request } = event;
  const url = new URL(request.url);
  
  // Skip non-GET requests
  if (request.method !== 'GET') {
    return;
  }
  
  // Skip service worker itself
  if (url.pathname === '/service-worker.js') {
    return;
  }
  
  // Handle different types of requests with appropriate strategies
  if (isAPIRequest(url)) {
    event.respondWith(handleAPIRequest(request));
  } else if (isStaticAsset(url)) {
    event.respondWith(handleStaticAssetRequest(request));
  } else if (isHTMLPage(request)) {
    event.respondWith(handleHTMLPageRequest(request));
  } else {
    event.respondWith(handleOtherRequest(request));
  }
});

// Check if request is for API
function isAPIRequest(url) {
  return url.pathname.startsWith('/api/') || 
         url.pathname.includes('/api/v1/');
}

// Check if request is for static asset
function isStaticAsset(url) {
  return url.pathname.includes('/assets/') ||
         url.pathname.endsWith('.js') ||
         url.pathname.endsWith('.css') ||
         url.pathname.endsWith('.png') ||
         url.pathname.endsWith('.jpg') ||
         url.pathname.endsWith('.svg') ||
         url.pathname.endsWith('.ico');
}

// Check if request is for HTML page
function isHTMLPage(request) {
  return request.headers.get('accept')?.includes('text/html');
}

// Handle API requests with network-first strategy
async function handleAPIRequest(request) {
  try {
    // Try network first for fresh data
    const networkResponse = await fetch(request);
    
    if (networkResponse.ok) {
      // Cache successful API responses
      const cache = await caches.open(CACHE_NAME);
      cache.put(request, networkResponse.clone());
    }
    
    return networkResponse;
  } catch (error) {
    console.log('Service Worker: Network failed, trying cache for:', request.url);
    
    // Fallback to cache for API requests
    const cachedResponse = await caches.match(request);
    if (cachedResponse) {
      return cachedResponse;
    }
    
    // Return offline response for API
    return new Response(
      JSON.stringify({ 
        error: 'Offline',
        message: 'This feature requires internet connection'
      }),
      {
        status: 503,
        statusText: 'Service Unavailable',
        headers: { 'Content-Type': 'application/json' }
      }
    );
  }
}

// Handle static assets with cache-first strategy
async function handleStaticAssetRequest(request) {
  const cachedResponse = await caches.match(request);
  
  if (cachedResponse) {
    // Check if cached response is still fresh
    const cacheDate = new Date(cachedResponse.headers.get('date'));
    const now = new Date();
    
    if (now - cacheDate < CACHE_MAX_AGE) {
      return cachedResponse;
    }
  }
  
  try {
    // Fetch from network
    const networkResponse = await fetch(request);
    
    if (networkResponse.ok) {
      // Cache successful responses
      const cache = await caches.open(CACHE_NAME);
      cache.put(request, networkResponse.clone());
    }
    
    return networkResponse;
  } catch (error) {
    // Fallback to cached response
    return cachedResponse || new Response('Asset not available offline');
  }
}

// Handle HTML pages with network-first strategy
async function handleHTMLPageRequest(request) {
  try {
    const networkResponse = await fetch(request);
    
    if (networkResponse.ok) {
      // Cache HTML pages for offline viewing
      const cache = await caches.open(CACHE_NAME);
      cache.put(request, networkResponse.clone());
    }
    
    return networkResponse;
  } catch (error) {
    console.log('Service Worker: Network failed, trying cache for HTML:', request.url);
    
    // Fallback to cached HTML pages
    const cachedResponse = await caches.match(request);
    if (cachedResponse) {
      return cachedResponse;
    }
    
    // Return offline page for critical pages
    if (CRITICAL_PAGES.some(page => request.url.includes(page))) {
      return caches.match('/') || new Response('Page not available offline');
    }
    
    return new Response('Page not available offline', {
      status: 503,
      statusText: 'Service Unavailable'
    });
  }
}

// Handle other requests (fallback)
async function handleOtherRequest(request) {
  const cachedResponse = await caches.match(request);
  
  if (cachedResponse) {
    return cachedResponse;
  }
  
  try {
    return await fetch(request);
  } catch (error) {
    return new Response('Resource not available');
  }
}

// Handle background sync for offline actions
self.addEventListener('sync', event => {
  if (event.tag === 'background-sync') {
    event.waitUntil(doBackgroundSync());
  }
});

// Background sync function
async function doBackgroundSync() {
  try {
    // Sync queued actions when online
    const syncActions = await getSyncActions();
    
    for (const action of syncActions) {
      try {
        await fetch(action.url, {
          method: action.method,
          headers: action.headers,
          body: action.body
        });
        
        // Remove successful actions from queue
        await removeSyncAction(action.id);
      } catch (error) {
        console.log('Service Worker: Background sync failed for:', action.url);
      }
    }
  } catch (error) {
    console.error('Service Worker: Background sync error:', error);
  }
}

// Handle push notifications (if implemented)
self.addEventListener('push', event => {
  if (event.data) {
    const data = event.data.json();
    
    const options = {
      body: data.body || 'You have a new notification',
      icon: '/icon-192x192.png',
      badge: '/icon-192x192.png',
      tag: data.tag || 'default',
      data: data.data || {},
      actions: data.actions || []
    };
    
    event.waitUntil(
      self.registration.showNotification(data.title || 'Social Media Platform', options)
    );
  }
});

// Handle notification clicks
self.addEventListener('notificationclick', event => {
  event.notification.close();
  
  const action = event.action;
  const data = event.notification.data;
  
  event.waitUntil(
    clients.matchAll().then(clientList => {
      // Focus existing window if available
      for (const client of clientList) {
        if (client.url === '/' && 'focus' in client) {
          return client.focus();
        }
      }
      
      // Open new window if no existing window
      if (clients.openWindow) {
        return clients.openWindow(data?.url || '/');
      }
    })
  );
});

// Handle messages from main thread
self.addEventListener('message', event => {
  if (event.data && event.data.type) {
    switch (event.data.type) {
      case 'SKIP_WAITING':
        self.skipWaiting();
        break;
      case 'CLEAR_CACHE':
        clearAllCaches();
        break;
      case 'GET_VERSION':
        event.ports[0].postMessage({ version: CACHE_VERSION });
        break;
      case 'IS_ONLINE':
        event.ports[0].postMessage({ online: navigator.onLine });
        break;
    }
  }
});

