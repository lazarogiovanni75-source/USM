<!-- Navigation -->
<div class="flex-grow flex flex-col">
  <div class="px-4">
    <div class="border-t border-gray-200 dark:border-gray-700 pt-4">
      <div class="pb-2 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">MENU</div>
    </div>
  </div>

  <nav class="px-4 space-y-1">
    <ul class="space-y-1">
      <li>
        <%= link_to admin_root_path,
            class: "flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900 dark:hover:text-blue-300 rounded-lg transition-colors #{'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' if current_path == admin_root_path}" do %>
          <%= lucide_icon "layout-dashboard", class: "w-5 h-5 mr-3" %>
          Dashboard
        <% end %>
      </li>

      <!-- Write your menu item here-->

      <!-- Generated by authentication: users -->
      <li>
        <%= link_to admin_users_path,
            class: "flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900 dark:hover:text-blue-300 rounded-lg transition-colors #{'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' if current_path.include?('/admin/users')}" do %>
          <%= lucide_icon "users", class: "w-5 h-5 mr-3" %>
          Users
        <% end %>
      </li>

      <!-- Generated by stripe_pay: payments -->
      <li>
        <%= link_to admin_payments_path,
            class: "flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900 dark:hover:text-blue-300 rounded-lg transition-colors #{'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' if current_path.include?('/admin/payments')}" do %>
          <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"/>
            <path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd"/>
          </svg>
          Payments
        <% end %>
      </li>

      <!-- Waitlist -->
      <li>
        <%= link_to waitlists_path,
            class: "flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900 dark:hover:text-blue-300 rounded-lg transition-colors #{'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' if current_path.include?('/waitlists')}" do %>
          <%= lucide_icon "mail", class: "w-5 h-5 mr-3" %>
          Waitlist
        <% end %>
      </li>

      <!-- Generated by admin_crud: site_settings -->
      <li>
        <%= link_to admin_site_settings_path,
            class: "flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900 dark:hover:text-blue-300 rounded-lg transition-colors #{'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' if current_path.include?('/admin/site_settings')}" do %>
          <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
          </svg>
          Site settings
        <% end %>
      </li>
    </ul>
  </nav>

  <div class="px-4 mt-6">
    <div class="border-t border-gray-200 dark:border-gray-700 pt-4">
      <div class="pb-2 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">SYSTEM</div>
    </div>
  </div>

  <nav class="px-4 space-y-1">
    <ul class="space-y-1">
      <li>
        <%= link_to admin_administrators_path,
            class: "flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900 dark:hover:text-blue-300 rounded-lg transition-colors #{'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' if current_path.include?('/admin/administrators')}" do %>
          <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
          </svg>
          Administrators
        <% end %>
      </li>
      <li>
        <%= link_to admin_admin_oplogs_path,
            class: "flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900 dark:hover:text-blue-300 rounded-lg transition-colors #{'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' if current_path.include?('/admin/admin_oplogs')}" do %>
          <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
          </svg>
          Operation Logs
        <% end %>
      </li>
    </ul>
  </nav>
</div>
