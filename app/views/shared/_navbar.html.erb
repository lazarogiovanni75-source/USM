              <%= link_to social_media_dashboard_path, class: "flex items-center gap-2 py-2 px-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" do %>
                <%= lucide_icon "layout-dashboard", class: "w-4 h-4 text-green-500" %>
                <span class="text-gray-900 dark:text-white">Social Media Dashboard</span>
              <% end %>
              <%= link_to scheduled_posts_path, class: "flex items-center gap-2 py-2 px-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" do %>
                <%= lucide_icon "calendar", class: "w-4 h-4 text-orange-500" %>
