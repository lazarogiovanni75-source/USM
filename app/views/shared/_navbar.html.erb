              <%= link_to ai_marketing_strategy_index_path, class: "flex items-center gap-2 py-2 px-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" do %>
                <%= lucide_icon "trending-up", class: "w-4 h-4 text-green-500" %>
