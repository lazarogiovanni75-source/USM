              <% end %>
              <%= link_to autopilot_index_path, class: "flex items-center gap-2 py-2 px-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" do %>
                <%= lucide_icon "rocket", class: "w-4 h-4 text-purple-500" %>
                <span class="text-gray-900 dark:text-white">Full Autopilot</span>
              <% end %>
              <div class="border-t border-gray-200 dark:border-gray-700 my-2"></div>
              <%= link_to competitor_tracking_index_path, class: "flex items-center gap-2 py-2 px-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" do %>
                <%= lucide_icon "search", class: "w-4 h-4 text-indigo-500" %>
                <span class="text-gray-900 dark:text-white">Competitor Tracking</span>
              <% end %>

              <%= link_to dashboard_path, class: "flex items-center gap-2 py-2 px-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" do %>
                <%= lucide_icon "layout-dashboard", class: "w-4 h-4 text-indigo-500" %>
                <span class="text-gray-900 dark:text-white">Dashboard</span>
              <% end %>
              <%= link_to pages_features_path, class: "flex items-center gap-2 py-2 px-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" do %>
                <%= lucide_icon "sparkles", class: "w-4 h-4 text-amber-500" %>
                <span class="text-gray-900 dark:text-white">Features</span>
              <% end %>
              <%= link_to pages_pricing_path, class: "flex items-center gap-2 py-2 px-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" do %>
                <%= lucide_icon "credit-card", class: "w-4 h-4 text-green-500" %>
