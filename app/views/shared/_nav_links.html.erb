<%# Navigation Links - Content only, no layout wrapper %>
<%# This partial will be rendered in different contexts (desktop horizontal / mobile vertical) %>
<%# The parent wrapper determines the layout %>

<%# Features Dropdown - accessible to all users %>
<li class="relative group/sub">
  <button class="flex items-center gap-2 px-4 py-2 text-secondary hover:text-primary transition-colors cursor-pointer">
    <%= lucide_icon "sparkles", class: "w-4 h-4" %>
    Features
    <%= lucide_icon "chevron-down", class: "w-4 h-4" %>
  </button>
  <div class="absolute left-0 top-full mt-2-white rounded-xl shadow w-56 bg-white border border-border/50 opacity-0 invisible group-hover/sub:opacity-100 group-hover/sub:visible transition-all z-50">
    <div class="py-2">
      <%= link_to ai_autopilot_index_path, class: "flex items-center gap-3 px-4 py-2.5 text-secondary hover:bg-surface hover:text-primary transition-colors" do %>
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center">
          <%= lucide_icon "bot", class: "w-4 h-4 text-white" %>
        </div>
        <div>
          <p class="font-medium text-primary">AI Autopilot</p>
          <p class="text-xs text-muted">Hands-free posting</p>
        </div>
      <% end %>
      <%= link_to ai_chat_index_path, class: "flex items-center gap-3 px-4 py-2.5 text-secondary hover:bg-surface hover:text-primary transition-colors" do %>
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center">
          <%= lucide_icon "message-square", class: "w-4 h-4 text-white" %>
        </div>
        <div>
          <p class="font-medium text-primary">AI Chat</p>
          <p class="text-xs text-muted">Conversations</p>
        </div>
      <% end %>
      <%= link_to content_creation_index_path, class: "flex items-center gap-3 px-4 py-2.5 text-secondary hover:bg-surface hover:text-primary transition-colors" do %>
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-red-500 to-rose-500 flex items-center justify-center">
          <%= lucide_icon "video", class: "w-4 h-4 text-white" %>
        </div>
        <div>
          <p class="font-medium text-primary">Sora 2 Pro</p>
          <p class="text-xs text-muted">Video generation</p>
        </div>
      <% end %>
      <%= link_to voice_commands_path, class: "flex items-center gap-3 px-4 py-2.5 text-secondary hover:bg-surface hover:text-primary transition-colors" do %>
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center">
          <%= lucide_icon "mic", class: "w-4 h-4 text-white" %>
        </div>
        <div>
          <p class="font-medium text-primary">Voice Commands</p>
          <p class="text-xs text-muted">Hands-free control</p>
        </div>
      <% end %>
      <div class="border-t border-border/50 my-2"></div>
      <%= link_to scheduled_posts_path, class: "flex items-center gap-3 px-4 py-2.5 text-secondary hover:bg-surface hover:text-primary transition-colors" do %>
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center">
          <%= lucide_icon "calendar", class: "w-4 h-4 text-white" %>
        </div>
        <div>
          <p class="font-medium text-primary">Scheduling</p>
          <p class="text-xs text-muted">Unlimited posts</p>
        </div>
      <% end %>
      <%= link_to campaigns_path, class: "flex items-center gap-3 px-4 py-2.5 text-secondary hover:bg-surface hover:text-primary transition-colors" do %>
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-green-500 to-emerald-500 flex items-center justify-center">
          <%= lucide_icon "megaphone", class: "w-4 h-4 text-white" %>
        </div>
        <div>
          <p class="font-medium text-primary">Campaigns</p>
          <p class="text-xs text-muted">AI strategies</p>
        </div>
      <% end %>
    </div>
  </div>
</li>

<%# Dashboard and main application features - accessible to all users %>
<%= link_to "Dashboard", dashboards_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
<%= link_to "Social Media", social_media_dashboard_index_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
<%= link_to "Connect Accounts", social_account_connections_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
<%= link_to "Calendar", calendar_index_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
<%= link_to "Content", contents_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
<%= link_to "Analytics", engagement_analytics_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
<%= link_to "Trends", trend_analyses_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
<%= link_to "Automation", automation_rules_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
<%= link_to "Auto-Responses", auto_response_triggers_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
<%= link_to "AI Tasks", scheduled_ai_tasks_path, class: "block px-3 py-2 md:p-0 rounded-lg md:rounded-none hover:bg-surface md:hover:bg-transparent text-secondary hover:text-primary transition-colors" %>
