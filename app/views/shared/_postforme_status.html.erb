<!-- Postforme Connection Status Indicator -->
<% postforme_status = local_assigns[:postforme_status] || { status: 'unknown', message: 'Checking...', profiles_count: 0 } %>

<div class="relative inline-flex items-center" data-controller="postforme-status">
  <% case postforme_status[:status] %>
  <% when 'connected' %>
    <div class="flex items-center gap-2 px-3 py-1.5 bg-green-50 border border-green-200 rounded-full">
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
      </span>
      <span class="text-xs font-medium text-green-700">Postforme <%= postforme_status[:message] %></span>
    </div>
  <% when 'error' %>
    <div class="flex items-center gap-2 px-3 py-1.5 bg-red-50 border border-red-200 rounded-full">
      <span class="relative flex h-2.5 w-2.5">
        <span class="inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span>
      </span>
      <span class="text-xs font-medium text-red-700"><%= postforme_status[:message] %></span>
      <%= link_to social_account_connections_path, class: "text-xs text-red-600 hover:text-red-800 underline" do %>
        Fix
      <% end %>
    </div>
  <% when 'unconfigured' %>
    <div class="flex items-center gap-2 px-3 py-1.5 bg-yellow-50 border border-yellow-200 rounded-full">
      <span class="relative flex h-2.5 w-2.5">
        <span class="inline-flex rounded-full h-2.5 w-2.5 bg-yellow-500"></span>
      </span>
      <span class="text-xs font-medium text-yellow-700">Postforme Not Connected</span>
      <%= link_to social_account_connections_path, class: "text-xs text-yellow-600 hover:text-yellow-800 underline" do %>
        Connect
      <% end %>
    </div>
  <% else %>
    <div class="flex items-center gap-2 px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-full">
      <span class="text-xs text-gray-500">Checking Postforme...</span>
    </div>
  <% end %>
</div>
