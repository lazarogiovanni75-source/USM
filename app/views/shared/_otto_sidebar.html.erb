<!-- Otto-Pilot Conversation Sidebar -->
<div id="otto-sidebar" class="fixed inset-0 z-[10000] hidden" data-controller="otto-sidebar">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" data-action="click->otto-sidebar#close"></div>
  
  <!-- Sidebar Panel -->
  <div id="otto-sidebar-panel" class="absolute left-0 top-0 bottom-0 w-80 max-w-[85vw] bg-white dark:bg-gray-900 shadow-2xl flex flex-col transform -translate-x-full transition-transform duration-300">
    <!-- Header -->
    <div class="px-4 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between bg-gradient-to-r from-primary to-purple-500">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-white/20 rounded-full flex items-center justify-center text-lg">🤖</div>
        <div>
          <div class="font-bold text-white text-base">Otto-Pilot</div>
          <div class="text-xs text-white/80">Conversations</div>
        </div>
      </div>
      <button data-action="click->otto-sidebar#close" class="w-8 h-8 rounded-lg flex items-center justify-center text-white hover:bg-white/20 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    
    <!-- New Chat Button -->
    <div class="p-3 border-b border-gray-200 dark:border-gray-700">
      <button data-action="click->otto-sidebar#newChat" class="w-full bg-primary/10 hover:bg-primary/20 text-primary dark:text-primary-light font-medium py-2.5 px-4 rounded-xl flex items-center justify-center gap-2 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        New Chat
      </button>
    </div>
    
    <!-- Conversation List -->
    <div id="otto-conversation-list" class="flex-1 overflow-y-auto" data-otto-sidebar-target="list">
      <div class="p-2">
        <div class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide px-2 py-2">Recent</div>
        <div id="otto-conversations-container">
          <!-- Conversations will be loaded here -->
          <div class="text-center py-8 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="mx-auto mb-2 opacity-50">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            <p class="text-sm">No conversations yet</p>
            <p class="text-xs mt-1">Start chatting to see them here</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #otto-sidebar.open #otto-sidebar-panel {
    transform: translateX(0) !important;
  }
  
  #otto-sidebar.open {
    display: block !important;
  }
  
  .otto-conversation-item {
    @apply flex items-center justify-between px-3 py-2.5 rounded-lg cursor-pointer transition-all group;
  }
  
  .otto-conversation-item:hover {
    @apply bg-gray-100 dark:bg-gray-800;
  }
  
  .otto-conversation-item.active {
    @apply bg-primary/10 border-l-4 border-primary;
  }
  
  .otto-conversation-delete {
    @apply opacity-0 group-hover:opacity-100 transition-opacity p-1 rounded hover:bg-red-100 dark:hover:bg-red-900/30;
  }
  
  .otto-conversation-delete:hover {
    @apply text-red-600 dark:text-red-400;
  }
</style>
