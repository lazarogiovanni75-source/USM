<!-- Otto-Pilot Floating Widget -->
<%= render 'shared/otto_sidebar' %>

<div id="otto-widget" class="otto-widget-closed" data-controller="otto">

  <!-- Chat Panel -->
  <div id="otto-panel" class="hidden flex-col w-96 h-[520px] bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-200 mb-3" data-otto-target="panel">
    <div id="otto-header" class="bg-gradient-to-r from-primary to-purple-500 px-3 py-2.5 flex items-center justify-between text-white gap-2">
      <div class="flex items-center gap-2 min-w-0 flex-shrink-0">
        <button data-action="click->otto#toggleSidebar" title="Conversations" class="w-7 h-7 rounded-lg flex items-center justify-center hover:bg-white/20 transition-colors flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center text-sm flex-shrink-0">🤖</div>
        <div class="min-w-0">
          <div id="otto-header-title" class="font-bold text-sm truncate">Otto-Pilot</div>
          <div class="text-xs opacity-80">AI Assistant</div>
        </div>
      </div>
      <div class="flex gap-1 flex-shrink-0">
        <select id="otto-language-select" data-action="change->otto#changeLanguage" class="bg-white/20 text-white text-xs px-2 py-1 rounded border-none cursor-pointer outline-none">
          <option value="en">English</option>
          <option value="af">Afrikaans</option>
          <option value="ar">Arabic</option>
          <option value="hy">Armenian</option>
          <option value="az">Azerbaijani</option>
          <option value="be">Belarusian</option>
          <option value="bs">Bosnian</option>
          <option value="bg">Bulgarian</option>
          <option value="ca">Catalan</option>
          <option value="zh">Chinese</option>
          <option value="hr">Croatian</option>
          <option value="cs">Czech</option>
          <option value="da">Danish</option>
          <option value="nl">Dutch</option>
          <option value="et">Estonian</option>
          <option value="fi">Finnish</option>
          <option value="fr">French</option>
          <option value="gl">Galician</option>
          <option value="de">German</option>
          <option value="el">Greek</option>
          <option value="he">Hebrew</option>
          <option value="hi">Hindi</option>
          <option value="hu">Hungarian</option>
          <option value="is">Icelandic</option>
          <option value="id">Indonesian</option>
          <option value="it">Italian</option>
          <option value="ja">Japanese</option>
          <option value="kn">Kannada</option>
          <option value="kk">Kazakh</option>
          <option value="ko">Korean</option>
          <option value="lv">Latvian</option>
          <option value="lt">Lithuanian</option>
          <option value="mk">Macedonian</option>
          <option value="ms">Malay</option>
          <option value="mr">Marathi</option>
          <option value="mi">Maori</option>
          <option value="ne">Nepali</option>
          <option value="no">Norwegian</option>
          <option value="fa">Persian</option>
          <option value="pl">Polish</option>
          <option value="pt">Portuguese</option>
          <option value="ro">Romanian</option>
          <option value="ru">Russian</option>
          <option value="sr">Serbian</option>
          <option value="sk">Slovak</option>
          <option value="sl">Slovenian</option>
          <option value="es">Spanish</option>
          <option value="sw">Swahili</option>
          <option value="sv">Swedish</option>
          <option value="tl">Tagalog</option>
          <option value="ta">Tamil</option>
          <option value="th">Thai</option>
          <option value="tr">Turkish</option>
          <option value="uk">Ukrainian</option>
          <option value="ur">Urdu</option>
          <option value="vi">Vietnamese</option>
          <option value="cy">Welsh</option>
        </select>
        <button id="otto-tts-btn" data-action="click->otto#toggleTTS" title="Toggle Text-to-Speech" class="w-8 h-8 rounded-lg flex items-center justify-center text-sm hover:bg-white/20 transition-colors">
          <svg id="otto-tts-off-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" clip-rule="evenodd"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/>
          </svg>
          <svg id="otto-tts-on-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
            <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
          </svg>
        </button>
        <button id="otto-voice-mode-btn" data-action="click->otto#toggleVoiceMode" title="Voice Mode" class="w-7 h-7 rounded-lg flex items-center justify-center text-sm hover:bg-white/20 transition-colors">
          <svg id="otto-voice-mode-auto-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <svg id="otto-voice-mode-manual-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </button>
        <button data-action="click->otto#clear" title="New Chat" class="w-7 h-7 rounded-lg flex items-center justify-center text-sm hover:bg-white/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
        </button>
        <button id="otto-onboarding-dismiss" data-action="click->otto#dismissOnboarding" title="Dismiss onboarding" class="hidden w-7 h-7 rounded-lg flex items-center justify-center text-sm hover:bg-white/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        <button data-action="click->otto#toggle" title="Close" class="w-7 h-7 rounded-lg flex items-center justify-center hover:bg-white/20 transition-colors">✕</button>
      </div>
    </div>

    <div id="otto-messages" class="flex-1 overflow-y-auto p-4 flex flex-col gap-3 bg-gray-50" data-otto-target="messages">
      <div class="otto-msg assistant flex justify-start">
        <div class="max-w-[80%] px-4 py-3 rounded-2xl rounded-bl-md bg-white text-gray-800 text-sm shadow-sm">
          👋 Hey! I'm Otto-Pilot, your AI assistant. I can help you write content, brainstorm ideas, answer questions, or anything else you need. What can I do for you today?
        </div>
      </div>
    </div>

    <div id="otto-input-area" class="p-3 bg-white border-t border-gray-100 flex items-end gap-2">
      <button id="otto-mic-btn" type="button" data-action="click->otto#toggleMic" class="w-10 h-10 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl flex items-center justify-center cursor-pointer transition-all flex-shrink-0 border-none">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
        </svg>
      </button>
      <textarea
        id="otto-input"
        data-action="keydown->otto#handleKeydown"
        data-otto-target="input"
        placeholder="Ask Otto anything..."
        rows="1"
        class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm resize-none outline-none focus:border-primary transition-colors leading-relaxed max-h-24 overflow-y-auto font-sans text-gray-900 bg-white" style="color: #111827 !important; -webkit-text-fill-color: #111827 !important;"
      ></textarea>
      <button id="otto-send" data-action="click->otto#send" class="w-10 h-10 bg-gradient-to-r from-primary to-purple-500 text-white rounded-xl flex items-center justify-center cursor-pointer hover:scale-105 transition-transform flex-shrink-0 border-none">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
      </button>
    </div>
    <div id="otto-voice-status" class="hidden px-3 py-2 bg-gray-50 text-center text-xs border-t border-gray-100">
      <span id="otto-status-text">Ready to record</span>
    </div>
  </div>

  <!-- Toggle Button (outside panel, always accessible) -->
  <button id="otto-toggle" data-action="click->otto#toggle" aria-label="Open Otto-Pilot" class="w-full bg-gradient-to-r from-primary to-purple-500 text-white border-none rounded-full px-5 py-3 cursor-pointer text-sm font-semibold shadow-lg hover:-translate-y-0.5 hover:shadow-xl transition-all duration-200 flex items-center justify-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
    </svg>
    <span>Otto-Pilot</span>
  </button>
</div>

<style>
  .otto-widget-closed, .otto-widget-open {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .otto-widget-open #otto-panel {
    display: flex !important;
  }

  .otto-widget-open #otto-toggle {
    background: #6b7280 !important;
  }

  #otto-messages::-webkit-scrollbar { width: 4px; }
  #otto-messages::-webkit-scrollbar-track { background: transparent; }
  #otto-messages::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 4px; }

  .otto-msg.user .otto-bubble {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    border-bottom-right-radius: 4px;
  }

  .otto-msg.assistant .otto-bubble {
    background: white;
    color: #1f2937;
    border-bottom-left-radius: 4px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  }

  .otto-typing .otto-bubble {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 14px;
  }

  .otto-dot {
    width: 7px;
    height: 7px;
    background: #9ca3af;
    border-radius: 50%;
    animation: ottoBounce 1.2s infinite;
  }

  .otto-dot:nth-child(2) { animation-delay: 0.2s; }
  .otto-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes ottoBounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-6px); }
  }

  #otto-mic-btn {
    display: flex !important;
  }

  #otto-mic-btn.recording {
    background: #ef4444 !important;
    color: white !important;
    animation: ottoPulse 1s infinite;
  }

  #otto-mic-btn.recording:hover {
    background: #dc2626 !important;
  }

  @keyframes ottoPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  #otto-voice-status.listening {
    background: #fef2f2;
    color: #dc2626;
  }

  #otto-voice-status.processing {
    background: #f0f9ff;
    color: #2563eb;
  }
  
  /* Mobile responsive */
  @media (max-width: 480px) {
    .otto-widget-closed, .otto-widget-open {
      bottom: 16px;
      right: 16px;
    }
    
    #otto-panel {
      width: calc(100vw - 32px) !important;
      height: calc(100vh - 120px) !important;
      max-height: 600px;
    }
  }
</style>
