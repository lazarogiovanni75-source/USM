<!-- Pricing Page -->
<div class="min-h-screen bg-gradient-to-br from-surface to-surface-elevated">
  <!-- Header -->
  <div class="bg-white/80 backdrop-blur-sm border-b border-border/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-4xl font-bold text-primary">Pricing & Plans</h1>
          <p class="mt-2 text-text-secondary">Choose the perfect plan for your social media journey</p>
        </div>
        <div class="flex items-center gap-3">
          <span class="badge badge-success">7-Day Free Trial</span>
          <a href="/" class="btn btn-ghost">Back to Home</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Dynamic Plans from Database -->
  <% if @plans.any? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% @plans.each do |plan| %>
          <div class="bg-white rounded-2xl shadow-lg border <%= plan.is_popular ? 'border-secondary ring-2 ring-secondary' : 'border-border/50' %> overflow-hidden relative">
            <% if plan.is_popular %>
              <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-secondary to-primary"></div>
              <div class="absolute top-0 right-0 bg-secondary text-white text-xs font-bold px-3 py-1 rounded-bl-lg">
                POPULAR
              </div>
            <% end %>
            
            <div class="p-6 <%= plan.is_popular ? 'bg-gradient-to-r from-secondary/10 to-primary/10' : 'bg-gradient-to-r from-primary/10 to-secondary/10' %> border-b border-border/50">
              <h3 class="text-2xl font-bold <%= plan.is_popular ? 'text-secondary' : 'text-primary' %>"><%= plan.name %></h3>
              <p class="text-5xl font-bold <%= plan.is_popular ? 'text-secondary' : 'text-primary' %> mt-4">$<%= plan.price_dollars.to_i %><span class="text-text-secondary text-lg">/month</span></p>
            </div>
            
            <div class="p-6 bg-surface-elevated">
              <% if plan.description.present? %>
                <p class="text-sm text-foreground mb-4"><%= plan.description %></p>
              <% end %>
              
              <% if plan.features_list.any? %>
                <ul class="space-y-2 text-sm text-foreground mb-6">
                  <% plan.features_list.each do |feature| %>
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                      <%= feature %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
              
              <% if @current_subscription&.subscription_plan_id == plan.id %>
                <button disabled class="w-full bg-gray-100 text-gray-400 font-semibold py-3 px-4 rounded-lg cursor-not-allowed">
                  Current Plan
                </button>
              <% elsif user_signed_in? %>
                <%= button_to 'Subscribe Now', 
                    subscriptions_path(plan_id: plan.id), 
                    method: :post,
                    class: "w-full #{plan.is_popular ? 'btn btn-secondary' : 'btn btn-primary'}" %>
              <% else %>
                <%= link_to 'Sign Up to Subscribe', sign_up_path, 
                    class: "block w-full text-center #{plan.is_popular ? 'btn btn-secondary' : 'btn btn-primary'}" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <!-- Fallback static plans if no plans in database -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Starter Plan -->
        <div class="bg-white rounded-2xl shadow-lg border border-border/50 overflow-hidden">
          <div class="p-6 bg-gradient-to-r from-blue-500/10 to-indigo-500/10 border-b border-border/50">
            <h3 class="text-2xl font-bold text-blue-600">Starter</h3>
            <p class="text-5xl font-bold text-blue-600 mt-4">$29<span class="text-text-secondary text-lg">/month</span></p>
          </div>
          <div class="p-6 bg-surface-elevated">
            <h4 class="font-semibold text-blue-600 mb-3">Account Limits: 3 Platforms, 10 Campaigns, 50 Posts/month</h4>
            <ul class="space-y-2 text-sm text-foreground">
              <li>Otto-Pilot post creation with AI content generation</li>
              <li>AI video storyboard generation</li>
              <li>Platform-specific content variations</li>
              <li>Recurring post scheduling</li>
              <li>Drag & drop calendar scheduling</li>
              <li>Media library for assets</li>
              <li>AI content assistant</li>
              <li>Dashboard with stats & metrics</li>
              <li>Post performance breakdown</li>
              <li>Social Media Management</li>
              <li>Multi-account management</li>
              <li>Unified inbox with AI response suggestions</li>
            </ul>
          </div>
        </div>

        <!-- Entrepreneur Plan -->
        <div class="bg-white rounded-2xl shadow-xl border-2 border-secondary/50 relative transform md:-translate-y-4">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-secondary to-primary"></div>
          <div class="p-6 bg-gradient-to-r from-secondary/10 to-primary/10 border-b border-border/50">
            <div class="flex items-center justify-between">
              <h3 class="text-2xl font-bold text-secondary">Entrepreneur</h3>
              <span class="badge badge-secondary">Most Popular</span>
            </div>
            <p class="text-5xl font-bold text-secondary mt-4">$59<span class="text-text-secondary text-lg">/month</span></p>
          </div>
          <div class="p-6 bg-surface-elevated">
            <h4 class="font-semibold text-secondary mb-3">Account Limits: 6 Platforms, 20 Campaigns, 100 Posts/month</h4>
            <p class="text-sm text-foreground mb-3">Everything in Starter, plus:</p>
            <ul class="space-y-2 text-sm text-foreground">
              <li>Publishing queue management</li>
              <li>Automated content workflows</li>
              <li>AI strategy generator</li>
              <li>AI settings & personality customization</li>
              <li>Auto-response manager</li>
              <li>Advanced analytics</li>
              <li>Stories/Reels analytics</li>
              <li>Competitor analytics & content gap analysis</li>
              <li>Campaign planner & wizard</li>
              <li>Link in bio pages</li>
            </ul>
          </div>
        </div>

        <!-- Pro Plan -->
        <div class="bg-white rounded-2xl shadow-lg border border-border/50 overflow-hidden">
          <div class="p-6 bg-gradient-to-r from-amber-500/10 to-orange-500/10 border-b border-border/50">
            <h3 class="text-2xl font-bold text-amber-600">Pro</h3>
            <p class="text-5xl font-bold text-amber-600 mt-4">$99<span class="text-text-secondary text-lg">/month</span></p>
          </div>
          <div class="p-6 bg-surface-elevated">
            <h4 class="font-semibold text-amber-600 mb-3">Account Limits: 9 Platforms, 30 Campaigns, 150 Posts/month</h4>
            <p class="text-sm text-foreground mb-3">Everything in Entrepreneur, plus:</p>
            <ul class="space-y-2 text-sm text-foreground">
              <li>Automated workflows & rules</li>
              <li>AI chatbot with lead capture & handover</li>
              <li>Performance predictions</li>
              <li>Trend alerts & monitoring</li>
              <li>A/B testing panel</li>
              <li>Custom report builder</li>
              <li>Audience demographics analysis</li>
              <li>Performance forecasting</li>
              <li>Brand mention monitoring</li>
              <li>Sentiment tracking & crisis detection</li>
              <li>Hashtag research & trending hashtags</li>
              <li>Influencer discovery & management</li>
              <li>Product opportunity identification</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Team & Support -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="bg-white rounded-2xl shadow-lg border border-border/50 p-6">
      <h2 class="text-2xl font-bold text-primary mb-6 text-center">Team & Support</h2>
      <ul class="space-y-2 text-text-secondary">
        <li>Support ticket system</li>
        <li>FAQ management</li>
        <li>Customer support interface</li>
        <li>Activity logs</li>
      </ul>
    </div>
  </div>
</div>
