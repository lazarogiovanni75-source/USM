<!-- About Page -->
<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">About Us</h1>
          <p class="mt-1 text-gray-600">Empowering businesses with AI-driven social media management</p>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to "Back to Home", root_path, class: "bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="p-8">
        <!-- Welcome Section -->
        <div class="mb-10">
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            Welcome to Ultimate Social Media – your all-in-one solution for mastering social media marketing. 
            Our mission is to empower businesses and individuals to take control of their social media presence 
            with ease and efficiency.
          </p>
          <p class="text-lg text-gray-700 leading-relaxed">
            At Ultimate Social Media, we understand the challenges of managing multiple social media accounts 
            and the need for seamless integration. That's why we've created a platform that not only consolidates 
            your communications but also provides powerful tools to optimize your marketing efforts.
          </p>
        </div>

        <!-- What Sets Us Apart -->
        <div class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 pb-2 border-b border-gray-200">What Sets Us Apart?</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- AI-Powered Insights -->
            <div class="flex gap-4 p-5 bg-gray-50 rounded-xl">
              <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
                <%= lucide_icon "sparkles", class: "w-6 h-6 text-primary" %>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">AI-Powered Insights</h3>
                <p class="text-gray-600">Our advanced AI algorithms provide personalized recommendations for content creation, optimal posting times, and trending hashtags.</p>
              </div>
            </div>

            <!-- Unified Communications -->
            <div class="flex gap-4 p-5 bg-gray-50 rounded-xl">
              <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
                <%= lucide_icon "message-square", class: "w-6 h-6 text-primary" %>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Unified Communications</h3>
                <p class="text-gray-600">Manage all your messages, comments, and mentions across multiple platforms from a single, intuitive dashboard.</p>
              </div>
            </div>

            <!-- Comprehensive Analytics -->
            <div class="flex gap-4 p-5 bg-gray-50 rounded-xl">
              <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
                <%= lucide_icon "bar-chart-3", class: "w-6 h-6 text-primary" %>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Comprehensive Analytics</h3>
                <p class="text-gray-600">Gain deep insights into your audience's behavior and track your competitors' strategies to stay ahead of the curve.</p>
              </div>
            </div>

            <!-- Custom Reports & Revenue Tracking -->
            <div class="flex gap-4 p-5 bg-gray-50 rounded-xl">
              <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
                <%= lucide_icon "file-text", class: "w-6 h-6 text-primary" %>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Custom Reports & Revenue Tracking</h3>
                <p class="text-gray-600">Monitor your ROI and campaign performance with detailed, customizable reports.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Closing Statement -->
        <div class="bg-gradient-to-r from-primary/5 to-secondary/5 rounded-xl p-6">
          <p class="text-lg text-gray-700 leading-relaxed text-center">
            At Ultimate Social Media, we are committed to continuously innovating and providing our users 
            with the best tools to succeed in the digital landscape. Join us and transform your social media strategy today!
          </p>
        </div>
      </div>
    </div>
  </div>
</div>