<!-- About Page -->
<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">About Ultimate Social Media</h1>
          <p class="mt-1 text-gray-600">Empowering businesses with AI-driven social media management</p>
        </div>
        <div class="flex items-center space-x-4">
          <%= link_to "Back to Home", root_path, class: "bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="p-8">
        <div class="prose max-w-none">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Mission</h2>
          <p class="text-gray-600 mb-6">
            Ultimate Social Media is revolutionizing how businesses manage their social media presence through 
            cutting-edge AI technology and voice-activated automation.
          </p>
          
          <h2 class="text-2xl font-bold text-gray-900 mb-4">What We Do</h2>
          <p class="text-gray-600 mb-6">
            We combine the power of artificial intelligence with intuitive voice commands to help businesses 
            create, schedule, and optimize their social media content across multiple platforms.
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Our Values</h3>
              <ul class="space-y-2 text-gray-600">
                <li>• Innovation through AI</li>
                <li>• User-friendly design</li>
                <li>• Data-driven insights</li>
                <li>• Continuous improvement</li>
              </ul>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Our Technology</h3>
              <ul class="space-y-2 text-gray-600">
                <li>• Advanced AI content generation</li>
                <li>• Real-time voice processing</li>
                <li>• Multi-platform integration</li>
                <li>• Predictive analytics</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>