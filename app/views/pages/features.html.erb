<% content_for :title, "Features - Ultimate Social Media" %>

<div class="min-h-screen bg-white dark:bg-gray-900">
  <!-- Hero Section -->
  <section class="py-20 px-4 bg-gradient-to-br from-purple-600 to-blue-500">
    <div class="container-xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 text-white;">Powerful Features for Social Media Success</h1>
      <p class="text-xl text-gray-200 max-w-2xl mx-auto;">Everything you need to create, schedule, and analyze your social media presence—all in one powerful platform.</p>
    </div>
  </section>

  <!-- Social Media Management -->
  <section class="py-16 px-4">
    <div class="container-xl mx-auto">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-500/10 rounded-full text-blue-600 font-medium mb-4">
          <%= lucide_icon "share-2", class: "w-5 h-5" %>
          <span>Social Media Management</span>
        </div>
        <h2 class="text-3xl font-bold mb-4 text-gray-900 dark:text-white;">Connect All Your Platforms</h2>
        <p class="text-gray-600 dark:text-gray-300 max-w-2xl mx-auto;">Manage all your social media accounts from one centralized dashboard.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card-hover bg-gray-50 dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "users", class: "w-6 h-6 text-blue-600" %>
          </div>
          <h3 class="font-semibold mb-2 text-gray-900 dark:text-white;">Multi-Account Management</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm;">Connect and manage up to 9 social accounts across multiple platforms.</p>
        </div>

        <div class="card-hover bg-gray-50 dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "megaphone", class: "w-6 h-6 text-blue-600" %>
          </div>
          <h3 class="font-semibold mb-2 text-gray-900 dark:text-white;">Multi-Platform Publishing</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm;">Publish to Facebook, Instagram, TikTok, and YouTube simultaneously.</p>
        </div>

        <div class="card-hover bg-gray-50 dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "smartphone", class: "w-6 h-6 text-blue-600" %>
          </div>
          <h3 class="font-semibold mb-2 text-gray-900 dark:text-white;">Platform-Specific Variations</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm;">Automatically adapt content for each platform's unique format and audience.</p>
        </div>

        <div class="card-hover bg-gray-50 dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "inbox", class: "w-6 h-6 text-blue-600" %>
          </div>
          <h3 class="font-semibold mb-2 text-gray-900 dark:text-white;">Unified Inbox</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm;">Manage all comments and messages from a single dashboard.</p>
        </div>

        <div class="card-hover bg-gray-50 dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "link", class: "w-6 h-6 text-blue-600" %>
          </div>
          <h3 class="font-semibold mb-2 text-gray-900 dark:text-white;">Link in Bio Pages</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm;">Create customizable link-in-bio pages to drive traffic.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Content Generation -->
