          <p class="text-gray-600 dark:text-gray-300 text-sm;">Create stunning images from text prompts for your posts.</p>
        </div>

        <div class="card-hover bg-white dark:bg-gray-700 rounded-2xl p-6 border border-gray-200 dark:border-gray-600">
          <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "video", class: "w-6 h-6 text-purple-600" %>
          </div>
          <h3 class="font-semibold mb-2 text-gray-900 dark:text-white;">AI Video Generation</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm;">Generate videos from text prompts to captivate your audience.</p>
        </div>

        <div class="card-hover bg-white dark:bg-gray-700 rounded-2xl p-6 border border-gray-200 dark:border-gray-600">
          <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "lightbulb", class: "w-6 h-6 text-purple-600" %>
          </div>
          <h3 class="font-semibold mb-2 text-gray-900 dark:text-white;">AI Content Ideas</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm;">Get AI-powered suggestions for content topics and themes.</p>
        </div>

        <div class="card-hover bg-white dark:bg-gray-700 rounded-2xl p-6 border border-gray-200 dark:border-gray-600">
          <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "image-plus", class: "w-6 h-6 text-purple-600" %>
