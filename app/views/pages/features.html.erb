<% content_for :title, "Features - Ultimate Social Media" %>

<div class="min-h-screen bg-white dark:bg-gray-900">
  <!-- Hero Section -->
  <section class="py-20 px-4 bg-gradient-to-br from-purple-600 to-blue-500">
    <div class="container-xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 text-white;">Powerful Features for Social Media Success</h1>
      <p class="text-xl text-gray-200 max-w-2xl mx-auto">Everything you need to create, schedule, and analyze your social media presence—all in one powerful platform.</p>
    </div>
  </section>

  <!-- AI-Powered Marketing -->
  <section class="py-16 px-4">
    <div class="container-xl mx-auto">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full text-primary font-medium mb-4">
          <%= lucide_icon "sparkles", class: "w-5 h-5" %>
          <span>AI-Powered Marketing</span>
        </div>
        <h2 class="text-3xl font-bold mb-4 text-white;">Intelligent Automation</h2>
        <p class="text-gray-300 max-w-2xl mx-auto">Let AI handle the heavy lifting while you focus on creating great content.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Otto-Pilot -->
        <div class="card-hover bg-gray-50 dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "bot", class: "w-6 h-6 text-primary" %>
          </div>
          <h3 class="font-semibold mb-2 text-white;">Otto-Pilot</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm">Automated content generation and posting based on your brand voice and audience preferences.</p>
        </div>

        <!-- Content Strategy Engine -->
        <div class="card-hover bg-gray-50 dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "brain", class: "w-6 h-6 text-primary" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Content Strategy Engine</h3>
          <p class="text-muted text-sm">AI analyzes your audience and generates comprehensive content strategies with actionable recommendations tailored to your goals.</p>
        </div>

        <!-- Strategy History -->
        <div class="card-hover bg-gray-50 dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "history", class: "w-6 h-6 text-primary" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Strategy History</h3>
          <p class="text-muted text-sm">Track your AI-generated strategies over time with detailed history, performance metrics, and trend analysis.</p>
        </div>

        <!-- Auto-Execute Recommendations -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "zap", class: "w-6 h-6 text-primary" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Auto-Execute Recommendations</h3>
          <p class="text-muted text-sm">Automatically turn AI-generated recommendations into scheduled posts with a single click.</p>
        </div>

        <!-- Weekly Auto-Analysis -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "calendar-days", class: "w-6 h-6 text-primary" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Weekly Auto-Analysis</h3>
          <p class="text-muted text-sm">Automated weekly analysis that evaluates your strategy performance and generates fresh insights every week.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Scheduling & Planning -->
  <section class="py-16 px-4 bg-gray-50 dark:bg-gray-800">
    <div class="container-xl mx-auto">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-500/10 rounded-full text-blue-600 font-medium mb-4">
          <%= lucide_icon "calendar", class: "w-5 h-5" %>
          <span>Scheduling & Planning</span>
        </div>
        <h2 class="text-3xl font-bold mb-4 text-white;">Smart Scheduling</h2>
        <p class="text-gray-300 max-w-2xl mx-auto">Post at the perfect times with intelligent scheduling that learns from your audience's behavior.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Smart Scheduling -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "clock", class: "w-6 h-6 text-blue-600" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Smart Scheduling</h3>
          <p class="text-muted text-sm">AI analyzes your audience activity patterns to determine the optimal posting times for maximum engagement.</p>
        </div>

        <!-- Calendar View -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "calendar-range", class: "w-6 h-6 text-blue-600" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Calendar View</h3>
          <p class="text-muted text-sm">Visual calendar to see your scheduled content at a glance and easily drag-and-drop to reschedule.</p>
        </div>

        <!-- Publishing Queue -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "list-ordered", class: "w-6 h-6 text-blue-600" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Publishing Queue</h3>
          <p class="text-muted text-sm">Queue up multiple posts and let the system distribute them evenly across your selected platforms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Analytics & Insights -->
  <section class="py-16 px-4">
    <div class="container-xl mx-auto">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-500/10 rounded-full text-green-600 font-medium mb-4">
          <%= lucide_icon "bar-chart-3", class: "w-5 h-5" %>
          <span>Analytics & Insights</span>
        </div>
        <h2 class="text-3xl font-bold mb-4 text-white;">Data-Driven Decisions</h2>
        <p class="text-gray-300 max-w-2xl mx-auto">Understand what's working and what's not with comprehensive analytics.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Trend Detection -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-green-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "trending-up", class: "w-6 h-6 text-green-600" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Trend Detection</h3>
          <p class="text-muted text-sm">Automatically identify emerging trends in your industry and suggest timely content opportunities.</p>
        </div>

        <!-- Sentiment Analysis -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-green-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "heart-handshake", class: "w-6 h-6 text-green-600" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Sentiment Analysis</h3>
          <p class="text-muted text-sm">AI analyzes comments and engagement to understand audience sentiment and emotional response to your content.</p>
        </div>

        <!-- Performance Forecasting -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-green-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "target", class: "w-6 h-6 text-green-600" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Performance Forecasting</h3>
          <p class="text-muted text-sm">Predict how your content will perform based on historical data and current trends.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Management -->
  <section class="py-16 px-4 bg-gray-50 dark:bg-gray-800">
    <div class="container-xl mx-auto">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-purple-500/10 rounded-full text-purple-600 font-medium mb-4">
          <%= lucide_icon "files", class: "w-5 h-5" %>
          <span>Content Management</span>
        </div>
        <h2 class="text-3xl font-bold mb-4 text-white;">Advanced Content Tools</h2>
        <p class="text-gray-300 max-w-2xl mx-auto">Create, manage, and reuse your content efficiently with powerful templates.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Advanced Post Templates -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "layout-template", class: "w-6 h-6 text-purple-600" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Advanced Post Templates</h3>
          <p class="text-muted text-sm">Create reusable templates with customizable variables for quick content generation while maintaining consistency.</p>
        </div>

        <!-- Content Library -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "library", class: "w-6 h-6 text-purple-600" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Content Library</h3>
          <p class="text-muted text-sm">Organize all your drafts, scheduled posts, and published content in one centralized location.</p>
        </div>

        <!-- Multi-Platform Publishing -->
        <div class="card-hover bg-surface-elevated rounded-2xl p-6 border border-border">
          <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-4">
            <%= lucide_icon "share-2", class: "w-6 h-6 text-purple-600" %>
          </div>
          <h3 class="font-semibold mb-2" style="color: white;">Multi-Platform Publishing</h3>
          <p class="text-muted text-sm">Publish to multiple social platforms simultaneously with platform-specific optimizations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4">
    <div class="container-xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-6 text-white;">Ready to Transform Your Social Media?</h2>
      <p class="text-gray-200 mb-8 max-w-xl mx-auto">Start using these powerful features today and see the difference AI can make in your social media strategy.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to "Get Started Free", new_user_registration_path, class: "btn-primary px-8 py-3 text-lg" %>
        <%= link_to "View Pricing", pages_pricing_path, class: "btn-secondary px-8 py-3 text-lg" %>
      </div>
    </div>
  </section>
</div>
