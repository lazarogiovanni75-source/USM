<div class="min-h-screen bg-gray-50">
  <div class="max-w-3xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">New Webhook</h1>
          <p class="mt-2 text-gray-600">Create a new webhook to automate your workflows</p>
        </div>
        <%= link_to zapier_webhooks_path, 
            class: "text-gray-600 hover:text-gray-700 text-sm font-medium" do %>
          <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-1 inline" %>
          Back to Webhooks
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200">
      <div class="p-6">
        <%= form_with(model: @webhook, local: true, class: "space-y-6") do |form| %>
          <% if @webhook.errors.any? %>
            <div class="bg-red-50 border border-red-200 rounded-lg p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <%= lucide_icon "alert-triangle", class: "w-5 h-5 text-red-400" %>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-red-800">
                    <%= pluralize(@webhook.errors.count, "error") %> prohibited this webhook from being saved:
                  </h3>
                  <div class="mt-2 text-sm text-red-700">
                    <ul class="list-disc list-inside space-y-1">
                      <% @webhook.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Basic Information -->
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-medium text-gray-900 mb-4">Basic Information</h3>
              
              <div class="grid grid-cols-1 gap-6">
                <div>
                  <%= form.label :name, "Webhook Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.text_field :name, 
                      class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500",
                      placeholder: "e.g., Slack Notification, Google Sheets Export" %>
                </div>

                <div>
                  <%= form.label :webhook_url, "Webhook URL", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.text_field :webhook_url, 
                      class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500",
                      placeholder: "https://hooks.zapier.com/hooks/catch/..." %>
                  <p class="mt-1 text-sm text-gray-500">The URL provided by your Zapier integration</p>
                </div>

                <div>
                  <%= form.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.select :status, 
                      [['Active', 'active'], ['Inactive', 'inactive']], 
                      {}, 
                      { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" } %>
                </div>
              </div>
            </div>

            <!-- Trigger Events -->
            <div>
              <h3 class="text-lg font-medium text-gray-900 mb-4">Trigger Events</h3>
              <p class="text-sm text-gray-600 mb-4">Select the events that should trigger this webhook:</p>
              
              <div class="space-y-3">
                <div class="flex items-center">
                  <%= form.check_box :trigger_content_created, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
                  <%= form.label :trigger_content_created, "Content Created", class: "ml-2 block text-sm text-gray-900" %>
                </div>
                
                <div class="flex items-center">
                  <%= form.check_box :trigger_post_published, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
                  <%= form.label :trigger_post_published, "Post Published", class: "ml-2 block text-sm text-gray-900" %>
                </div>
                
                <div class="flex items-center">
                  <%= form.check_box :trigger_engagement_received, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
                  <%= form.label :trigger_engagement_received, "High Engagement Received", class: "ml-2 block text-sm text-gray-900" %>
                </div>
                
                <div class="flex items-center">
                  <%= form.check_box :trigger_scheduled_post, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
                  <%= form.label :trigger_scheduled_post, "Scheduled Post Created", class: "ml-2 block text-sm text-gray-900" %>
                </div>
                
                <div class="flex items-center">
                  <%= form.check_box :trigger_weekly_summary, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
                  <%= form.label :trigger_weekly_summary, "Weekly Summary", class: "ml-2 block text-sm text-gray-900" %>
                </div>
                
                <div class="flex items-center">
                  <%= form.check_box :trigger_competitor_detected, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
                  <%= form.label :trigger_competitor_detected, "Competitor Content Detected", class: "ml-2 block text-sm text-gray-900" %>
                </div>
              </div>
            </div>

            <!-- Advanced Configuration -->
            <div>
              <h3 class="text-lg font-medium text-gray-900 mb-4">Advanced Configuration</h3>
              
              <div class="space-y-4">
                <div>
                  <%= form.label :event_type, "Event Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.select :event_type, 
                      [['Generic', 'generic'], ['Content', 'content'], ['Engagement', 'engagement'], ['Scheduling', 'scheduling']], 
                      {}, 
                      { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" } %>
                </div>

                <div>
                  <%= form.label :config, "Custom Configuration (JSON)", class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.text_area :config, 
                      class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 font-mono text-sm",
                      rows: 4,
                      placeholder: '{"include_metrics": true, "format": "detailed"}' %>
                  <p class="mt-1 text-sm text-gray-500">Optional JSON configuration for advanced webhook behavior</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex items-center justify-between pt-6 border-t border-gray-200">
            <%= link_to zapier_webhooks_path, 
                class: "px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors" do %>
              Cancel
            <% end %>
            
            <%= form.submit "Create Webhook", 
                class: "px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Help Section -->
    <div class="mt-8 bg-gray-50 border border-gray-200 rounded-lg p-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <%= lucide_icon "help-circle", class: "w-5 h-5 text-gray-400" %>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-gray-900">Need Help?</h3>
          <div class="mt-2 text-sm text-gray-600">
            <p class="mb-2">Get started with our most popular templates:</p>
            <div class="flex flex-wrap gap-2">
              <% @workflow_templates.first(3).each do |template| %>
                <%= link_to template[:name], 
                    create_from_template_zapier_webhooks_path(template_id: template[:id]),
                    method: :post,
                    class: "inline-block text-xs px-3 py-1 bg-white border border-gray-300 rounded-full text-gray-700 hover:bg-gray-50" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>